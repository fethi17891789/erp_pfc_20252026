@page
@model erp_pfc_20252026.Pages.Achats.HubModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Module Achats";
    Layout = "~/Presentation/view/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Achats.css" asp-append-version="true" />
}

@section HeaderLeft {
    <div class="breadcrumb">
        <span class="breadcrumb-item breadcrumb-active">Achats</span>
    </div>
}

<section class="erp-content">

    @* ── Bannière si non configuré ─────────────────────────────────────────── *@
    @if (!Model.EstConfigure)
    {
        <div style="display:flex;align-items:center;gap:14px;padding:16px 22px;background:rgba(251,191,36,0.06);border:1px solid rgba(251,191,36,0.25);border-radius:14px;margin-bottom:24px;">
            <svg viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" style="width:20px;height:20px;flex-shrink:0;">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span style="font-size:13px;color:var(--text-muted);flex:1;">
                Le module Achats n'est pas encore configuré. Certaines fonctionnalités sont désactivées.
            </span>
            <a asp-page="/Achats/Config" style="font-size:0.75rem;font-weight:700;color:var(--accent);background:rgba(123,94,255,0.12);border:1px solid rgba(123,94,255,0.25);border-radius:8px;padding:5px 14px;text-decoration:none;">Configurer →</a>
        </div>
    }

    <div class="section-header">
        <h2>Module Achats</h2>
    </div>

    <div class="modules-grid">

        @* ── Bons de commande ──────────────────────────────────────────────── *@
        <article class="module-tile">
            <div class="module-tile-header">
                <div class="module-circle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 01-8 0"/>
                    </svg>
                </div>
                <span class="module-badge">BC</span>
            </div>
            <h3>Bons de commande</h3>
            <p>Créez et suivez vos commandes fournisseurs. Envoi automatique avec lien de confirmation pour le fournisseur.@(Model.EstConfigure && Model.NbBCEnAttente > 0 ? $" ({Model.NbBCEnAttente} en attente)" : "")</p>
            <div class="module-tile-footer">
                <span class="module-status-dot"></span>
                <span class="module-status-text">@(Model.EstConfigure ? "Actif" : "Configuration requise")</span>
                <a asp-page="/Achats/Index" class="module-action-link">
                    <button class="module-action" type="button">Ouvrir</button>
                </a>
            </div>
        </article>

        @* ── Bons de réception ─────────────────────────────────────────────── *@
        <article class="module-tile">
            <div class="module-tile-header">
                <div class="module-circle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                        <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                    </svg>
                </div>
                <span class="module-badge">BR</span>
            </div>
            <h3>Bons de réception</h3>
            <p>Enregistrez la réception des marchandises. Contrôlez les quantités et l'état de chaque article reçu.</p>
            <div class="module-tile-footer">
                <span class="module-status-dot"></span>
                <span class="module-status-text">@(Model.EstConfigure ? "Actif" : "Configuration requise")</span>
                <a asp-page="/Achats/Index" asp-route-filtre="receptions" class="module-action-link">
                    <button class="module-action" type="button">Ouvrir</button>
                </a>
            </div>
        </article>

        @* ── Factures fournisseurs ─────────────────────────────────────────── *@
        <article class="module-tile">
            <div class="module-tile-header">
                <div class="module-circle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="7" y1="13" x2="17" y2="13"/>
                        <line x1="7" y1="17" x2="13" y2="17"/>
                    </svg>
                </div>
                <span class="module-badge">Factures</span>
            </div>
            <h3>Factures fournisseurs</h3>
            <p>Rapprochez les factures fournisseurs avec vos bons de commande. Détection automatique des écarts de prix.</p>
            <div class="module-tile-footer">
                <span class="module-status-dot"></span>
                <span class="module-status-text">@(Model.EstConfigure ? "Actif" : "Configuration requise")</span>
                <a asp-page="/Achats/Index" asp-route-filtre="factures" class="module-action-link">
                    <button class="module-action" type="button">Ouvrir</button>
                </a>
            </div>
        </article>

        @* ── Analyse des prix ──────────────────────────────────────────────── *@
        <article class="module-tile">
            <div class="module-tile-header">
                <div class="module-circle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                </div>
                <span class="module-badge">IA · Innovation</span>
            </div>
            <h3>Analyse des prix</h3>
            <p>Visualisez l'historique des prix par fournisseur, simulez des hausses et anticipez les variations.</p>
            <div class="module-tile-footer">
                <span class="module-status-dot"></span>
                <span class="module-status-text">Graphiques & simulateur</span>
                <a asp-page="/Achats/AnalysePrix" class="module-action-link">
                    <button class="module-action" type="button">Analyser</button>
                </a>
            </div>
        </article>

        @* ── Configuration ─────────────────────────────────────────────────── *@
        <article class="module-tile">
            <div class="module-tile-header">
                <div class="module-circle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
                    </svg>
                </div>
                <span class="module-badge">Paramètres</span>
            </div>
            <h3>Configuration</h3>
            <p>@(Model.EstConfigure ? "Module configuré. Modifiez la politique de prix et les paramètres du module." : "Configurez le module : choisissez la politique de prix pour démarrer.")</p>
            <div class="module-tile-footer">
                <span class="module-status-dot"></span>
                <span class="module-status-text">@(Model.EstConfigure ? "Configuré" : "Non configuré")</span>
                <a asp-page="/Achats/Config" class="module-action-link">
                    <button class="module-action" type="button">@(Model.EstConfigure ? "Modifier" : "Configurer")</button>
                </a>
            </div>
        </article>

    </div>

</section>
