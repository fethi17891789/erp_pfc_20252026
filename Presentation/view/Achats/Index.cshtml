@page
@model erp_pfc_20252026.Pages.Achats.IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using global::Donnees.Achats

@{
    ViewData["Title"] = "Achats";
    Layout = "~/Presentation/view/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Achats.css" asp-append-version="true" />
}

@section HeaderLeft {
    <div class="breadcrumb">
        <span class="breadcrumb-item breadcrumb-active">Achats</span>
    </div>
}

@if (Model.MessageSucces != null)
{
    <div id="bc-toast" class="bc-toast bc-toast-visible">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:16px;height:16px;flex-shrink:0;">
            <polyline points="20 6 9 17 4 12"/>
        </svg>
        @Model.MessageSucces
    </div>
}

<div class="achats-page">

    @* ── EN-TÊTE ──────────────────────────────────────────────────────────── *@
    <div class="achats-page-header">
        <div>
            <h1 class="achats-page-title">@Model.TitreFiltre</h1>
            <p class="achats-page-subtitle">@Model.SousTitreFiltre</p>
        </div>
        <div style="display:flex;align-items:center;gap:10px;">
            @if (!string.IsNullOrEmpty(Model.Filtre))
            {
                <a asp-page="/Achats/Index" class="bc-btn-filtre-reset">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                    Tous les BCs
                </a>
            }
            <a asp-page="/Achats/BonCommande" class="btn-primary bc-btn-nouveau">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:14px;height:14px;">
                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Nouveau bon de commande
            </a>
        </div>
    </div>

    @* ── KPI CARDS ─────────────────────────────────────────────────────────── *@
    <div class="bc-kpi-grid">
        <div class="bc-kpi-card">
            <div class="bc-kpi-icon bc-kpi-icon-blue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px;">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            <div class="bc-kpi-content">
                <span class="bc-kpi-num">@Model.NbBCEnCours</span>
                <span class="bc-kpi-label">En attente de réponse</span>
            </div>
        </div>
        <div class="bc-kpi-card">
            <div class="bc-kpi-icon bc-kpi-icon-green">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px;">
                    <polyline points="20 6 9 17 4 12"/>
                </svg>
            </div>
            <div class="bc-kpi-content">
                <span class="bc-kpi-num">@Model.NbBCConfirmes</span>
                <span class="bc-kpi-label">Confirmés — à réceptionner</span>
            </div>
        </div>
        <div class="bc-kpi-card">
            <div class="bc-kpi-icon bc-kpi-icon-red">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px;">
                    <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
            </div>
            <div class="bc-kpi-content">
                <span class="bc-kpi-num">@Model.NbBCRefuses</span>
                <span class="bc-kpi-label">Refusés</span>
            </div>
        </div>
        <div class="bc-kpi-card">
            <div class="bc-kpi-icon bc-kpi-icon-purple">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px;">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                </svg>
            </div>
            <div class="bc-kpi-content">
                <span class="bc-kpi-num">@Model.NbBCFactures</span>
                <span class="bc-kpi-label">Facturés</span>
            </div>
        </div>
    </div>

    @* ── RECHERCHE ─────────────────────────────────────────────────────────── *@
    <div class="bc-search-bar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:15px;height:15px;color:var(--text-muted-2);">
            <circle cx="11" cy="11" r="6"/><line x1="16" y1="16" x2="20" y2="20"/>
        </svg>
        <input type="text" class="bc-search-input" placeholder="Rechercher par numéro, fournisseur..."
               oninput="filtrerBC(this.value)" />
    </div>

    @* ── LISTE DES BC ──────────────────────────────────────────────────────── *@
    @if (!Model.BonCommandes.Any())
    {
        <div class="bc-empty-state">
            <div class="bc-empty-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:36px;height:36px;color:var(--accent);">
                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 01-8 0"/>
                </svg>
            </div>
            @if (Model.Filtre == "receptions")
            {
                <h3>Aucun BC en attente de réception</h3>
                <p>Les BCs confirmés par le fournisseur apparaîtront ici.</p>
                <a asp-page="/Achats/Index" class="btn-primary">Voir tous les BCs</a>
            }
            else if (Model.Filtre == "factures")
            {
                <h3>Aucun BC prêt à être facturé</h3>
                <p>Les BCs réceptionnés pour lesquels une facture peut être enregistrée apparaîtront ici.</p>
                <a asp-page="/Achats/Index" class="btn-primary">Voir tous les BCs</a>
            }
            else
            {
                <h3>Aucun bon de commande</h3>
                <p>Créez votre premier bon de commande pour démarrer vos achats.</p>
                <a asp-page="/Achats/BonCommande" class="btn-primary">Créer un bon de commande</a>
            }
        </div>
    }
    else
    {
        <div class="bc-cards-grid" id="bc-list">
            @foreach (var bc in Model.BonCommandes)
            {
                var (statBg, statColor, statLabel) = BonCommandeModel.GetStatutStyle(bc.Statut);
                <a asp-page="/Achats/BonCommande" asp-route-id="@bc.Id" class="bc-card" data-search="@bc.Numero @bc.Fournisseur?.FullName">
                    <div class="bc-card-top">
                        <span class="bc-card-num">@bc.Numero</span>
                        <span class="bc-statut-badge" style="background:@statBg;color:@statColor;border:1px solid @statColor;">
                            @statLabel
                        </span>
                    </div>
                    <div class="bc-card-fournisseur">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;color:var(--text-muted-2);">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                        @(bc.Fournisseur?.FullName ?? "—")
                    </div>
                    <div class="bc-card-footer">
                        <span class="bc-card-ttc">@bc.TotalTTC.ToString("N2") DZD TTC</span>
                        <span class="bc-card-date">@bc.DateCommande.ToString("dd/MM/yyyy")</span>
                    </div>
                </a>
            }
        </div>
    }
</div>

@section Scripts {
<script>
const toast = document.getElementById('bc-toast');
if (toast) setTimeout(() => toast.classList.remove('bc-toast-visible'), 4000);

function filtrerBC(q) {
    const query = q.toLowerCase().trim();
    document.querySelectorAll('.bc-card').forEach(card => {
        const search = card.dataset.search?.toLowerCase() || '';
        card.style.display = !query || search.includes(query) ? '' : 'none';
    });
}
</script>
}
