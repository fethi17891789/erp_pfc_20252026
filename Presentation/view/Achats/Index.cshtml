@page
@model erp_pfc_20252026.Pages.Achats.IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using global::Donnees.Achats
@using System.Text.Json

@{
    ViewData["Title"] = "Commandes";
    Layout = "~/Presentation/view/Shared/_Layout.cshtml";

    // Données commandes pour JS (filtrage/tri côté client sur la liste déjà filtrée serveur)
    var commandesJson = JsonSerializer.Serialize(Model.BonCommandes.Select(bc =>
    {
        var (statBg, statColor, statLabel) = BonCommandeModel.GetStatutStyle(bc.Statut);
        return new
        {
            id          = bc.Id,
            numero      = bc.Numero,
            fournisseur = bc.Fournisseur?.FullName ?? "—",
            statut      = bc.Statut,
            statutLabel = statLabel,
            statutBg    = statBg,
            statutColor = statColor,
            totalTTC    = bc.TotalTTC,
            totalTTCStr = bc.TotalTTC.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("fr-FR")),
            date        = bc.DateCommande.ToString("dd/MM/yyyy"),
            dateTs      = bc.DateCommande.Ticks,
            search      = (bc.Numero + " " + (bc.Fournisseur?.FullName ?? "")).ToLower()
        };
    }));
}

@section Styles {
    <link rel="stylesheet" href="~/css/Achats.css" asp-append-version="true" />
    <style>
        /* ─── TOOLBAR ───────────────────────────────────────────── */
        .ach-toolbar {
            display: flex; align-items: center; gap: 10px; margin-bottom: 20px;
        }
        .filter-dd-item {
            display: flex; align-items: center; justify-content: space-between; width: 100%;
            padding: 8px 12px; border: none; background: transparent;
            color: var(--text-muted); font-size: 0.83rem; font-weight: 500;
            cursor: pointer; border-radius: 7px; font-family: inherit;
            transition: background .15s, color .15s; text-decoration: none;
        }
        .filter-dd-item:hover { background: rgba(123,94,255,0.10); color: var(--text); }
        .filter-dd-item.active { background: rgba(123,94,255,0.12); color: var(--accent-light); font-weight: 600; }
        .filter-dd-count {
            background: rgba(255,255,255,0.07); border-radius: 999px;
            padding: 1px 8px; font-size: 0.75rem; font-weight: 700;
        }

        .ach-view-toggle {
            display: flex; gap: 2px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px; padding: 3px;
        }
        .ach-view-btn {
            width: 32px; height: 32px; border: none;
            background: transparent; border-radius: 7px;
            color: var(--text-muted); cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: all .15s;
        }
        .ach-view-btn:hover { color: var(--text); }
        .ach-view-btn.active { background: rgba(123,94,255,0.20); color: var(--accent-light); }

        /* ─── LIST VIEW ─────────────────────────────────────────── */
        .ach-list-wrap {
            max-height: 65vh; overflow-y: auto; padding-right: 4px;
            scrollbar-width: thin; scrollbar-color: rgba(123,94,255,0.30) transparent;
        }
        .ach-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
        .ach-table thead th {
            padding: 10px 14px; text-align: left;
            color: var(--text-muted); font-size: 0.72rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.4px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
            cursor: pointer; user-select: none; white-space: nowrap;
            transition: color .15s;
        }
        .ach-table thead th:hover { color: var(--accent-light); }
        .ach-table thead th .sort-arrow { display: inline-block; margin-left: 4px; opacity: 0.4; font-size: 0.75rem; }
        .ach-table thead th.sorted .sort-arrow { opacity: 1; color: var(--accent-light); }
        .ach-table tbody tr {
            border-bottom: 1px solid rgba(255,255,255,0.04);
            transition: background .12s;
        }
        .ach-table tbody tr:hover td { background: rgba(123,94,255,0.04); }
        .ach-table tbody td { padding: 10px 14px; color: var(--text); vertical-align: middle; }
        .ach-table .td-name { font-weight: 600; white-space: nowrap; }
        .ach-table .td-muted { color: var(--text-muted); font-size: 0.82rem; white-space: nowrap; }
        .ach-table .td-num { font-weight: 700; color: var(--accent-light); white-space: nowrap; }

        /* ─── EMPTY STATE ───────────────────────────────────────── */
        .ach-empty {
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; padding: 60px 20px; gap: 14px;
            color: var(--text-muted); text-align: center;
        }
        .ach-empty svg { opacity: 0.35; }
        .ach-empty p { font-size: 0.9rem; margin: 0; }
        .ach-empty .ach-empty-title { font-size: 1.05rem; font-weight: 700; color: var(--text); margin: 0; }

        /* ─── SCROLLBAR ─────────────────────────────────────────── */
        #viewGrid::-webkit-scrollbar,
        .ach-list-wrap::-webkit-scrollbar { width: 6px; }
        #viewGrid::-webkit-scrollbar-thumb,
        .ach-list-wrap::-webkit-scrollbar-thumb { background: rgba(123,94,255,0.30); border-radius: 3px; }
    </style>
}

@section HeaderLeft {
    <h1>Commandes</h1>
    <p>@Model.NbTotalCommandes commande@(Model.NbTotalCommandes > 1 ? "s" : "") — bons de commande, réceptions et factures fournisseurs</p>
}

@if (Model.MessageSucces != null)
{
    <div id="bc-toast" class="bc-toast bc-toast-visible">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:16px;height:16px;flex-shrink:0;">
            <polyline points="20 6 9 17 4 12"/>
        </svg>
        @Model.MessageSucces
    </div>
}

<section class="erp-content">

    <!-- ═══ TOOLBAR ═════════════════════════════════════════════════ -->
    <div class="ach-toolbar">

        <!-- Filtre dropdown (gauche) -->
        <div style="position:relative; flex-shrink:0;">
            <button id="btnFilter" type="button" onclick="toggleFilterDropdown(event)"
                    style="display:inline-flex;align-items:center;gap:7px;padding:7px 13px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:var(--text-muted);font-size:0.8rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .18s;"
                    onmouseover="this.style.borderColor='rgba(123,94,255,0.45)';this.style.color='var(--text)';"
                    onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='var(--text-muted)';">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                Filtre
                <span id="filterActiveLabel" style="color:var(--accent-light);font-weight:700;font-size:0.78rem;">
                    @{
                        var activeLabel = Model.Filtre switch
                        {
                            "receptions" => "· Bons de réception",
                            "factures"   => "· Factures fournisseurs",
                            _            => ""
                        };
                    }
                    @activeLabel
                </span>
                <svg id="filterArrow" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" style="transition:transform .2s;margin-left:2px;"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div id="filterDropdown"
                 style="display:none;position:absolute;left:0;top:calc(100% + 6px);background:#0c1124;border:1px solid rgba(123,94,255,0.22);border-radius:10px;padding:5px;box-shadow:0 14px 36px rgba(0,0,0,0.55);min-width:240px;z-index:200;">
                <a asp-page="/Achats/Index"
                   class="filter-dd-item @(string.IsNullOrEmpty(Model.Filtre) ? "active" : "")">
                    <span>Bons de commande</span>
                    <span class="filter-dd-count">@Model.NbTotalCommandes</span>
                </a>
                <a asp-page="/Achats/Index" asp-route-filtre="receptions"
                   class="filter-dd-item @(Model.Filtre == "receptions" ? "active" : "")">
                    <span>Bons de réception</span>
                    <span class="filter-dd-count">@Model.NbTotalReceptions</span>
                </a>
                <a asp-page="/Achats/Index" asp-route-filtre="factures"
                   class="filter-dd-item @(Model.Filtre == "factures" ? "active" : "")">
                    <span>Factures fournisseurs</span>
                    <span class="filter-dd-count">@Model.NbTotalFactures</span>
                </a>
            </div>
        </div>

        <!-- Recherche (centré) -->
        <div style="flex:1; display:flex; justify-content:center;">
            <div class="job-input-wrapper" style="max-width:420px; width:100%;">
                <input type="text" id="searchInput" class="job-input" placeholder="Rechercher numéro, fournisseur..."
                       oninput="applyFilters()">
                <span class="job-input-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;">
                        <circle cx="11" cy="11" r="6"/><line x1="16" y1="16" x2="20" y2="20"/>
                    </svg>
                </span>
            </div>
        </div>

        <!-- Vue + actions (droite) -->
        <div style="display:flex; align-items:center; gap:10px; flex-shrink:0;">
            <!-- Vue toggle -->
            <div style="display:flex; align-items:center; gap:7px;">
                <span style="font-size:0.78rem; color:var(--text-muted); font-weight:600;">Vue</span>
                <div class="ach-view-toggle">
                    <button class="ach-view-btn active" id="btnGrid" type="button" onclick="setView('grid')" title="Grille">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15"><path d="M3 3h7v7H3zm0 11h7v7H3zm11-11h7v7h-7zm0 11h7v7h-7z"/></svg>
                    </button>
                    <button class="ach-view-btn" id="btnList" type="button" onclick="setView('list')" title="Liste">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                    </button>
                </div>
            </div>

            <!-- Nouveau BC -->
            <a asp-page="/Achats/BonCommande"
               class="sidebar-quick"
               style="display:inline-flex;align-items:center;gap:6px;padding-inline:16px;text-decoration:none;">
                <span>Nouveau bon de commande</span>
                <span style="font-size:16px;line-height:1">+</span>
            </a>
        </div>
    </div>

    <!-- ═══ VUE GRILLE (cartes style MRP) ═══════════════════════════ -->
    <div id="viewGrid"
         style="display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:16px; max-height:70vh; overflow-y:auto; padding-right:8px;">
        <!-- Contenu injecté par JS via renderGrid() -->
    </div>

    <!-- ═══ VUE LISTE ════════════════════════════════════════════════ -->
    <div id="viewList" style="display:none;">
        <div class="ach-list-wrap">
            <table class="ach-table">
                <thead>
                    <tr>
                        <th onclick="sortBy('numero')" data-col="numero">Numéro <span class="sort-arrow">↕</span></th>
                        <th onclick="sortBy('fournisseur')" data-col="fournisseur">Fournisseur <span class="sort-arrow">↕</span></th>
                        <th>Statut</th>
                        <th onclick="sortBy('totalTTC')" data-col="totalTTC" style="text-align:right;">Total TTC <span class="sort-arrow">↕</span></th>
                        <th onclick="sortBy('dateTs')" data-col="dateTs" class="sorted"><span style="">Date</span> <span class="sort-arrow">↓</span></th>
                    </tr>
                </thead>
                <tbody id="listBody">
                    <!-- Contenu injecté par JS via renderList() -->
                </tbody>
            </table>
        </div>
    </div>

</section>

@section Scripts {
<script>
// ═══════════════════════════════════════════════════════════════════
//  DONNÉES
// ═══════════════════════════════════════════════════════════════════
const ALL_COMMANDES = @Html.Raw(commandesJson);

let currentSort = { col: 'dateTs', dir: -1 };
let filtered    = [...ALL_COMMANDES];
let currentView = 'grid';

// ─── Toast ─────────────────────────────────────────────────────────
const toast = document.getElementById('bc-toast');
if (toast) setTimeout(() => toast.classList.remove('bc-toast-visible'), 4000);

// ═══════════════════════════════════════════════════════════════════
//  DROPDOWN FILTRE (navigation serveur via ?filtre=)
// ═══════════════════════════════════════════════════════════════════
let filterOpen = false;

function toggleFilterDropdown(e) {
    e.stopPropagation();
    filterOpen = !filterOpen;
    const dd = document.getElementById('filterDropdown');
    const arrow = document.getElementById('filterArrow');
    dd.style.display = filterOpen ? 'block' : 'none';
    arrow.style.transform = filterOpen ? 'rotate(180deg)' : '';
}

function closeFilterDropdown() {
    filterOpen = false;
    const dd = document.getElementById('filterDropdown');
    const arrow = document.getElementById('filterArrow');
    if (dd) dd.style.display = 'none';
    if (arrow) arrow.style.transform = '';
}

// ═══════════════════════════════════════════════════════════════════
//  RECHERCHE / FILTRAGE CLIENT
// ═══════════════════════════════════════════════════════════════════
function applyFilters() {
    const q = (document.getElementById('searchInput')?.value || '').toLowerCase().trim();
    filtered = ALL_COMMANDES.filter(c => !q || c.search.includes(q));
    if (currentView === 'grid') renderGrid();
    if (currentView === 'list') renderList();
}

// ═══════════════════════════════════════════════════════════════════
//  VUE GRILLE — cartes style MRP
// ═══════════════════════════════════════════════════════════════════
function renderGrid() {
    const container = document.getElementById('viewGrid');

    if (!filtered.length) {
        container.style.gridTemplateColumns = '1fr';
        container.innerHTML = `
            <div class="ach-empty">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 01-8 0"/>
                </svg>
                <p class="ach-empty-title">Aucune commande</p>
                <p>Aucune commande ne correspond à votre recherche ou filtre.</p>
            </div>`;
        return;
    }

    container.style.gridTemplateColumns = 'repeat(3, minmax(0, 1fr))';
    container.innerHTML = filtered.map(c => `
        <div class="ach-cmd-item" data-id="${c.id}" style="margin:0;">
            <a href="/Achats/BonCommande/${c.id}" style="text-decoration:none; color:inherit;">
                <div class="product-card"
                     style="padding:12px 12px; background:linear-gradient(135deg, rgba(8,11,32,0.96), rgba(18,22,54,0.96)); border:1px solid var(--border-soft); border-radius:var(--radius-sm); display:flex; flex-direction:column; gap:6px; transition:border-color 140ms cubic-bezier(0.2,0.8,0.2,1), box-shadow 140ms cubic-bezier(0.2,0.8,0.2,1), transform 80ms ease-out, background 140ms cubic-bezier(0.2,0.8,0.2,1);"
                     onmouseover="this.style.borderColor='var(--accent-glow)'; this.style.boxShadow='0 14px 40px rgba(123,94,255,0.35)'; this.style.transform='translateY(-2px)'; this.style.background='linear-gradient(135deg, rgba(15,18,48,1), rgba(25,30,70,1))';"
                     onmouseout="this.style.borderColor='var(--border-soft)'; this.style.boxShadow='none'; this.style.transform='translateY(0)'; this.style.background='linear-gradient(135deg, rgba(8,11,32,0.96), rgba(18,22,54,0.96))';">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <div style="font-size:0.8rem; font-weight:700; color:var(--accent);">${c.numero}</div>
                        <div style="font-size:0.75rem; color:var(--text-muted);">${c.date}</div>
                    </div>
                    <div style="font-size:0.9rem; font-weight:600; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                        ${c.fournisseur}
                    </div>
                    <div style="font-size:0.8rem; color:var(--text-muted);">
                        ${c.totalTTCStr} DZD TTC
                    </div>
                    <div style="margin-top:4px;">
                        <span style="font-size:0.75rem; padding:3px 8px; border-radius:999px; background:${c.statutBg}; color:${c.statutColor}; border:1px solid ${c.statutColor};">
                            ${c.statutLabel}
                        </span>
                    </div>
                </div>
            </a>
        </div>
    `).join('');
}

// ═══════════════════════════════════════════════════════════════════
//  VUE LISTE
// ═══════════════════════════════════════════════════════════════════
function sortBy(col) {
    if (currentSort.col === col) {
        currentSort.dir *= -1;
    } else {
        currentSort.col = col;
        currentSort.dir = 1;
    }
    document.querySelectorAll('.ach-table th[data-col]').forEach(th => {
        th.classList.toggle('sorted', th.dataset.col === col);
        const arrow = th.querySelector('.sort-arrow');
        if (!arrow) return;
        if (th.dataset.col === col) {
            arrow.textContent = currentSort.dir === 1 ? '↑' : '↓';
        } else {
            arrow.textContent = '↕';
        }
    });
    renderList();
}

function renderList() {
    const sorted = [...filtered].sort((a, b) => {
        const va = a[currentSort.col] ?? '';
        const vb = b[currentSort.col] ?? '';
        if (va < vb) return -1 * currentSort.dir;
        if (va > vb) return  1 * currentSort.dir;
        return 0;
    });

    const tbody = document.getElementById('listBody');
    if (!sorted.length) {
        tbody.innerHTML = `<tr><td colspan="5"><div class="ach-empty" style="padding:40px 0;"><p>Aucune commande ne correspond à votre recherche.</p></div></td></tr>`;
        return;
    }

    tbody.innerHTML = sorted.map(c => `
        <tr style="cursor:pointer;" onclick="window.location.href='/Achats/BonCommande/${c.id}'">
            <td class="td-num">${c.numero}</td>
            <td class="td-name">${c.fournisseur}</td>
            <td>
                <span style="font-size:0.72rem; padding:2px 8px; border-radius:999px; background:${c.statutBg}; color:${c.statutColor}; border:1px solid ${c.statutColor}; font-weight:600;">
                    ${c.statutLabel}
                </span>
            </td>
            <td class="td-muted" style="text-align:right; font-weight:600; color:var(--text);">${c.totalTTCStr} DZD</td>
            <td class="td-muted">${c.date}</td>
        </tr>
    `).join('');
}

// ═══════════════════════════════════════════════════════════════════
//  BASCULE DES VUES
// ═══════════════════════════════════════════════════════════════════
function setView(view) {
    currentView = view;
    document.getElementById('viewGrid').style.display = view === 'grid' ? 'grid'  : 'none';
    document.getElementById('viewList').style.display = view === 'list' ? 'block' : 'none';

    document.getElementById('btnGrid').classList.toggle('active', view === 'grid');
    document.getElementById('btnList').classList.toggle('active', view === 'list');

    if (view === 'grid') renderGrid();
    if (view === 'list') renderList();
}

// ═══════════════════════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
    renderGrid();
    document.addEventListener('click', () => { closeFilterDropdown(); });
});
</script>
}
