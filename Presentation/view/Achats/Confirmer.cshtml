@page
@model erp_pfc_20252026.Pages.Achats.ConfirmerModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
    ViewData["Title"] = Model.Tentative != null
        ? $"Réponse BC {Model.Tentative.BonCommande?.Numero}"
        : "Lien invalide";
}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>@ViewData["Title"] — SKYRA ERP</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: #02030A;
      color: #fff;
      min-height: 100vh;
      padding: 24px 16px 48px;
    }
    .page { max-width: 780px; margin: 0 auto; display: flex; flex-direction: column; gap: 20px; }

    /* Header */
    .cf-header {
      background: linear-gradient(135deg, #7B5EFF, #5B3EDF);
      border-radius: 20px;
      padding: 28px 32px;
      text-align: center;
    }
    .cf-header h1 { font-size: 1.5rem; font-weight: 800; }
    .cf-header p  { color: rgba(255,255,255,0.75); font-size: 0.85rem; margin-top: 4px; }

    /* Section label */
    .cf-section-label {
      display: flex; align-items: center; gap: 12px;
      margin: 8px 0 0;
      font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 1px; color: #7F83A5;
    }
    .cf-section-label::after {
      content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.06);
    }
    .cf-section-label .cf-section-icon {
      width: 28px; height: 28px; border-radius: 8px; display: flex; align-items: center; justify-content: center;
      font-size: 0.85rem;
    }
    .cf-section-icon-bc { background: rgba(123,94,255,0.15); }
    .cf-section-icon-pf { background: rgba(34,197,94,0.15); }

    /* Card */
    .cf-card {
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      overflow: hidden;
    }
    .cf-card-title {
      padding: 14px 20px;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: #A4A7C8;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    /* Info grid */
    .cf-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
    .cf-info-item {
      padding: 14px 20px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .cf-info-item:nth-child(odd) { border-right: 1px solid rgba(255,255,255,0.05); }
    .cf-info-label { font-size: 0.72rem; color: #7F83A5; font-weight: 600; text-transform: uppercase; letter-spacing: .3px; }
    .cf-info-value { font-size: 0.9rem; font-weight: 600; color: #fff; margin-top: 3px; }

    /* Tableau read-only */
    .cf-table { width: 100%; border-collapse: collapse; font-size: 0.83rem; }
    .cf-table thead th {
      padding: 10px 14px;
      text-align: left;
      color: #7F83A5;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .4px;
      background: rgba(255,255,255,0.02);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .cf-table td {
      padding: 12px 14px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      color: #e0e0e0;
      vertical-align: middle;
    }
    .cf-table tr:last-child td { border-bottom: none; }

    /* Proforma table */
    .pf-table { width: 100%; border-collapse: collapse; font-size: 0.83rem; }
    .pf-table thead th {
      padding: 10px 14px;
      text-align: left;
      color: #7F83A5;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .4px;
      background: rgba(34,197,94,0.04);
      border-bottom: 1px solid rgba(34,197,94,0.12);
    }
    .pf-table td {
      padding: 12px 14px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      color: #e0e0e0;
      vertical-align: middle;
    }
    .pf-table tr:last-child td { border-bottom: none; }
    .pf-table .pf-produit { color: #fff; font-weight: 600; }
    .pf-table .pf-qte-demandee { color: #7F83A5; font-size: 0.78rem; }

    /* Input fields */
    .pf-input {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      color: #fff;
      font-family: inherit;
      font-size: 0.83rem;
      font-weight: 600;
      padding: 8px 10px;
      width: 120px;
      transition: border-color .15s;
    }
    .pf-input:focus { outline: none; border-color: rgba(34,197,94,0.5); box-shadow: 0 0 0 2px rgba(34,197,94,0.12); }
    .pf-input::placeholder { color: #7F83A5; font-weight: 400; }

    /* Total box */
    .pf-total-box {
      background: rgba(34,197,94,0.06);
      border: 1px solid rgba(34,197,94,0.15);
      border-radius: 12px;
      padding: 16px 20px;
      margin: 16px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .pf-total-label { color: #A4A7C8; font-size: 0.83rem; }
    .pf-total-value { font-size: 1.2rem; font-weight: 800; color: #22c55e; }

    /* Notes */
    .cf-textarea {
      width: 100%;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: 10px;
      color: #fff;
      font-family: inherit;
      font-size: 0.85rem;
      padding: 12px 14px;
      resize: vertical;
      min-height: 80px;
      transition: border-color .15s;
    }
    .cf-textarea:focus { outline: none; border-color: rgba(34,197,94,0.4); }

    /* Boutons */
    .cf-actions { display: flex; gap: 12px; padding: 20px; flex-wrap: wrap; }
    .btn-proforma {
      flex: 2; min-width: 200px; padding: 14px 20px;
      background: linear-gradient(135deg, #22c55e, #16a34a);
      color: #fff; border: none; border-radius: 12px;
      font-family: inherit; font-size: 0.9rem; font-weight: 700;
      cursor: pointer; transition: opacity .15s, transform .1s;
    }
    .btn-proforma:hover:not(:disabled) { opacity: .88; }
    .btn-proforma:active:not(:disabled) { transform: scale(.98); }
    .btn-refuser-tout {
      flex: 1; min-width: 140px; padding: 14px 20px;
      background: transparent;
      color: #ef4444; border: 1.5px solid rgba(239,68,68,0.3); border-radius: 12px;
      font-family: inherit; font-size: 0.9rem; font-weight: 700;
      cursor: pointer; transition: background .15s, border-color .15s;
    }
    .btn-refuser-tout:hover:not(:disabled) { background: rgba(239,68,68,0.06); border-color: #ef4444; }
    button:disabled { opacity: .3; cursor: not-allowed; }

    /* Mobile */
    @@media (max-width: 600px) {
      .cf-table thead, .pf-table thead { display: none; }
      .cf-table, .cf-table tbody, .pf-table, .pf-table tbody { display: block; }
      .cf-table tr, .pf-table tr {
        display: block;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        margin: 8px 12px;
        padding: 4px 0;
      }
      .cf-table td, .pf-table td {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        padding: 10px 14px;
        text-align: left !important;
      }
      .cf-table td:last-child, .pf-table td:last-child { border-bottom: none; }
      .cf-table td::before, .pf-table td::before {
        content: attr(data-label);
        font-size: 0.72rem;
        color: #7F83A5;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .3px;
        margin-right: 12px;
        flex-shrink: 0;
      }
      .pf-input { width: 100px; }
      .cf-actions { flex-direction: column; }
      .btn-proforma, .btn-refuser-tout { min-width: 0; width: 100%; }
    }
    @@media (max-width: 500px) {
      .cf-info-grid { grid-template-columns: 1fr; }
      .cf-info-item:nth-child(odd) { border-right: none; }
    }

    /* Alerte */
    .cf-alert {
      border-radius: 12px;
      padding: 16px 20px;
      font-size: 0.88rem;
      font-weight: 600;
      text-align: center;
    }
    .cf-alert-error  { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.25); color: #ef4444; }

    /* État succès */
    .cf-done {
      display: flex; flex-direction: column; align-items: center; gap: 16px;
      padding: 48px 32px; text-align: center;
    }
    .cf-done-icon { font-size: 3rem; }
    .cf-done h2 { font-size: 1.3rem; font-weight: 800; }
    .cf-done p { color: #A4A7C8; font-size: 0.88rem; line-height: 1.6; }
  </style>
</head>
<body>
<div class="page">

  <div class="cf-header">
    <h1>SKYRA ERP</h1>
    <p>Réponse à un bon de commande</p>
  </div>

  @if (Model.DejaRepondu)
  {
    <div class="cf-card">
      <div class="cf-done">
        <div class="cf-done-icon">✓</div>
        <h2>Réponse déjà enregistrée</h2>
        <p>Ce lien a déjà été utilisé ou a expiré.<br>Merci de contacter notre équipe si vous avez une question.</p>
      </div>
    </div>
  }
  else if (Model.Tentative == null)
  {
    <div class="cf-alert cf-alert-error">Lien invalide ou expiré. Veuillez contacter l'émetteur du bon de commande.</div>
  }
  else if (Model.Succes)
  {
    var bc2 = Model.Tentative.BonCommande!;
    <div class="cf-card">
      <div class="cf-done">
        <div class="cf-done-icon">@(Model.EstRefusTotal ? "❌" : "📄")</div>
        <h2>@(Model.EstRefusTotal ? "Commande refusée" : "Proforma envoyée")</h2>
        <p>
          @if (Model.EstRefusTotal)
          {
            <text>Vous avez refusé le bon de commande <strong>@bc2.Numero</strong>. L'acheteur en a été notifié.</text>
          }
          else
          {
            <text>Votre proforma pour le bon <strong>@bc2.Numero</strong> a bien été transmise à l'acheteur. Il reviendra vers vous.</text>
          }
        </p>
      </div>
    </div>
  }
  else
  {
    var bc   = Model.Tentative.BonCommande!;
    var tent = Model.Tentative;
    string dateLiv = bc.DateLivraisonSouhaitee.HasValue
        ? bc.DateLivraisonSouhaitee.Value.ToString("dd/MM/yyyy")
        : "Non précisée";

    <!-- ═══════════════ PARTIE 1 : BON DE COMMANDE (lecture seule) ═══════════════ -->
    <div class="cf-section-label">
      <span class="cf-section-icon cf-section-icon-bc">📋</span>
      Bon de commande
    </div>

    <div class="cf-card">
      <div class="cf-card-title">Informations de la commande</div>
      <div class="cf-info-grid">
        <div class="cf-info-item">
          <div class="cf-info-label">Référence</div>
          <div class="cf-info-value">@bc.Numero</div>
        </div>
        <div class="cf-info-item">
          <div class="cf-info-label">Date de commande</div>
          <div class="cf-info-value">@bc.DateCommande.ToString("dd/MM/yyyy")</div>
        </div>
        <div class="cf-info-item">
          <div class="cf-info-label">Livraison souhaitée</div>
          <div class="cf-info-value">@dateLiv</div>
        </div>
        <div class="cf-info-item">
          <div class="cf-info-label">Fournisseur</div>
          <div class="cf-info-value">@(bc.Fournisseur?.FullName ?? "—")</div>
        </div>
      </div>
    </div>

    <div class="cf-card">
      <div class="cf-card-title">Produits demandés</div>
      <table class="cf-table">
        <thead>
          <tr>
            <th>Composant</th>
            <th style="text-align:right;">Quantité demandée</th>
          </tr>
        </thead>
        <tbody>
          @{ var lignesActives = bc.Lignes.Where(l => !l.EstExclue).ToList(); }
          @foreach (var l in lignesActives)
          {
            <tr>
              <td data-label="Composant" style="font-weight:600; color:#fff;">@(l.Produit?.Nom ?? "—")</td>
              <td data-label="Quantité" style="text-align:right; font-weight:700; color:#9C8CFF;">@l.Quantite.ToString("N3")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>

    @if (!string.IsNullOrEmpty(bc.Notes))
    {
      <div class="cf-card">
        <div class="cf-card-title">Notes de l'acheteur</div>
        <div style="padding:14px 20px; color:#A4A7C8; font-size:0.85rem; line-height:1.6;">@bc.Notes</div>
      </div>
    }

    <!-- ═══════════════ PARTIE 2 : PROFORMA (formulaire fournisseur) ═══════════════ -->
    <div class="cf-section-label">
      <span class="cf-section-icon cf-section-icon-pf">📄</span>
      Votre proforma
    </div>

    <form method="post" id="form-reponse">
      <input type="hidden" name="Token" value="@tent.Token" />

      <div class="cf-card">
        <div class="cf-card-title">Renseignez vos quantités et prix</div>
        <table class="pf-table">
          <thead>
            <tr>
              <th>Composant</th>
              <th style="text-align:right;">Quantité disponible</th>
              <th style="text-align:right;">Prix unitaire HT</th>
              <th style="text-align:right;">Total HT</th>
            </tr>
          </thead>
          <tbody id="tbody-proforma">
            @for (int i = 0; i < lignesActives.Count; i++)
            {
              var l = lignesActives[i];
              <tr>
                <td data-label="Composant">
                  <span class="pf-produit">@(l.Produit?.Nom ?? "—")</span>
                  <br><span class="pf-qte-demandee">Demandé : @l.Quantite.ToString("N3")</span>
                </td>
                <td data-label="Quantité" style="text-align:right;">
                  <input type="number"
                         name="QtesProposees[@i]"
                         class="pf-input qte-input"
                         data-qte-demandee="@l.Quantite"
                         value="@l.Quantite.ToString("F3", System.Globalization.CultureInfo.InvariantCulture)"
                         step="0.001" min="0"
                         placeholder="@l.Quantite.ToString("N3")" />
                  <input type="hidden" name="LigneIds[@i]" value="@l.Id" />
                </td>
                <td data-label="Prix HT" style="text-align:right;">
                  <input type="number"
                         name="PrixProposes[@i]"
                         class="pf-input prix-input"
                         value=""
                         step="0.01" min="0"
                         placeholder="0.00 DZD" />
                </td>
                <td data-label="Total" style="text-align:right; font-weight:700; color:#22c55e;" class="td-total">
                  —
                </td>
              </tr>
            }
          </tbody>
        </table>

        <div class="pf-total-box">
          <span class="pf-total-label">Total HT proforma</span>
          <span class="pf-total-value" id="total-ht-live">— DZD</span>
        </div>
      </div>

      <div class="cf-card">
        <div class="cf-card-title">Message (optionnel)</div>
        <div style="padding:14px 20px;">
          <textarea name="MessageFournisseur" class="cf-textarea"
                    placeholder="Commentaire, condition particulière, délai de livraison…"></textarea>
        </div>
        <div class="cf-actions">
          <button type="submit" name="Action" value="proforma" class="btn-proforma" id="btn-proforma">
            📄 Envoyer proforma
          </button>
          <button type="submit" name="Action" value="refuser" class="btn-refuser-tout" id="btn-refuser-tout">
            ✗ Refuser tout
          </button>
        </div>
      </div>
    </form>
  }

  <div style="text-align:center; color:#7F83A5; font-size:0.75rem; padding-top:8px;">
    Envoyé automatiquement par <strong style="color:#9C8CFF;">SKYRA ERP</strong>. Lien à usage unique.
  </div>
</div>

<script>
(function() {
  var prixInputs = document.querySelectorAll('.prix-input');
  var qteInputs  = document.querySelectorAll('.qte-input');
  var btnProforma = document.getElementById('btn-proforma');

  function recalculer() {
    var totalGlobal = 0;
    var rows = document.querySelectorAll('#tbody-proforma tr');
    var toutRempli = true;

    rows.forEach(function(row) {
      var prix = parseFloat(row.querySelector('.prix-input').value) || 0;
      var qte  = parseFloat(row.querySelector('.qte-input').value) || 0;
      var total = prix * qte;
      var tdTotal = row.querySelector('.td-total');

      if (prix > 0 && qte > 0) {
        tdTotal.textContent = total.toLocaleString('fr-FR', { minimumFractionDigits: 2 }) + ' DZD';
        totalGlobal += total;
      } else {
        tdTotal.textContent = '—';
      }

      if (!prix || prix <= 0) toutRempli = false;
    });

    var el = document.getElementById('total-ht-live');
    if (el) {
      el.textContent = totalGlobal > 0
        ? totalGlobal.toLocaleString('fr-FR', { minimumFractionDigits: 2 }) + ' DZD'
        : '— DZD';
    }

    if (btnProforma) btnProforma.disabled = !toutRempli;
  }

  prixInputs.forEach(function(inp) { inp.addEventListener('input', recalculer); });
  qteInputs.forEach(function(inp)  { inp.addEventListener('input', recalculer); });

  recalculer();
})();
</script>
</body>
</html>
