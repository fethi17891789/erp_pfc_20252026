                    </div>

                    @* Date livraison *@
                    <div class="bc-field-group">
                        <label class="bc-label" for="date-livraison">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/>
                                <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                            Date de livraison souhaitée
                        </label>
                        <input type="date"
                               name="DateLivraisonSouhaitee"
                               id="date-livraison"
                               class="bc-input"
                               style="color-scheme:dark; padding:10px 14px;"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>

                    @* Notes *@
                    <div class="bc-field-group">
                        <label class="bc-label" for="notes">Notes / Conditions</label>
                        <textarea name="Notes" id="notes" class="bc-textarea" rows="3"
                                  placeholder="Ex: Livraison en palette, référencer le n° BC sur la facture..."></textarea>
