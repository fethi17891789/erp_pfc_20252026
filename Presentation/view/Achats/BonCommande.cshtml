@page "{id:int?}"
@model erp_pfc_20252026.Pages.Achats.BonCommandeModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using global::Donnees.Achats

@{
    ViewData["Title"] = Model.ModeCreation ? "Nouveau BC" : $"BC {Model.BonCommande!.Numero}";
    Layout = "~/Presentation/view/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Achats.css" asp-append-version="true" />
    <style>
        /* ── Dropdown fournisseur ── */
        #fournisseur-select {
            appearance: none;
            -webkit-appearance: none;
            padding-right: 38px;
            cursor: pointer;
            background: linear-gradient(135deg, rgba(8,11,32,0.98), rgba(18,22,54,0.98));
        }
        #fournisseur-select:focus {
            box-shadow: 0 0 0 1px rgba(123,94,255,0.5), 0 0 15px rgba(123,94,255,0.25), inset 0 1px 2px rgba(255,255,255,0.05);
            background: linear-gradient(135deg, rgba(15,18,48,1), rgba(25,30,70,1));
        }
        /* ── Date input — icône calendrier visible ── */
        #date-livraison { color-scheme: dark; }
        #date-livraison::-webkit-calendar-picker-indicator {
            filter: invert(0.6) sepia(1) hue-rotate(220deg) saturate(3);
            cursor: pointer;
            opacity: 0.7;
            border-radius: 4px;
            padding: 2px;
        }
        #date-livraison::-webkit-calendar-picker-indicator:hover {
            opacity: 1;
            background: rgba(123,94,255,0.18);
        }

        /* ── Accordéons négociation ── */
        .bc-negoc-accordion {
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .bc-negoc-accordion:last-child { border-bottom: none; }
        .bc-negoc-summary {
            list-style: none;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 20px;
            cursor: pointer;
            user-select: none;
            transition: background .12s;
        }
        .bc-negoc-summary::-webkit-details-marker { display: none; }
        .bc-negoc-summary:hover { background: rgba(255,255,255,0.025); }
        details[open] .bc-negoc-chevron { transform: rotate(180deg); }
        .bc-negoc-body {
            padding: 4px 20px 20px;
        }
        .co-row-exclue td:not(:last-child) { opacity: .35; }
        .co-row-exclue .bc-td-nom { text-decoration: line-through; }
    </style>
}

@section HeaderLeft {
    <div class="breadcrumb">
        <a asp-page="/Achats/Index" class="breadcrumb-item breadcrumb-link">Achats</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-item breadcrumb-active">
            @(Model.ModeCreation ? "Nouveau bon de commande" : Model.BonCommande!.Numero)
        </span>
    </div>
}

@* ── TOAST SUCCÈS ───────────────────────────────────────────────────────────── *@
@if (Model.MessageSucces != null)
{
    <div id="bc-toast" class="bc-toast bc-toast-visible">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:16px;height:16px;flex-shrink:0;">
            <polyline points="20 6 9 17 4 12"/>
        </svg>
        @Model.MessageSucces
    </div>
}

<div class="bc-page">

    @* ═══════════════════════════════════════════════════════════════
       MODE DÉTAIL
    ════════════════════════════════════════════════════════════════ *@
    @if (!Model.ModeCreation)
    {
        var bc = Model.BonCommande!;
        var (statBg, statColor, statLabel) = BonCommandeModel.GetStatutStyle(bc.Statut);
        var tentatives = bc.Tentatives
            .Where(t => t.Statut != "Expiree")
            .OrderByDescending(t => t.Numero)
            .ToList();

        @* ── HEADER DÉTAIL ─────────────────────────────────────────────── *@
        <div class="bc-detail-header">
            <div class="bc-detail-meta">
                <h2 class="bc-detail-num">@bc.Numero</h2>
                <span class="bc-statut-badge" style="background:@statBg; color:@statColor; border:1px solid @statColor;">
                    @statLabel
                </span>
            </div>
            <div class="bc-detail-actions">
                @if (bc.Statut == StatutBonCommande.Brouillon)
                {
                    <form method="post" asp-page-handler="Envoyer" style="display:inline;">
                        <input type="hidden" name="id" value="@bc.Id" />
                        <button type="submit" class="btn-primary bc-btn-send">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:15px;height:15px;">
                                <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                            </svg>
                            Envoyer au fournisseur
                        </button>
                    </form>
                    <form method="post" asp-page-handler="Supprimer" style="display:inline;" onsubmit="return confirmSuppression()">
                        <input type="hidden" name="id" value="@bc.Id" />
                        <button type="submit" class="bc-btn-danger">Supprimer</button>
                    </form>
                }
                @{
                    var tentativeEnAttente = tentatives.FirstOrDefault(t => t.Statut == "EnAttente");
                }
                @if (tentativeEnAttente != null)
                {
                    string lienFournisseur = $"/Achats/Confirmer?token={tentativeEnAttente.Token}";
                    <a href="@lienFournisseur" target="_blank" class="bc-btn-secondary" style="font-size:13px;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;">
                            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                            <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                        </svg>
                        Voir page fournisseur
                    </a>
                    <button type="button" class="bc-btn-secondary" style="font-size:13px;"
                            onclick="copierLienFournisseur('@lienFournisseur', this)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                        </svg>
                        Copier lien
                    </button>
                }
                @if (bc.Statut == StatutBonCommande.Confirme || bc.Statut == StatutBonCommande.PartiellemtRecu)
                {
                    <a asp-page="/Achats/BonReception" asp-route-bcId="@bc.Id" class="btn-primary bc-btn-send">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:15px;height:15px;">
                            <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                            <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                        </svg>
                        Créer un bon de réception
                    </a>
                }
                @if (bc.Statut == StatutBonCommande.Recu || bc.Statut == StatutBonCommande.PartiellemtRecu)
                {
                    <a asp-page="/Achats/Facture" asp-route-bcId="@bc.Id" class="bc-btn-secondary">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:15px;height:15px;">
                            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </svg>
                        Créer une facture
                    </a>
                }
            </div>
        </div>

        @* ── TIMELINE STATUT ───────────────────────────────────────────── *@
        var etapes = new[] {
            (StatutBonCommande.Brouillon,       "Brouillon"),
            (StatutBonCommande.Envoye,          "Envoyé"),
            (StatutBonCommande.Confirme,        "Confirmé"),
            (StatutBonCommande.Recu,            "Reçu"),
            (StatutBonCommande.Facture,         "Facturé")
        };
        var ordreStatut = new Dictionary<string,int> {
            [StatutBonCommande.Brouillon]=0,       [StatutBonCommande.Envoye]=1,
            [StatutBonCommande.EnNegociation]=1,   [StatutBonCommande.Confirme]=2,
            [StatutBonCommande.PartiellemtRecu]=2, [StatutBonCommande.Recu]=3,
            [StatutBonCommande.Facture]=4,         [StatutBonCommande.Refuse]=-1,
            [StatutBonCommande.Annule]=-1
        };
        int indexActuel = ordreStatut.GetValueOrDefault(bc.Statut, 0);

        @if (bc.Statut != StatutBonCommande.Refuse && bc.Statut != StatutBonCommande.Annule)
        {
            <div class="bc-timeline">
                @for (int i = 0; i < etapes.Length; i++)
                {
                    bool fait = i < indexActuel;
                    bool actif = i == indexActuel;
                    <div class="bc-timeline-step @(fait ? "bc-step-done" : actif ? "bc-step-active" : "bc-step-pending")">
                        <div class="bc-step-dot">
                            @if (fait)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="width:10px;height:10px;">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                            }
                        </div>
                        <span class="bc-step-label">@etapes[i].Item2</span>
                    </div>
                    @if (i < etapes.Length - 1)
                    {
                        <div class="bc-timeline-line @(fait ? "bc-line-done" : "")"></div>
                    }
                }
            </div>
        }
        else
        {
            <div class="bc-refused-banner">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;">
                    <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
                @if (bc.Statut == StatutBonCommande.Annule)
                {
                    <span>Ce bon de commande a été annulé.</span>
                }
                else
                {
                    <span>Ce bon de commande a été refusé par le fournisseur.</span>
                    @if (!string.IsNullOrEmpty(bc.RepondeurMessage))
                    {
                        <span>— "@bc.RepondeurMessage"</span>
                    }
                }
            </div>
        }

        @* ── INFOS BC ──────────────────────────────────────────────────── *@
        <div class="bc-info-grid">
            <div class="bc-info-card">
                <span class="bc-info-label">Fournisseur</span>
                <span class="bc-info-value">@bc.Fournisseur?.FullName</span>
                @if (!string.IsNullOrEmpty(bc.Fournisseur?.Email))
                {
                    <span class="bc-info-sub">@bc.Fournisseur.Email</span>
                }
            </div>
            <div class="bc-info-card">
                <span class="bc-info-label">Date de commande</span>
                <span class="bc-info-value">@bc.DateCommande.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="bc-info-card">
                <span class="bc-info-label">Livraison souhaitée</span>
                <span class="bc-info-value">
                    @(bc.DateLivraisonSouhaitee.HasValue ? bc.DateLivraisonSouhaitee.Value.ToString("dd/MM/yyyy") : "—")
                </span>
            </div>
            @if (bc.DateLivraisonProposee.HasValue)
            {
                <div class="bc-info-card bc-info-card-alt">
                    <span class="bc-info-label">Livraison proposée par le fournisseur</span>
                    <span class="bc-info-value">@bc.DateLivraisonProposee.Value.ToString("dd/MM/yyyy")</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(bc.Notes))
            {
                <div class="bc-info-card bc-info-card-full">
                    <span class="bc-info-label">Notes</span>
                    <span class="bc-info-value">@bc.Notes</span>
                </div>
            }
        </div>

        @* ── TABLEAU DES LIGNES ────────────────────────────────────────── *@
        <div class="bc-table-card">
            <div class="bc-table-header">
                <span class="bc-table-title">Lignes de commande</span>
            </div>
            <table class="bc-table">
                <thead>
                    <tr>
                        <th>Composant</th>
                        <th>Référence</th>
                        <th style="text-align:center;">Sous-traitance</th>
                        <th style="text-align:right;">Quantité</th>
                        <th style="text-align:right;">Prix unitaire HT</th>
                        <th style="text-align:right;">Total HT</th>
                        <th style="width:80px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ligne in bc.Lignes)
                    {
                        <tr>
                            <td class="bc-td-nom">@ligne.Produit?.Nom</td>
                            <td class="bc-td-ref">@ligne.Produit?.Reference</td>
                            <td style="text-align:center;">
                                @if (ligne.EstSousTraitance)
                                {
                                    <span class="bc-badge-st">Sous-traitance</span>
                                }
                                else { <span style="color:var(--text-muted-2);">—</span> }
                            </td>
                            <td style="text-align:right; font-weight:600;">@ligne.Quantite.ToString("N2")</td>
                            <td style="text-align:right;">@ligne.PrixUnitaireHT.ToString("N2") DZD</td>
                            <td style="text-align:right; font-weight:700; color:var(--accent-light);">@ligne.TotalHT.ToString("N2") DZD</td>
                            <td style="text-align:right;">
                                <a asp-page="/Achats/AnalysePrix" asp-route-produitId="@ligne.ProduitId"
                                   class="bc-link" style="font-size:11px;font-weight:600;white-space:nowrap;"
                                   title="Graphique historique des prix et simulateur Et si ?">
                                   📈 Analyser
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @* ── TOTAUX ────────────────────────────────────────────────── *@
            <div class="bc-totaux">
                <div class="bc-total-row">
                    <span>Total HT</span>
                    <span>@bc.TotalHT.ToString("N2") DZD</span>
                </div>
                <div class="bc-total-row">
                    <span>TVA (19%)</span>
                    <span>@bc.MontantTVA.ToString("N2") DZD</span>
                </div>
                <div class="bc-total-row bc-total-ttc">
                    <span>Total TTC</span>
                    <span>@bc.TotalTTC.ToString("N2") DZD</span>
                </div>
            </div>
        </div>

        @* ── HISTORIQUE DES NÉGOCIATIONS ──────────────────────────────── *@
        @if (tentatives.Any())
        {
            <div class="bc-section-card" style="margin-top:20px;">
                <div class="bc-section-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;">
                        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                    </svg>
                    Historique des négociations (@tentatives.Count)
                </div>

                @foreach (var tent in tentatives)
                {
                    bool estContrePropo = tent.Statut == "ContreProposition";
                    bool estAcceptee    = tent.Statut == "Acceptee";
                    bool estEnAttente   = tent.Statut == "EnAttente";

                    string tentBadgeBg    = estAcceptee  ? "rgba(34,197,94,0.10)"  :
                                           estContrePropo ? "rgba(251,146,60,0.10)" :
                                           estEnAttente   ? "rgba(251,191,36,0.10)" :
                                                            "rgba(255,255,255,0.06)";
                    string tentBadgeColor = estAcceptee  ? "#22c55e"  :
                                           estContrePropo ? "#fb923c" :
                                           estEnAttente   ? "#fbbf24" : "#a4a7c8";
                    string tentBadgeLabel = estAcceptee  ? "Acceptée"         :
                                           estContrePropo ? "Contre-proposition" :
                                           estEnAttente   ? "En attente"       : tent.Statut;

                    <details class="bc-negoc-accordion">
                        <summary class="bc-negoc-summary">
                            <div style="display:flex; align-items:center; gap:10px; flex:1;">
                                <span style="font-weight:700; color:var(--accent-light);">Tentative n°@tent.Numero</span>
                                <span style="color:var(--text-muted); font-size:0.8rem;">@tent.DateEnvoi.ToString("dd/MM/yyyy HH:mm")</span>
                                <span class="bc-statut-badge" style="background:@tentBadgeBg; color:@tentBadgeColor; border:1px solid @tentBadgeColor; font-size:0.72rem;">
                                    @tentBadgeLabel
                                </span>
                            </div>
                            <svg class="bc-negoc-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:14px;height:14px;flex-shrink:0;transition:transform .2s;">
                                <polyline points="6 9 12 15 18 9"/>
                            </svg>
                        </summary>

                        <div class="bc-negoc-body">
                            @if (!string.IsNullOrEmpty(tent.MessageFournisseur))
                            {
                                <div style="background:rgba(255,255,255,0.03); border-left:3px solid var(--accent); border-radius:4px; padding:10px 14px; margin-bottom:14px; font-size:0.85rem; color:var(--text-muted);">
                                    <span style="font-weight:700; color:var(--text);">Message fournisseur :</span> @tent.MessageFournisseur
                                </div>
                            }

                            <table class="bc-table" style="margin:0;">
                                <thead>
                                    <tr>
                                        <th>Composant</th>
                                        <th style="text-align:right;">Qté</th>
                                        <th style="text-align:right;">Prix BC</th>
                                        <th style="text-align:right;">Prix proposé</th>
                                        <th style="text-align:center;">Statut ligne</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var bcLigne in bc.Lignes)
                                    {
                                        var repLigne = tent.Lignes.FirstOrDefault(l => l.BonCommandeLigneId == bcLigne.Id);
                                        bool ligneRefusee = repLigne?.EstRefusee == true;
                                        bool prixModifie  = repLigne?.PrixProposeHT.HasValue == true;
                                        decimal prixAffiche = repLigne?.PrixProposeHT ?? bcLigne.PrixUnitaireHT;

                                        <tr style="@(ligneRefusee ? "opacity:0.45;" : "")">
                                            <td class="bc-td-nom" style="@(ligneRefusee ? "text-decoration:line-through;" : "")">@bcLigne.Produit?.Nom</td>
                                            <td style="text-align:right;">@bcLigne.Quantite.ToString("N3")</td>
                                            <td style="text-align:right; color:var(--text-muted);">@bcLigne.PrixUnitaireHT.ToString("N2") DZD</td>
                                            <td style="text-align:right; font-weight:700; color:@(ligneRefusee ? "#ef4444" : prixModifie ? "#fb923c" : "#22c55e");">
                                                @if (ligneRefusee)
                                                {
                                                    <span>Refusé</span>
                                                }
                                                else if (prixModifie)
                                                {
                                                    <span>@prixAffiche.ToString("N2") DZD</span>
                                                }
                                                else
                                                {
                                                    <span>✓ Accepté</span>
                                                }
                                            </td>
                                            <td style="text-align:center;">
                                                @if (ligneRefusee)
                                                {
                                                    <span style="font-size:0.72rem; padding:2px 8px; border-radius:999px; background:rgba(239,68,68,0.10); color:#ef4444; border:1px solid #ef4444;">Refusée</span>
                                                }
                                                else if (prixModifie)
                                                {
                                                    <span style="font-size:0.72rem; padding:2px 8px; border-radius:999px; background:rgba(251,146,60,0.10); color:#fb923c; border:1px solid #fb923c;">Prix modifié</span>
                                                }
                                                else
                                                {
                                                    <span style="font-size:0.72rem; padding:2px 8px; border-radius:999px; background:rgba(34,197,94,0.10); color:#22c55e; border:1px solid #22c55e;">OK</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </details>
                }

                @* Formulaire contre-offre acheteur si dernière tentative = contre-proposition *@
                @if (tentatives.FirstOrDefault()?.Statut == "ContreProposition" &&
                     bc.Statut == StatutBonCommande.EnNegociation)
                {
                    var dernTent = tentatives.First();
                    <div style="border-top:1px solid rgba(255,255,255,0.07); margin-top:4px; padding:20px;">
                        <p style="font-size:0.82rem; color:var(--text-muted); margin-bottom:14px; font-weight:600;">
                            Ajustez votre contre-offre puis envoyez-la au fournisseur.
                            Les produits refusés sont décochés — cochez pour les réintégrer.
                        </p>
                        <form method="post" asp-page-handler="ContreOffrir">
                            <input type="hidden" name="id" value="@bc.Id" />
                            <table class="bc-table" style="margin-bottom:16px;">
                                <thead>
                                    <tr>
                                        <th>Composant</th>
                                        <th style="text-align:right;">Prix BC</th>
                                        <th style="text-align:right;">Prix fournisseur</th>
                                        <th>Votre offre</th>
                                        <th style="text-align:center;">Inclure</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < bc.Lignes.Count; i++)
                                    {
                                        var lig = bc.Lignes[i];
                                        var repFourn = dernTent.Lignes.FirstOrDefault(l => l.BonCommandeLigneId == lig.Id);
                                        bool refuseFourn = repFourn?.EstRefusee == true;
                                        decimal prixFourn = repFourn?.PrixProposeHT ?? lig.PrixUnitaireHT;
                                        bool incluse = !lig.EstExclue && !refuseFourn;

                                        <tr id="co-row-@lig.Id" class="@(incluse ? "" : "co-row-exclue")">
                                            <td class="bc-td-nom" style="@(!incluse ? "opacity:.45;text-decoration:line-through;" : "")">
                                                @lig.Produit?.Nom
                                                @if (refuseFourn)
                                                {
                                                    <span style="font-size:0.7rem; color:#ef4444; font-weight:700; margin-left:6px;">(refusé)</span>
                                                }
                                            </td>
                                            <td style="text-align:right; color:var(--text-muted);">@lig.PrixUnitaireHT.ToString("N2") DZD</td>
                                            <td style="text-align:right; color:@(refuseFourn ? "#ef4444" : prixFourn != lig.PrixUnitaireHT ? "#fb923c" : "#22c55e"); font-weight:700;">
                                                @(refuseFourn ? "Refusé" : prixFourn.ToString("N2") + " DZD")
                                            </td>
                                            <td>
                                                <input type="hidden" name="OffreLigneIds[@i]" value="@lig.Id" />
                                                <input type="number"
                                                       name="OffrePrix[@i]"
                                                       class="bc-input co-prix-input"
                                                       style="width:130px; padding:5px 8px; font-size:0.82rem; @(!incluse ? "opacity:.35; pointer-events:none;" : "")"
                                                       value="@prixFourn.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                                       step="0.01" min="0"
                                                       id="co-prix-@lig.Id" />
                                            </td>
                                            <td style="text-align:center;">
                                                <input type="hidden" name="OffreReintegrer[@i]" value="false" />
                                                <input type="checkbox"
                                                       name="OffreReintegrer[@i]"
                                                       value="true"
                                                       @(incluse ? "checked" : "")
                                                       style="width:16px;height:16px;accent-color:var(--accent);cursor:pointer;"
                                                       onchange="toggleLigneCO(@lig.Id, this.checked)" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            <div style="display:flex; gap:10px; flex-wrap:wrap;">
                                <button type="submit" class="btn-primary bc-btn-send" style="background:linear-gradient(135deg,#7B5EFF,#5B3EDF);">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;">
                                        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                                    </svg>
                                    Envoyer la contre-offre
                                </button>
                                <form method="post" asp-page-handler="Annuler" style="display:contents;">
                                    <input type="hidden" name="id" value="@bc.Id" />
                                    <button type="submit" class="bc-btn-danger">Annuler le BC</button>
                                </form>
                            </div>
                        </form>
                    </div>
                }
            </div>
        }

        @* ── BONS DE RÉCEPTION LIÉS ────────────────────────────────────── *@
        @if (bc.BonsReception.Any())
        {
            <div class="bc-section-card" style="margin-top:20px;">
                <div class="bc-section-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;">
                        <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                        <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                    </svg>
                    Bons de réception (@bc.BonsReception.Count)
                </div>
                <table class="bc-table" style="margin:0;">
                    <thead>
                        <tr>
                            <th>Numéro</th>
                            <th>Date</th>
                            <th>Statut</th>
                            <th>Articles</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var br in bc.BonsReception.OrderByDescending(r => r.DateCreation))
                        {
                            bool brValide = br.Statut == StatutBonReception.Valide;
                            <tr>
                                <td style="font-weight:700;">@br.Numero</td>
                                <td>@br.DateReception.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (brValide)
                                    {
                                        <span class="bc-statut-badge" style="background:rgba(34,197,94,0.10);color:#22c55e;border:1px solid #22c55e;">Validé</span>
                                    }
                                    else
                                    {
                                        <span class="bc-statut-badge" style="background:rgba(251,191,36,0.10);color:#fbbf24;border:1px solid #fbbf24;">En cours</span>
                                    }
                                </td>
                                <td>@br.Lignes.Count ligne@(br.Lignes.Count > 1 ? "s" : "")</td>
                                <td style="text-align:right;">
                                    <a asp-page="/Achats/BonReception" asp-route-id="@br.Id" class="bc-link" style="font-size:12px;font-weight:600;">
                                        Voir →
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @* ── FACTURES LIÉES ────────────────────────────────────────────── *@
        @if (Model.Factures.Any())
        {
            <div class="bc-section-card" style="margin-top:12px;">
                <div class="bc-section-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                    </svg>
                    Factures (@Model.Factures.Count)
                </div>
                <table class="bc-table" style="margin:0;">
                    <thead>
                        <tr>
                            <th>N° SKYRA</th>
                            <th>N° Fournisseur</th>
                            <th>Date</th>
                            <th style="text-align:right;">Montant TTC</th>
                            <th>Statut</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fac in Model.Factures)
                        {
                            var (fBg, fColor, fLabel) = BonCommandeModel.GetFactureStatutStyle(fac.Statut);
                            <tr>
                                <td style="font-weight:700;">@fac.Numero</td>
                                <td>@(fac.NumeroFournisseur ?? "—")</td>
                                <td>@fac.DateFacture.ToString("dd/MM/yyyy")</td>
                                <td style="text-align:right;font-weight:700;">@fac.MontantTTC.ToString("N2") DZD</td>
                                <td>
                                    <span class="bc-statut-badge" style="background:@fBg;color:@fColor;border:1px solid @fColor;">
                                        @fLabel
                                        @if (fac.AlerteEcartPrix)
                                        {
                                            <span style="margin-left:4px;">⚠</span>
                                        }
                                    </span>
                                </td>
                                <td style="text-align:right;">
                                    <a asp-page="/Achats/Facture" asp-route-id="@fac.Id" class="bc-link" style="font-size:12px;font-weight:600;">
                                        Voir →
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }

    @* ═══════════════════════════════════════════════════════════════
       MODE CRÉATION
    ════════════════════════════════════════════════════════════════ *@
    else
    {
        <div class="bc-create-header">
            <h2 class="bc-detail-num">Nouveau bon de commande</h2>
        </div>

        <form method="post" asp-page-handler="Creer" id="form-bc">
            <input type="hidden" name="LignesJson" id="lignes-json" value="[]" />

            <div class="bc-form-grid">

                @* ── COLONNE GAUCHE ─────────────────────────────────────── *@
                <div class="bc-form-main">

                    @* Fournisseur *@
                    <div class="bc-field-group">
                        <label class="bc-label" for="fournisseur-select">
                            Fournisseur <span class="bc-required">*</span>
                        </label>
                        @if (!Model.Fournisseurs.Any())
                        {
                            <div class="bc-empty-warning">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;">
                                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                                </svg>
                                Aucun fournisseur dans votre annuaire.
                                <a asp-page="/AnnuaireNew" style="color:var(--accent);">Ajouter un contact fournisseur →</a>
                            </div>
                        }
                        else
                        {
                            <div class="select-wrapper">
                                <select name="FournisseurId" id="fournisseur-select" class="bc-select" required>
                                    <option value="">— Choisir un fournisseur —</option>
                                    @foreach (var f in Model.Fournisseurs)
                                    {
                                        <option value="@f.Id"
                                                data-email="@f.Email"
                                                data-phone="@f.Phone">
                                            @f.FullName
                                            @if (!string.IsNullOrEmpty(f.Email)) { <text> (@f.Email)</text> }
                                        </option>
                                    }
                                </select>
                                <svg class="select-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                            </div>
                        }
                    </div>

                    @* Date livraison *@
                    <div class="bc-field-group">
                        <label class="bc-label" for="date-livraison">Date de livraison souhaitée</label>
                        <input type="date"
                               name="DateLivraisonSouhaitee"
                               id="date-livraison"
                               class="bc-input"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>

                    @* Notes *@
                    <div class="bc-field-group">
                        <label class="bc-label" for="notes">Notes / Conditions</label>
                        <textarea name="Notes" id="notes" class="bc-textarea" rows="3"
                                  placeholder="Ex: Livraison en palette, référencer le n° BC sur la facture..."></textarea>
                    </div>

                    @* ── LIGNES DE COMMANDE ──────────────────────────── *@
                    <div class="bc-lignes-section">
                        <div class="bc-lignes-header">
                            <span class="bc-table-title">Lignes de commande</span>
                            <button type="button" class="bc-btn-add-ligne" onclick="ouvrirAjoutLigne()">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:14px;height:14px;">
                                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                                </svg>
                                Ajouter un composant
                            </button>
                        </div>

                        <div id="lignes-empty" class="bc-lignes-empty">
                            Aucune ligne pour l'instant. Cliquez sur "Ajouter un composant".
                        </div>
                        <div id="lignes-container"></div>

                        @* Totaux live *@
                        <div class="bc-totaux" id="totaux-section" style="display:none;">
                            <div class="bc-total-row">
                                <span>Total HT</span>
                                <span id="total-ht">0,00 DZD</span>
                            </div>
                            <div class="bc-total-row">
                                <span>TVA (19%)</span>
                                <span id="total-tva">0,00 DZD</span>
                            </div>
                            <div class="bc-total-row bc-total-ttc">
                                <span>Total TTC</span>
                                <span id="total-ttc">0,00 DZD</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* ── COLONNE DROITE : aide ────────────────────────────── *@
                <div class="bc-form-aside">
                    <div class="bc-aside-card">
                        <div class="bc-aside-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:20px;height:20px;">
                                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                        </div>
                        <h4>Comment ça marche</h4>
                        <ol class="bc-aside-steps">
                            <li>Choisissez un fournisseur</li>
                            <li>Ajoutez les composants à commander</li>
                            <li>Enregistrez le bon de commande</li>
                            <li>Envoyez-le au fournisseur par email</li>
                            <li>Le fournisseur confirme ou refuse via le lien reçu</li>
                        </ol>
                    </div>
                    <div class="bc-aside-card bc-aside-warning">
                        <strong>Sous-traitance</strong>
                        <p>Si vous commandez un composant qui n'est pas une matière première, SKYRA vous demandera une confirmation — c'est un achat de sous-traitance.</p>
                    </div>
                </div>

            </div>

            @* Actions *@
            <div class="bc-form-actions">
                <a asp-page="/Achats/Index" class="btn-secondary-outline">Annuler</a>
                <button type="submit" class="btn-primary" id="btn-submit-bc">
                    Enregistrer le bon de commande
                </button>
            </div>
        </form>
    }
</div>

@* ═══════════════════════════════════════════════════════════════════════════
   MODAL : Ajouter une ligne
════════════════════════════════════════════════════════════════════════════ *@
@if (Model.ModeCreation)
{
    <div id="modal-ligne" class="bc-modal-overlay" style="display:none;" onclick="fermerModalSiDehors(event)">
        <div class="bc-modal">
            <div class="bc-modal-header">
                <h3>Ajouter un composant</h3>
                <button type="button" class="bc-modal-close" onclick="fermerModalLigne()">✕</button>
            </div>
            <div class="bc-modal-body">
                <div class="bc-field-group">
                    <label class="bc-label">Composant <span class="bc-required">*</span></label>
                    <input type="text" id="search-produit" class="bc-input"
                           placeholder="Rechercher un composant..."
                           oninput="filtrerProduits(this.value)" autocomplete="off" />
                    <div id="produit-results" class="bc-produit-results"></div>
                    <input type="hidden" id="selected-produit-id" />
                    <input type="hidden" id="selected-produit-nom" />
                    <input type="hidden" id="selected-produit-est-mp" />
                </div>
                <div class="bc-field-group">
                    <label class="bc-label">Quantité <span class="bc-required">*</span></label>
                    <input type="number" id="input-qte" class="bc-input" value="1" min="0.001" step="0.001" />
                </div>
                <div class="bc-field-group">
                    <label class="bc-label">Prix unitaire HT (DZD)</label>
                    <input type="number" id="input-prix" class="bc-input" step="0.01" min="0"
                           placeholder="Laissez vide pour utiliser le coût d'achat" />
                    <span class="bc-field-hint" id="hint-cout-achat"></span>
                </div>
            </div>
            <div class="bc-modal-footer">
                <button type="button" class="btn-secondary-outline" onclick="fermerModalLigne()">Annuler</button>
                <button type="button" class="btn-primary" onclick="validerLigne()">Ajouter</button>
            </div>
        </div>
    </div>

    @* MODAL SOUS-TRAITANCE *@
    <div id="modal-sst" class="bc-modal-overlay" style="display:none;">
        <div class="bc-modal bc-modal-warning">
            <div class="bc-modal-header">
                <h3>⚠️ Composant en sous-traitance</h3>
            </div>
            <div class="bc-modal-body">
                <p style="color:var(--text-muted);line-height:1.7;">
                    Le composant <strong id="sst-nom" style="color:var(--text);"></strong> n'est pas classifié comme matière première.
                    Le commander implique un achat de <strong>sous-traitance</strong>.
                </p>
                <p style="color:var(--text-muted);font-size:13px;">Confirmez-vous vouloir l'inclure dans ce bon de commande ?</p>
            </div>
            <div class="bc-modal-footer">
                <button type="button" class="btn-secondary-outline" onclick="annulerSousTraitance()">Annuler</button>
                <button type="button" class="btn-primary" onclick="confirmerSousTraitance()" style="background:linear-gradient(135deg,#f97316,#ea580c);">
                    Oui, inclure en sous-traitance
                </button>
            </div>
        </div>
    </div>
}

@* ═══════════════════════════════════════════════════════════════════════════
   DONNÉES PRODUITS (JSON pour JS)
════════════════════════════════════════════════════════════════════════════ *@
@if (Model.ModeCreation)
{
    <script id="produits-data" type="application/json">
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Produits,
            new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))
    </script>
}

@section Scripts {
<script>
// ─── Données produits ────────────────────────────────────────────────────
const produits = JSON.parse(document.getElementById('produits-data')?.textContent || '[]');
let lignes = [];
let ligneEnCours = null; // Pour gérer le flow sous-traitance

// ─── Toast ───────────────────────────────────────────────────────────────
const toast = document.getElementById('bc-toast');
if (toast) setTimeout(() => toast.classList.remove('bc-toast-visible'), 4000);

function afficherErreurModal(msg) {
    let el = document.getElementById('modal-erreur');
    if (!el) {
        el = document.createElement('div');
        el.id = 'modal-erreur';
        el.style.cssText = 'color:#ef4444;font-size:12.5px;padding:6px 10px;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:8px;margin-top:-6px;';
        document.querySelector('.bc-modal-footer').before(el);
    }
    el.textContent = msg;
    setTimeout(() => { if (el) el.textContent = ''; }, 3000);
}

// ─── Modal ligne ─────────────────────────────────────────────────────────
function ouvrirAjoutLigne() {
    document.getElementById('search-produit').value = '';
    document.getElementById('selected-produit-id').value = '';
    document.getElementById('selected-produit-nom').value = '';
    document.getElementById('selected-produit-est-mp').value = '';
    document.getElementById('input-qte').value = '1';
    document.getElementById('input-prix').value = '';
    document.getElementById('hint-cout-achat').textContent = '';
    filtrerProduits(''); // afficher les produits dès l'ouverture
    document.getElementById('modal-ligne').style.display = 'flex';
    setTimeout(() => document.getElementById('search-produit').focus(), 50);
}

function fermerModalLigne() {
    document.getElementById('modal-ligne').style.display = 'none';
}

function fermerModalSiDehors(e) {
    if (e.target.id === 'modal-ligne') fermerModalLigne();
}

// ─── Recherche produits ──────────────────────────────────────────────────
function filtrerProduits(q) {
    const container = document.getElementById('produit-results');
    const query = q.toLowerCase().trim();

    const matches = !query
        ? produits.slice(0, 10)
        : produits.filter(p =>
            p.nom.toLowerCase().includes(query) ||
            (p.reference || '').toLowerCase().includes(query)
          ).slice(0, 10);

    if (matches.length === 0) {
        container.innerHTML = '<div class="bc-produit-none">Aucun produit trouvé</div>';
        return;
    }

    container.innerHTML = matches.map(p => {
        const tagCls  = p.estMatierePremiere ? 'bc-tag-mp' : 'bc-tag-st';
        const tagLbl  = p.typeLabel || (p.estMatierePremiere ? 'MP' : 'Autre');
        const prix    = Number(p.coutAchat).toLocaleString('fr-FR', {minimumFractionDigits:2});
        const nomSafe = p.nom.replace(/'/g, "\\'");
        return `
            <div class="bc-produit-item" onclick="selectionnerProduit(${p.id}, '${nomSafe}', ${p.coutAchat}, ${p.estMatierePremiere})">
                <span class="bc-produit-nom">${p.nom}</span>
                <span class="bc-produit-meta">
                    ${p.reference ? '<code style="font-size:0.7rem;opacity:.7">' + p.reference + '</code> · ' : ''}
                    <span class="${tagCls}">${tagLbl}</span>
                    · ${prix} DZD
                </span>
            </div>`;
    }).join('');
}

function selectionnerProduit(id, nom, coutAchat, estMP) {
    document.getElementById('selected-produit-id').value = id;
    document.getElementById('selected-produit-nom').value = nom;
    document.getElementById('selected-produit-est-mp').value = estMP;
    document.getElementById('search-produit').value = nom;
    document.getElementById('produit-results').innerHTML = '';

    if (coutAchat > 0) {
        document.getElementById('input-prix').value = coutAchat.toFixed(2);
        document.getElementById('hint-cout-achat').textContent =
            `Prix pré-rempli depuis le dernier coût d'achat : ${Number(coutAchat).toLocaleString('fr-FR',{minimumFractionDigits:2})} DZD`;
    } else {
        document.getElementById('input-prix').value = '';
        document.getElementById('hint-cout-achat').textContent = 'Aucun coût d\'achat enregistré pour ce composant.';
    }
}

// ─── Valider la ligne (avec flow sous-traitance) ─────────────────────────
function validerLigne() {
    const produitId = parseInt(document.getElementById('selected-produit-id').value);
    const nom       = document.getElementById('selected-produit-nom').value;
    const estMP     = document.getElementById('selected-produit-est-mp').value === 'true';
    const qte       = parseFloat(document.getElementById('input-qte').value);
    const prix      = parseFloat(document.getElementById('input-prix').value) || 0;

    if (!produitId || !nom) { afficherErreurModal('Veuillez sélectionner un composant dans la liste.'); return; }
    if (!qte || qte <= 0)   { afficherErreurModal('La quantité doit être supérieure à 0.'); return; }

    ligneEnCours = { produitId, nom, estSousTraitance: false, quantite: qte, prixHT: prix };

    if (!estMP) {
        // Afficher modal sous-traitance
        fermerModalLigne();
        document.getElementById('sst-nom').textContent = nom;
        document.getElementById('modal-sst').style.display = 'flex';
    } else {
        ajouterLigneListe(ligneEnCours);
        fermerModalLigne();
    }
}

function confirmerSousTraitance() {
    if (!ligneEnCours) return;
    ligneEnCours.estSousTraitance = true;
    ajouterLigneListe(ligneEnCours);
    document.getElementById('modal-sst').style.display = 'none';
    ligneEnCours = null;
}

function annulerSousTraitance() {
    document.getElementById('modal-sst').style.display = 'none';
    ligneEnCours = null;
}

// ─── Ajouter une ligne à la liste ────────────────────────────────────────
function ajouterLigneListe(ligne) {
    lignes.push(ligne);
    mettreAJourAffichage();
}

function supprimerLigne(index) {
    lignes.splice(index, 1);
    mettreAJourAffichage();
}

function mettreAJourAffichage() {
    const container = document.getElementById('lignes-container');
    const empty = document.getElementById('lignes-empty');
    const totauxSection = document.getElementById('totaux-section');

    if (lignes.length === 0) {
        container.innerHTML = '';
        empty.style.display = 'block';
        totauxSection.style.display = 'none';
    } else {
        empty.style.display = 'none';
        totauxSection.style.display = 'block';

        container.innerHTML = `
            <table class="bc-table">
                <thead><tr>
                    <th>Composant</th>
                    <th style="text-align:center;">Type</th>
                    <th style="text-align:right;">Quantité</th>
                    <th style="text-align:right;">Prix HT</th>
                    <th style="text-align:right;">Total HT</th>
                    <th></th>
                </tr></thead>
                <tbody>
                    ${lignes.map((l, i) => `
                        <tr>
                            <td class="bc-td-nom">${l.nom}</td>
                            <td style="text-align:center;">
                                ${l.estSousTraitance
                                    ? '<span class="bc-badge-st">Sous-traitance</span>'
                                    : '<span class="bc-tag-mp">Matière première</span>'}
                            </td>
                            <td style="text-align:right;font-weight:600;">${l.quantite.toLocaleString('fr-FR',{minimumFractionDigits:3})}</td>
                            <td style="text-align:right;">${Number(l.prixHT).toLocaleString('fr-FR',{minimumFractionDigits:2})} DZD</td>
                            <td style="text-align:right;font-weight:700;color:var(--accent-light);">
                                ${(l.quantite * l.prixHT).toLocaleString('fr-FR',{minimumFractionDigits:2})} DZD
                            </td>
                            <td style="text-align:center;">
                                <button type="button" class="bc-btn-remove" onclick="supprimerLigne(${i})">✕</button>
                            </td>
                        </tr>`).join('')}
                </tbody>
            </table>`;
    }

    // Calcul totaux
    const totalHT = lignes.reduce((s, l) => s + l.quantite * l.prixHT, 0);
    const tva     = totalHT * 0.19;
    const ttc     = totalHT + tva;
    document.getElementById('total-ht').textContent  = totalHT.toLocaleString('fr-FR',{minimumFractionDigits:2}) + ' DZD';
    document.getElementById('total-tva').textContent = tva.toLocaleString('fr-FR',{minimumFractionDigits:2})     + ' DZD';
    document.getElementById('total-ttc').textContent = ttc.toLocaleString('fr-FR',{minimumFractionDigits:2})     + ' DZD';

    // Mettre à jour le champ caché
    document.getElementById('lignes-json').value = JSON.stringify(lignes);
}

// ─── Toggle ligne contre-offre ───────────────────────────────────────────
function toggleLigneCO(ligneId, inclus) {
    const row   = document.getElementById('co-row-' + ligneId);
    const input = document.getElementById('co-prix-' + ligneId);
    if (!row) return;
    row.classList.toggle('co-row-exclue', !inclus);
    if (input) {
        input.style.opacity = inclus ? '1' : '0.35';
        input.style.pointerEvents = inclus ? '' : 'none';
    }
}

// ─── Copier lien fournisseur ──────────────────────────────────────────────
function copierLienFournisseur(lien, btn) {
    const url = window.location.origin + lien;
    navigator.clipboard.writeText(url).then(() => {
        const orig = btn.innerHTML;
        btn.textContent = '✓ Copié !';
        setTimeout(() => { btn.innerHTML = orig; }, 2000);
    });
}

// ─── Confirmation suppression BC ─────────────────────────────────────────
function confirmSuppression() {
    return window.confirm('Supprimer définitivement ce bon de commande ?');
}

// ─── Copier le lien de confirmation ──────────────────────────────────────
function copierLien() {
    const lien = document.getElementById('lien-confirm')?.textContent;
    if (lien) {
        navigator.clipboard.writeText(lien).then(() => {
            const btn = document.querySelector('.bc-link-copy');
            if (btn) { btn.textContent = '✓ Copié !'; setTimeout(() => btn.textContent = 'Copier', 2000); }
        });
    }
}
</script>
}
