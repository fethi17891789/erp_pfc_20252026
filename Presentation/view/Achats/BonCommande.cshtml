                                            <label class="bc-multiselect-option" data-id="@f.Id" data-nom="@f.FullName" data-search="@f.FullName @f.Email">
                                                <input type="checkbox" value="@f.Id" onchange="toggleFournisseur(this, @f.Id, '@f.FullName.Replace("'", "\\'")')"/>
                                                <div style="flex:1; min-width:0;">
                                                    <div style="font-weight:600; font-size:0.85rem;">@f.FullName</div>
