                            <div class="bc-empty-warning">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;">
                                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                                </svg>
                                Aucun fournisseur dans votre annuaire.
                                <a asp-page="/AnnuaireNew" style="color:var(--accent);">Ajouter un contact fournisseur →</a>
                            </div>
                        }
                        else
                        {
                            <div class="bc-multiselect" id="fournisseur-multiselect">
