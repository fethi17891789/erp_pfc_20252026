@page
@model erp_pfc_20252026.Pages.ErrorModel

@{
    Layout = null;
    ViewData["Title"] = "Erreur SKYRA";
}

<link rel="stylesheet" href="~/fonts/plus-jakarta-sans.css" />
<link rel="stylesheet" href="~/css/Common.css" />

<div class="container">
    <div class="header">
        <h1>Une erreur est survenue</h1>
        <p>SKYRA ERP a rencontré un problème inattendu.</p>
    </div>

    <div class="form-section">
        <div class="alert-box">
            <strong>Code d'erreur : @Model.StatusCode</strong>
            @if (!string.IsNullOrEmpty(Model.RequestId))
            {
                <span style="display:block;margin-top:4px;font-size:0.75rem;opacity:0.7;">ID : @Model.RequestId</span>
            }
        </div>

        <a href="/ChooseProfile" class="btn btn-primary" style="display:inline-block;margin-top:16px;text-decoration:none;">
            Retour à l'accueil
        </a>
    </div>

    <div class="footer">
        SKYRA ERP • Si le problème persiste, redémarrez l'application.
    </div>
</div>
