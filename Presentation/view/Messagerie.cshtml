<script>
    window.currentUserIdFromServer = parseInt(document.getElementById("currentUserId")?.value || "0");

    function filterUsers(searchTerm) {
        const container = document.getElementById('usersContainer');
        if (!container) return;

        const items = container.querySelectorAll('.user-item');
        const term = (searchTerm || '').toLowerCase();

        items.forEach(item => {
            const login = (item.dataset.login || '').toLowerCase();
            const email = (item.dataset.email || '').toLowerCase();
            const poste = (item.dataset.poste || '').toLowerCase();

            if (!term || login.includes(term) || email.includes(term) || poste.includes(term)) {
                item.style.display = '';
            } else {
                item.style.display = 'none';
            }
        });
    }
</script>

