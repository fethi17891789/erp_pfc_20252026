@page
@model erp_pfc_20252026.Pages.MessagerieModel
@{
    ViewData["Title"] = "Messagerie";
}
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/Common.css">
<link rel="stylesheet" href="/css/Home.css">

<style>
    :root {
        --bg: #02030A;
        --bg-alt: #050718;
        --border-soft: rgba(255, 255, 255, 0.05);
        --text: #FFFFFF;
        --text-muted: #A4A7C8;
        --text-muted-2: #7F83A5;
        --accent: #7B5EFF;
        --accent-light: #9C8CFF;
        --accent-glow: rgba(123, 94, 255, 0.35);
    }

    .oa-preview-card {
        width: min(980px, 96vw);
        padding: 18px 20px;
        border-radius: 18px;
        background: radial-gradient(circle at top left, rgba(123, 94, 255, 0.35), transparent 55%), radial-gradient(circle at bottom right, rgba(15, 23, 42, 0.96), rgba(3, 7, 18, 0.98));
        border: 1px solid rgba(148, 163, 253, 0.5);
        box-shadow: 0 24px 80px rgba(15, 23, 42, 0.9);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    .oa-col-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: #CBD5F5;
        margin-bottom: 4px;
    }

    .oa-col-sub {
        font-size: 0.75rem;
        color: var(--text-muted-2);
        margin-bottom: 10px;
    }

    .oa-group-title {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin: 10px 0 4px;
    }

    .chat-message-row {
        display: flex;
        margin-bottom: 8px;
    }

        .chat-message-row.outgoing {
            justify-content: flex-end;
        }

        .chat-message-row.incoming {
            justify-content: flex-start;
        }

    .chat-message-bubble {
        display: inline-block;
        max-width: 420px;
        padding: 10px 12px;
        border-radius: 16px;
        background: linear-gradient(135deg, rgba(123, 94, 255, 0.16), rgba(15, 23, 42, 0.98));
        border: 1px solid rgba(123, 94, 255, 0.3);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
        font-size: 0.83rem;
    }

    .chat-message-row.outgoing .chat-message-bubble {
        border-top-right-radius: 6px;
    }

    .chat-message-row.incoming .chat-message-bubble {
        border-top-left-radius: 6px;
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(3, 7, 18, 0.98));
        border-color: rgba(148, 163, 253, 0.3);
    }

    .oa-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 3px 9px;
        border-radius: 999px;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        border: 1px solid rgba(123, 94, 255, 0.6);
        background: rgba(123, 94, 255, 0.18);
        color: #CBD5F5;
        margin-bottom: 6px;
    }

    .oa-badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 999px;
        background: var(--accent-light);
        box-shadow: 0 0 8px var(--accent-glow);
    }

    .oa-product-line {
        font-size: 0.86rem;
        margin-bottom: 2px;
    }

        .oa-product-line strong {
            font-weight: 600;
        }

    .oa-meta {
        font-size: 0.76rem;
        color: var(--text-muted-2);
        margin-top: 4px;
        margin-bottom: 8px;
    }

    .oa-status-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 3px 9px;
        border-radius: 999px;
        font-size: 0.7rem;
        border: 1px solid rgba(148, 163, 184, 0.6);
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(30, 41, 59, 0.96));
        color: #E5E7EB;
    }

    .oa-status-pill-dot {
        width: 6px;
        height: 6px;
        border-radius: 999px;
    }

    .oa-status-en-attente .oa-status-pill-dot {
        background: #FACC15;
        box-shadow: 0 0 8px rgba(250, 204, 21, 0.9);
    }

    .oa-status-confirme .oa-status-pill-dot {
        background: #22C55E;
        box-shadow: 0 0 8px rgba(34, 197, 94, 0.9);
    }

    .oa-status-refuse .oa-status-pill-dot {
        background: #F97373;
        box-shadow: 0 0 8px rgba(248, 113, 113, 0.9);
    }

    .oa-footer {
        margin-top: 8px;
        font-size: 0.7rem;
        color: var(--text-muted-2);
        display: flex;
        justify-content: space-between;
        gap: 8px;
    }

    .oa-actions {
        display: flex;
        gap: 8px;
        margin-top: 6px;
    }

    .oa-btn {
        border-radius: 999px;
        padding: 6px 14px;
        border: none;
        cursor: pointer;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .oa-btn-accept {
        background: linear-gradient(135deg, #16A34A, #22C55E);
        color: #ECFDF3;
        box-shadow: 0 8px 24px rgba(22, 163, 74, 0.6);
    }

        .oa-btn-accept:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 40px rgba(22, 163, 74, 0.8);
        }

    .oa-btn-reject {
        background: linear-gradient(135deg, #7F1D1D, #B91C1C);
        color: #FEE2E2;
        box-shadow: 0 8px 24px rgba(185, 28, 28, 0.6);
    }

        .oa-btn-reject:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 40px rgba(185, 28, 28, 0.8);
        }

    .typing-indicator {
        display: flex;
        gap: 4px;
        padding: 10px 14px;
        background: rgba(15, 23, 42, 0.9);
        border-radius: 16px;
        border-bottom-left-radius: 6px;
        width: fit-content;
        align-items: center;
        margin-bottom: 8px;
        border: 1px solid rgba(148, 163, 253, 0.2);
    }

    .typing-dot {
        width: 6px;
        height: 6px;
        background: var(--accent-light);
        border-radius: 50%;
        animation: typing-bounce 1.4s infinite ease-in-out both;
        box-shadow: 0 0 8px var(--accent-glow);
    }

    .typing-dot:nth-child(1) { animation-delay: -0.32s; }
    .typing-dot:nth-child(2) { animation-delay: -0.16s; }

    @@keyframes typing-bounce {
        0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
        40% { transform: scale(1.1); opacity: 1; }
    }

    /* ==== FIX LAYOUT MESSAGERIE (No Global Scroll) ==== */
    .erp-main {
        overflow: hidden !important;
        display: flex;
        flex-direction: column;
        height: 100vh;
        max-height: 100vh;
        padding-bottom: 10px !important;
    }

    .erp-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
        gap: 12px;
        padding-bottom: 4px;
    }

    .chat-layout {
        flex: 1;
        min-height: 0;
        height: auto !important;
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 16px;
    }

    .chat-sidebar {
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    #usersContainer {
        max-height: none !important;
        flex: 1;
        min-height: 0;
        overflow-y: auto;
    }

    .chat-main {
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    /* ==== ANIMATIONS OVERLAY DRAG & DROP ==== */
    @@keyframes overlayFadeIn {
        from { opacity: 0; backdrop-filter: blur(0); }
        to { opacity: 1; backdrop-filter: blur(4px); }
    }

    @@keyframes iconBounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    @@keyframes pulseGlow {
        0%, 100% { box-shadow: 0 0 20px rgba(123, 94, 255, 0.4); border-color: var(--accent); }
        50% { box-shadow: 0 0 40px rgba(123, 94, 255, 0.8); border-color: var(--accent-light); }
    }

    .drop-zone-active {
        animation: overlayFadeIn 0.3s ease forwards;
        display: flex !important;
    }

    .drop-zone-icon {
        animation: iconBounce 2s infinite ease-in-out;
    }

    .drop-zone-circle {
        animation: pulseGlow 2s infinite ease-in-out;
    }

    /* ==== ANIMATIONS BOUTONS CHAT ==== */
    .btn-chat-action {
        transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
        cursor: pointer;
    }

    .btn-chat-action:hover {
        transform: scale(1.25) translateY(-3px) rotate(5deg);
        color: var(--accent-light) !important;
        filter: drop-shadow(0 4px 12px var(--accent-glow));
    }

    .btn-chat-action:active {
        transform: scale(0.9);
    }

    #btnSend {
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    #btnSend:hover {
        box-shadow: 0 0 25px rgba(123, 94, 255, 0.8);
        transform: translateY(-2px) scale(1.08);
    }

    #btnSend:active {
        transform: scale(0.96);
    }

    /* Animation de pulsation pour l'enregistrement vocal */
    @@keyframes recordingPulse {
        0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); background: rgba(239, 68, 68, 0.1); transform: scale(1); }
        50% { box-shadow: 0 0 0 15px rgba(239, 68, 68, 0); background: rgba(239, 68, 68, 0.3); transform: scale(1.1); }
        100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); background: rgba(239, 68, 68, 0.1); transform: scale(1); }
    }

    .is-recording {
        animation: recordingPulse 1.2s infinite !important;
        color: #ef4444 !important;
        background: rgba(239, 68, 68, 0.1) !important;
        border-radius: 50% !important;
        z-index: 10;
    }

    /* ==== CUSTOM AUDIO PLAYER ==== */
    .audio-player {
        background: rgba(8, 12, 32, 0.6);
        border: 1px solid rgba(123, 94, 255, 0.2);
        border-radius: 12px;
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 260px;
        margin: 6px 0;
        backdrop-filter: blur(8px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.4);
    }

    .audio-play-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent), var(--accent-hover));
        border: none;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(123, 94, 255, 0.3);
    }

    .audio-play-btn:hover {
        transform: scale(1.15);
        box-shadow: 0 6px 20px var(--accent-glow);
    }

    .audio-play-btn svg {
        width: 16px;
        height: 16px;
        fill: currentColor;
    }

    .audio-content-right {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .audio-visual-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .audio-progress-container {
        flex: 1;
        height: 6px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
        position: relative;
        cursor: pointer;
        overflow: hidden;
    }

    .audio-progress-bar {
        height: 100%;
        background: linear-gradient(90deg, var(--accent-light), var(--accent));
        border-radius: 3px;
        width: 0%;
        transition: width 0.1s linear;
    }

    .audio-info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.65rem;
        color: var(--text-muted);
        font-weight: 600;
        letter-spacing: 0.02em;
    }

    .audio-waves {
        display: flex;
        align-items: center;
        gap: 2px;
        height: 14px;
    }

    .audio-wave-bar {
        width: 2px;
        background: var(--accent-light);
        border-radius: 1px;
        opacity: 0.4;
        transition: height 0.2s ease;
    }
</style>

<div class="erp-shell">
    <!-- BARRE LATÉRALE GAUCHE (identique) -->
    <aside class="erp-sidebar">
        <div class="erp-logo">
            <span class="erp-logo-mark">E</span>
            <span class="erp-logo-text">ERP Suite</span>
        </div>
        <nav class="erp-nav">
            <a asp-page="/Home" class="nav-item">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
                <span>Accueil</span>
            </a>
            <a asp-page="/Fabrication" class="nav-item">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 9h12M6 12h12M6 15h12M3 3h18a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2z" />
                </svg>
                <span>Modules</span>
            </a>
            <button class="nav-item" type="button">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
                <span>Profils</span>
            </button>
            <button class="nav-item" type="button">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7" />
                    <rect x="14" y="3" width="7" height="7" />
                    <rect x="14" y="14" width="7" height="7" />
                    <rect x="3" y="14" width="7" height="7" />
                </svg>
                <span>Bases ERP</span>
            </button>
            <button class="nav-item" type="button">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="1" />
                    <path d="M12 1v6m6.07 6.07h-6.13M12 19v4m6.07-6.07v0" />
                    <path d="M19 5l-4.24 4.24M5 19l4.24-4.24" />
                    <path d="M19 19l-4.24-4.24M5 5l4.24 4.24" />
                </svg>
                <span>Paramètres</span>
            </button>
        </nav>
        <div class="erp-sidebar-footer">
            <button class="sidebar-quick" type="button">
                <svg style="width: 14px; height: 14px; display: inline-block; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="15" x2="12" y2="21" />
                    <line x1="15" y1="11" x2="21" y2="12" />
                </svg>
                Nouveau profil
            </button>
            <button class="sidebar-quick secondary" type="button" onclick="openLogoutModal()">
                <svg style="width: 14px; height: 14px; display: inline-block; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 3 16 10 13 7" />
                    <path d="M16 10v7a2 2 0 0 1-2 2h-2" />
                </svg>
                Déconnexion
            </button>
        </div>
    </aside>

    <!-- CONTENU PRINCIPAL -->
    <main class="erp-main">
        <!-- HEADER GLOBAL -->
        <header class="erp-header">
            <div class="header-left">
                <h1>Messagerie</h1>
                <p>Discutez avec vos utilisateurs internes.</p>
            </div>
            <div class="header-right">
                <div class="header-db">
                    <span class="header-db-label">Base active</span>
                    <span class="header-db-name">erp_db</span>
                </div>
                <button class="header-btn" type="button">
                    <svg style="width: 14px; height: 14px; display: inline-block; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M1 4v6h6" />
                        <path d="M23 20v-6h-6" />
                        <path d="M20.49 9A9 9 0 0 0 5.64 5.64" />
                        <path d="M3.51 15A9 9 0 0 0 18.36 18.36" />
                    </svg>
                    Changer de base
                </button>
                <button class="header-profile-btn" type="button">
                    <div class="header-avatar">P</div>
                </button>
            </div>
        </header>

        <!-- CONTENU MESSAGERIE -->
        <section class="erp-content">
            <!-- Bandeau info -->
            <div class="alert-box">
                @if (Model.Utilisateurs == null || !Model.Utilisateurs.Any())
                {
                    <text>Aucun utilisateur trouvé dans ErpUsers. Créez au moins un autre profil pour démarrer la messagerie.</text>
                }
                else
                {
                    <text>@Model.Utilisateurs.Count utilisateur(s) trouvé(s). Cliquez sur un utilisateur puis envoyez un message.</text>
                }
            </div>

            <div class="chat-layout">
                <!-- COLONNE GAUCHE : recherche + liste utilisateurs -->
                <aside class="chat-sidebar" style="gap:12px; padding:12px; border-radius:16px; background:rgba(4,6,20,0.9); border:1px solid rgba(255,255,255,0.06);">

                    <div>
                        <label class="chat-label" style="font-size:0.75rem; font-weight:600; text-transform:uppercase; color:var(--text-muted); margin-bottom:6px; display:block;">
                            Rechercher un utilisateur
                        </label>
                        <div class="chat-search-wrapper" style="position:relative;">
                            <input type="text"
                                   id="userSearchInput"
                                   onkeyup="filterUsers(this.value)"
                                   placeholder="Login, email ou poste..."
                                   style="width:100%; height:var(--input-height); padding:0 32px 0 12px; border-radius:var(--radius-sm); border:1px solid var(--border); background:linear-gradient(135deg, rgba(8,11,32,0.98), rgba(18,22,54,0.98)); color:var(--text); font-size:0.85rem;" />
                            <span style="position:absolute; right:8px; top:50%; transform:translateY(-50%); color:var(--text-muted-2);">
                                🔍
                            </span>
                        </div>
                    </div>

                    <div style="border-top:1px solid rgba(255,255,255,0.06); padding-top:10px; display:flex; flex-direction:column; gap:6px; flex:1; min-height:0;">
                        <div style="display:flex; justify-content:space-between; align-items:center;">
                            <h2 style="font-size:0.9rem;">Utilisateurs</h2>
                            <span style="font-size:0.7rem; padding:2px 8px; border-radius:999px; border:1px solid rgba(255,255,255,0.14); color:var(--text-muted);">
                                @Model.Utilisateurs.Count
                            </span>
                        </div>

                        <div id="usersContainer" style="opacity:0.95; display:flex; flex-direction:column; gap:4px;">
                            @if (Model.Utilisateurs != null && Model.Utilisateurs.Any())
                            {
                                foreach (var u in Model.Utilisateurs)
                                {
                                    var displayName = string.IsNullOrWhiteSpace(u.Login)
                                    ? (string.IsNullOrWhiteSpace(u.Email) ? "Utilisateur" : u.Email)
                                    : u.Login;

                                    var initial = !string.IsNullOrWhiteSpace(displayName)
                                    ? char.ToUpper(displayName[0]).ToString()
                                    : "U";

                                    var statusText = u.IsOnline ? "En ligne" : "Hors ligne";
                                    var statusClass = u.IsOnline ? "online" : "offline";

                                    <button type="button"
                                            class="user-item"
                                            data-user-id="@u.Id"
                                            data-login="@u.Login"
                                            data-email="@u.Email"
                                            data-poste="@u.Poste"
                                            data-isonline="@u.IsOnline"
                                            style="width:100%; text-align:left; border:none; background:transparent; padding:6px 8px; border-radius:10px; display:flex; gap:8px; align-items:center; cursor:pointer;">
                                        <div style="width:28px; height:28px; border-radius:999px; background:linear-gradient(135deg, var(--accent), var(--accent-hover)); display:flex; align-items:center; justify-content:center; font-size:0.8rem; font-weight:700;">
                                            @initial
                                        </div>
                                        <div style="flex:1; min-width:0;">
                                            <div style="display:flex; align-items:center; gap:6px;">
                                                <div style="font-size:0.85rem; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                                    @displayName
                                                </div>
                                                <span class="chat-user-status @statusClass"></span>
                                            </div>
                                            <div style="font-size:0.75rem; color:var(--text-muted-2); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                                @u.Email (@u.Poste)
                                            </div>
                                            <div class="chat-user-status-text @statusClass">
                                                @statusText
                                            </div>
                                        </div>
                                    </button>
                                }
                            }
                            else
                            {
                                <div style="font-size:0.8rem; color:var(--text-muted-2); padding:8px 4px;">
                                    Aucun autre utilisateur pour le moment. Créez un nouveau profil pour démarrer la messagerie.
                                </div>
                            }
                        </div>
                    </div>
                </aside>

                <!-- COLONNE DROITE : conversation -->
                <section class="chat-main" style="position:relative; border-radius:16px; background:rgba(4,6,20,0.92); border:1px solid rgba(255,255,255,0.08); padding:8px 8px 6px; min-width:0;">

                    <!-- Overlay Drag & Drop -->
                    <div id="chatDropZoneOverlay" style="display:none; position:absolute; inset:0; background:rgba(123, 94, 255, 0.15); z-index:100; border:2px dashed var(--accent); border-radius:16px; align-items:center; justify-content:center; pointer-events:none; flex-direction:column; gap:12px;">
                        <div class="drop-zone-circle" style="width:60px; height:60px; border-radius:50%; background:rgba(123, 94, 255, 0.2); display:flex; align-items:center; justify-content:center; border:1px solid var(--accent); color:white; font-size:1.5rem;">
                            <svg class="drop-zone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:28px; height:28px;">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
