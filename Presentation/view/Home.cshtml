@page
@model erp_pfc_20252026.Pages.HomeModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Tableau de bord ERP";
}

@section HeaderLeft {
    <h1>Tableau de bord ERP</h1>
    <p>Accédez à vos modules, profils et configuration.</p>
}




        <!-- KPI CARDS -->
        <section class="erp-content" style="padding-bottom:0;">
            <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:16px; margin-bottom:24px;">

                <!-- Produits -->
                <div style="display:flex; align-items:center; gap:16px; padding:20px 24px;
                            background:linear-gradient(135deg, rgba(8,11,32,0.96), rgba(18,22,54,0.96));
                            border:1px solid rgba(255,255,255,0.08); border-radius:16px;
                            box-shadow:0 8px 24px rgba(0,0,0,0.3);
                            transition:transform 150ms ease, box-shadow 150ms ease;"
                     onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 14px 40px rgba(123,94,255,0.25)';"
                     onmouseout="this.style.transform='';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.3)';">
                    <div style="width:48px; height:48px; border-radius:14px; flex-shrink:0;
                                background:rgba(123,94,255,0.15); border:1px solid rgba(123,94,255,0.3);
                                display:flex; align-items:center; justify-content:center;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#9C8CFF" stroke-width="2" style="width:22px;height:22px;">
                            <path d="M3 7.5L12 3l9 4.5v9L12 21l-9-4.5v-9z"/>
                            <path d="M12 21v-9"/><path d="M3 7.5l9 4.5 9-4.5"/>
                        </svg>
                    </div>
                    <div>
                        <div style="font-size:1.8rem; font-weight:800; color:#fff; line-height:1;">@Model.NbProduits</div>
                        <div style="font-size:0.8rem; color:var(--text-muted); margin-top:3px;">Produits enregistrés</div>
                    </div>
                    <a asp-page="/ProduitCreate" style="margin-left:auto; color:var(--accent-light); font-size:0.75rem; text-decoration:none; opacity:0.7; transition:opacity .15s;"
                       onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">Voir →</a>
                </div>

                <!-- Contacts -->
                <div style="display:flex; align-items:center; gap:16px; padding:20px 24px;
                            background:linear-gradient(135deg, rgba(8,11,32,0.96), rgba(18,22,54,0.96));
                            border:1px solid rgba(255,255,255,0.08); border-radius:16px;
                            box-shadow:0 8px 24px rgba(0,0,0,0.3);
                            transition:transform 150ms ease, box-shadow 150ms ease;"
                     onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 14px 40px rgba(56,189,248,0.2)';"
                     onmouseout="this.style.transform='';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.3)';">
                    <div style="width:48px; height:48px; border-radius:14px; flex-shrink:0;
                                background:rgba(56,189,248,0.12); border:1px solid rgba(56,189,248,0.3);
                                display:flex; align-items:center; justify-content:center;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="2" style="width:22px;height:22px;">
                            <circle cx="12" cy="7" r="4"/>
                            <path d="M5 22v-2a7 7 0 0 1 14 0v2"/>
                        </svg>
                    </div>
                    <div>
                        <div style="font-size:1.8rem; font-weight:800; color:#fff; line-height:1;">@Model.NbContacts</div>
                        <div style="font-size:0.8rem; color:var(--text-muted); margin-top:3px;">Contacts (clients, fournisseurs…)</div>
                    </div>
                    <a asp-page="/AnnuaireList" style="margin-left:auto; color:#38bdf8; font-size:0.75rem; text-decoration:none; opacity:0.7; transition:opacity .15s;"
                       onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">Voir →</a>
                </div>

                <!-- Véhicules -->
                <div style="display:flex; align-items:center; gap:16px; padding:20px 24px;
                            background:linear-gradient(135deg, rgba(8,11,32,0.96), rgba(18,22,54,0.96));
                            border:1px solid rgba(255,255,255,0.08); border-radius:16px;
                            box-shadow:0 8px 24px rgba(0,0,0,0.3);
                            transition:transform 150ms ease, box-shadow 150ms ease;"
                     onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 14px 40px rgba(34,197,94,0.2)';"
                     onmouseout="this.style.transform='';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.3)';">
                    <div style="width:48px; height:48px; border-radius:14px; flex-shrink:0;
                                background:rgba(34,197,94,0.12); border:1px solid rgba(34,197,94,0.3);
                                display:flex; align-items:center; justify-content:center;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" style="width:22px;height:22px;">
                            <path d="M10 17h4V5H2v12h3m0 0a2 2 0 1 0 4 0 2 2 0 1 0-4 0m10 0h3l4-4v-4h-7v8m0 0a2 2 0 1 0 4 0 2 2 0 1 0-4 0"/>
                        </svg>
                    </div>
                    <div>
                        <div style="line-height:1;">
                            <span style="font-size:1.8rem; font-weight:800; color:@(Model.NbVehiculesEnRoute > 0 ? "#22c55e" : "#fff");">@Model.NbVehiculesEnRoute</span>
                            <span style="font-size:1.1rem; font-weight:600; color:var(--text-muted);"> / @Model.NbVehiculesTotal</span>
                        </div>
                        <div style="font-size:0.8rem; color:var(--text-muted); margin-top:3px;">
                            @if (Model.NbVehiculesEnRoute > 0)
                            {
                                <span style="color:#22c55e; font-weight:600;">●</span>
                                <span> véhicule@(Model.NbVehiculesEnRoute > 1 ? "s" : "") en livraison</span>
                            }
                            else
                            {
                                <span>Aucun véhicule en route</span>
                            }
                        </div>
                    </div>
                    <a asp-page="/Logistique/Index" style="margin-left:auto; color:#22c55e; font-size:0.75rem; text-decoration:none; opacity:0.7; transition:opacity .15s;"
                       onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">Voir →</a>
                </div>

            </div>
        </section>

        <!-- BLOC PRINCIPAL : MODULES -->
        <section class="erp-content">
            <div class="section-header">
                <h2>Modules ERP</h2>
                <button class="section-link" type="button">Voir tous</button>
            </div>

            <div class="modules-grid">
                <!-- Ventes -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M9 2l3-2h6l3 2H22v2H2V2z"></path>
                                <path d="M3 4h18v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4z"></path>
                                <circle cx="12" cy="13" r="2"></circle>
                            </svg>
                        </div>
                        <span class="module-badge">Ventes</span>
                    </div>
                    <h3>Gestion commerciale</h3>
                    <p>Devis, commandes et facturation clients.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">À venir</span>
                        <button class="module-action" type="button">Ouvrir</button>
                    </div>
                </article>

                <!-- Achats -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="9" cy="21" r="1"></circle>
                                <circle cx="20" cy="21" r="1"></circle>
                                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                            </svg>
                        </div>
                        <span class="module-badge">Achats</span>
                    </div>
                    <h3>Approvisionnement</h3>
                    <p>Commandes fournisseurs et réceptions.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">À venir</span>
                        <button class="module-action" type="button">Ouvrir</button>
                    </div>
                </article>

                <!-- Stock -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="3" width="7" height="7"></rect>
                                <rect x="14" y="3" width="7" height="7"></rect>
                                <rect x="14" y="14" width="7" height="7"></rect>
                                <rect x="3" y="14" width="7" height="7"></rect>
                            </svg>
                        </div>
                        <span class="module-badge">Stock</span>
                    </div>
                    <h3>Gestion d'inventaire</h3>
                    <p>Magasins, mouvements et niveaux.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">À venir</span>
                        <button class="module-action" type="button">Ouvrir</button>
                    </div>
                </article>

                <!-- Production (MRP) -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M2 6l10-4 10 4M2 6v12l10 4 10-4V6M2 6l10 4 10-4"></path>
                                <polyline points="12 10 12 20"></polyline>
                            </svg>
                        </div>
                        <span class="module-badge">Production</span>
                    </div>
                    <h3>Fabrication (MRP)</h3>
                    <p>Ordres de fabrication et planification.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">Actif</span>
                        <a asp-page="/Fabrication" class="module-action-link">
                            <button class="module-action" type="button">Ouvrir</button>
                        </a>
                    </div>
                </article>

                <!-- Logistique -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M10 17h4V5H2v12h3m0 0a2 2 0 1 0 4 0 2 2 0 1 0-4 0m10 0h3l4-4v-4h-7v8m0 0a2 2 0 1 0 4 0 2 2 0 1 0-4 0"></path>
                            </svg>
                        </div>
                        <span class="module-badge">Logistique</span>
                    </div>
                    <h3>Flotte & Tracking</h3>
                    <p>Gestion des véhicules et suivi GPS en temps réel.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">Actif</span>
                        <a asp-page="/Logistique/Index" class="module-action-link">
                            <button class="module-action" type="button">Ouvrir</button>
                        </a>
                    </div>
                </article>

                <!-- Bilan Carbone RSE -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
                                <path d="M7 15s1 1 2.5 1S12 14 14 14s3.5 2 3.5 2"/>
                                <path d="M8 9h.01M16 9h.01"/>
                            </svg>
                        </div>
                        <span class="module-badge">RSE</span>
                    </div>
                    <h3>Bilan Carbone RSE</h3>
                    <p>Empreinte écologique de la flotte et émissions CO2.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">Actif</span>
                        <a asp-page="/Logistique/Environnement" class="module-action-link" style="text-decoration:none;">
                            <button class="module-action" type="button">Ouvrir</button>
                        </a>
                    </div>
                </article>

                <!-- Annuaire CRM -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle" >
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="7" r="4"></circle>
                                <path d="M5 22v-2a7 7 0 0 1 14 0v2"></path>
                            </svg>
                        </div>
                        <span class="module-badge" >Annuaire</span>
                    </div>
                    <h3>Contacts Globaux</h3>
                    <p>Clients, fournisseurs et contacts.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">Actif</span>
                        <a asp-page="/AnnuaireList" class="module-action-link" style="text-decoration:none;">
                            <button class="module-action" type="button" style="cursor:pointer;">Ouvrir</button>
                        </a>
                    </div>
                </article>

                <!-- Comptabilité -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="2" x2="12" y2="22"></line>
                                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                            </svg>
                        </div>
                        <span class="module-badge">Comptabilité</span>
                    </div>
                    <h3>Gestion financière</h3>
                    <p>Écritures, états et TVA.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">À venir</span>
                        <button class="module-action" type="button">Ouvrir</button>
                    </div>
                </article>

                <!-- Tableaux de bord -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="12 3 20 7.5 20 16.5 12 21 4 16.5 4 7.5 12 3"></polyline>
                                <polyline points="12 12 20 7.5"></polyline>
                                <polyline points="12 12 12 21"></polyline>
                                <polyline points="12 12 4 7.5"></polyline>
                            </svg>
                        </div>
                        <span class="module-badge">Reporting</span>
                    </div>
                    <h3>Tableaux de bord</h3>
                    <p>KPIs, graphiques et synthèses.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">À venir</span>
                        <button class="module-action" type="button">Ouvrir</button>
                    </div>
                </article>

                <!-- Rapports -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h12l4 4v12H4z"></path>
                                <path d="M16 4v4h4"></path>
                                <line x1="8" y1="12" x2="16" y2="12"></line>
                                <line x1="8" y1="16" x2="14" y2="16"></line>
                            </svg>
                        </div>
                        <span class="module-badge">Rapports</span>
                    </div>
                    <h3>Modèles de rapports</h3>
                    <p>Créer, structurer et archiver des rapports standards.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">Actif</span>
                        <button class="module-action" type="button">Ouvrir</button>
                    </div>
                </article>

                <!-- Paramètres -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="3"></circle>
                                <path d="M12 1v6m6 0h6m0 6v6m-6 6h6m-10-6v6m0-10h-6m0 10v6"></path>
                                <path d="M4.22 4.22l4.24 4.24m0 7.08l-4.24 4.24M19.78 4.22l-4.24 4.24m0 7.08l4.24 4.24"></path>
                            </svg>
                        </div>
                        <span class="module-badge">Configuration</span>
                    </div>
                    <h3>Paramètres système</h3>
                    <p>Sécurité, utilisateurs et bases.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">À venir</span>
                        <button class="module-action" type="button">Ouvrir</button>
                    </div>
                </article>
            </div>
        </section>
@section Scripts {
    <script src="~/js/Home.js"></script>
}



