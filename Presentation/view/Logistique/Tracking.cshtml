@page
@model erp_pfc_20252026.Pages.Logistique.TrackingModel
@{
    Layout = null; // Page autonome pour mobile
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>ERP Tracking - Chauffeur</title>
    <link rel="stylesheet" href="~/fonts/plus-jakarta-sans.css" />
    <style>
        :root {
            --bg: #020617;
            --accent: #7b5eff;
            --accent-light: #a5b4fc;
            --card-bg: rgba(30, 41, 59, 0.7);
            --danger: #ef4444;
            --success: #22c55e;
            --text-muted: #94a3b8;
        }
        * { box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }
        body {
            margin: 0; padding: 20px;
            background-color: var(--bg); color: white;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            min-height: 100vh; text-align: center;
        }
        .container {
            width: 100%; max-width: 400px;
            background: var(--card-bg); backdrop-filter: blur(10px);
            border-radius: 24px; padding: 30px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            position: relative; overflow: hidden;
            transition: all 0.3s ease;
        }
        h1 { font-size: 1.5rem; margin: 0 0 5px; font-weight: 800; }
        p.subtitle { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 25px; line-height: 1.4; }
        .vehicule-box {
            background: rgba(123, 94, 255, 0.1); border: 1px solid rgba(123, 94, 255, 0.3);
            border-radius: 16px; padding: 15px; margin-bottom: 25px;
            display: flex; flex-direction: column; align-items: center;
        }
        .vehicule-label { font-size: 0.75rem; color: var(--accent-light); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
        .vehicule-name { font-size: 1.1rem; font-weight: 700; color: white; }
        select {
            width: 100%; padding: 12px; background: rgba(0,0,0,0.2); 
            border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 12px; color: white; font-size: 1rem;
        }
        .chrono-wrapper { position: relative; width: 180px; height: 180px; margin: 0 auto 25px; display: none; }
        .is-tracking .chrono-wrapper { display: block; animation: fadeIn 0.5s ease forwards; }
        .chrono-ring { transform: rotate(-90deg); width: 100%; height: 100%; }
        .chrono-circle-bg { fill: none; stroke: rgba(255,255,255,0.05); stroke-width: 8; }
        .chrono-circle-fg { 
            fill: none; stroke: var(--accent); stroke-width: 8; 
            stroke-dasharray: 440; stroke-dashoffset: 440; 
            stroke-linecap: round; transition: stroke-dashoffset 1s linear; 
        }
        .chrono-text-container { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
        .chrono-time { font-size: 2.2rem; font-weight: 800; color: white; line-height: 1; font-variant-numeric: tabular-nums; }
        .chrono-label { font-size: 0.7rem; color: var(--text-muted); margin-top: 6px; text-transform: uppercase; letter-spacing: 1px; }
        .initial-icon { width: 80px; height: 80px; background: rgba(123, 94, 255, 0.2); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; color: var(--accent); }
        .is-tracking .initial-icon { display: none; }
        .stats-grid { display: none; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 25px; }
        .is-tracking .stats-grid { display: grid; animation: fadeIn 0.5s ease forwards; }
        .stat-card { background: rgba(0, 0, 0, 0.2); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; padding: 15px; }
        .stat-value { font-size: 1.5rem; font-weight: 800; color: white; display: flex; align-items: baseline; justify-content: center; gap: 2px; }
        .stat-unit { font-size: 0.8rem; color: var(--accent-light); font-weight: 600; }
        .stat-label { font-size: 0.75rem; color: var(--text-muted); margin-top: 4px; }
        .btn { width: 100%; padding: 16px; border-radius: 16px; border: none; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.3s ease; }
        .btn-start { background: var(--accent); color: white; }
        .btn-stop { background: var(--danger); color: white; display: none; }
        .is-tracking .btn-start { display: none; }
        .is-tracking .btn-stop { display: block; }
        .btn-demo {
            width: 100%; padding: 14px; border-radius: 16px; border: none;
            font-size: 0.9rem; font-weight: 700; cursor: pointer;
            background: linear-gradient(135deg, #f59e0b, #ef4444);
            color: white; margin-top: 12px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(245, 158, 11, 0.3);
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-demo:hover { transform: translateY(-2px); box-shadow: 0 6px 25px rgba(245, 158, 11, 0.4); }
        .btn-demo:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
        .is-tracking .btn-demo { display: none; }
        .is-demo .btn-stop { display: none; } /* En démo, arrêt géré automatiquement */
        .demo-badge {
            position: absolute; top: 14px; right: 14px;
            background: linear-gradient(135deg, #f59e0b, #ef4444);
            color: white; font-size: 0.65rem; font-weight: 800;
            padding: 4px 10px; border-radius: 20px;
            text-transform: uppercase; letter-spacing: 1px;
            display: none; animation: fadeIn 0.4s ease;
        }
        .is-demo .demo-badge { display: block; }
        .demo-phase-banner {
            width: 100%; padding: 10px 14px; border-radius: 12px;
            font-size: 0.82rem; font-weight: 700;
            display: none; margin-bottom: 14px;
            animation: fadeIn 0.3s ease;
            text-align: center; letter-spacing: 0.5px;
        }
        .demo-phase-banner.aller {
            background: rgba(34, 197, 94, 0.15);
            border: 1px solid rgba(34, 197, 94, 0.35);
            color: #4ade80;
        }
        .demo-phase-banner.livraison {
            background: rgba(245, 158, 11, 0.15);
            border: 1px solid rgba(245, 158, 11, 0.35);
            color: #fbbf24;
        }
        .demo-phase-banner.retour {
            background: rgba(123, 94, 255, 0.15);
            border: 1px solid rgba(123, 94, 255, 0.35);
            color: #a78bfa;
        }
        .is-demo .demo-phase-banner { display: block; }
        .demo-progress-bar {
            width: 100%; height: 6px; background: rgba(255,255,255,0.1);
            border-radius: 4px; margin-top: 12px;
            display: none; overflow: hidden; position: relative;
        }
        .is-demo .demo-progress-bar { display: block; }
        .demo-progress-fill {
            height: 100%; width: 0%;
            background: linear-gradient(90deg, #22c55e, #f59e0b, #7b5eff);
            border-radius: 4px;
            transition: width 1.5s linear;
        }
        /* Marqueur mi-parcours (point de livraison) */
        .demo-midpoint-marker {
            position: absolute; top: -3px; left: 50%;
            transform: translateX(-50%);
            width: 12px; height: 12px;
            background: #f59e0b; border-radius: 50%;
            border: 2px solid #020617;
            box-shadow: 0 0 6px #f59e0b;
        }
        .status-info { margin-top: 20px; font-size: 0.8rem; color: var(--text-muted); display: flex; align-items: center; justify-content: center; gap: 6px; }
        .status-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--text-muted); }
        .is-tracking .status-dot { background: var(--success); box-shadow: 0 0 10px var(--success); animation: pulse 1.5s infinite; }
        .modal { display: none; position: fixed; inset: 0; background: rgba(2, 6, 23, 0.9); backdrop-filter: blur(8px); z-index: 100; align-items: center; justify-content: center; padding: 20px; }
        .modal.show { display: flex; animation: fadeIn 0.3s ease forwards; }
        .modal-content { background: var(--card-bg); border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; padding: 25px; width: 100%; max-width: 350px; text-align: center; }
        .modal-stats { display: flex; justify-content: space-around; background: rgba(0,0,0,0.2); padding: 15px; border-radius: 16px; margin-bottom: 20px; }
        .modal-actions { display: flex; gap: 10px; }
        .btn-secondary { background: rgba(255,255,255,0.1); color: white; flex: 1; }
        @@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>
    <div class="container" id="main-container">
        <div class="initial-icon">
            <svg style="width: 40px; height: 40px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7z"></path>
                <circle cx="12" cy="9" r="3"></circle>
            </svg>
        </div>
        <h1>Assistant Trajet</h1>
        <p class="subtitle" id="subtitle-text">Activez la localisation pour transmettre vos positions en direct.</p>
        @{
            var preSelectedVehiculeId = ViewContext.HttpContext.Request.Query["vehiculeId"].ToString();
            var hasPreSelection = !string.IsNullOrEmpty(preSelectedVehiculeId);
        }
        <div id="vehicule-selection-area" style="@(hasPreSelection ? "display:none;" : "margin-bottom:20px;")">
            <select id="vehicule-select">
                <option value="">Sélectionner votre véhicule...</option>
                @foreach(var v in Model.VehiculesDisponibles) {
                    <option value="@v.Id">@v.Nom (@v.Matricule)</option>
                }
            </select>
        </div>
        @if(hasPreSelection) {
            var selectedV = Model.VehiculesDisponibles.FirstOrDefault(v => v.Id.ToString() == preSelectedVehiculeId);
            if (selectedV != null) {
                <div class="vehicule-box">
                    <span class="vehicule-label">Assignation active</span>
                    <span class="vehicule-name">@selectedV.Nom</span>
                </div>
                <input type="hidden" id="hidden-vehicule-id" value="@selectedV.Id" />
            }
        }
        <div class="chrono-wrapper">
            <svg class="chrono-ring" viewBox="0 0 160 160">
                <circle class="chrono-circle-bg" cx="80" cy="80" r="70"></circle>
                <circle class="chrono-circle-fg" cx="80" cy="80" r="70" id="chrono-progress"></circle>
            </svg>
            <div class="chrono-text-container">
                <div class="chrono-time" id="chrono-display">00:00</div>
                <div class="chrono-label">En cours</div>
            </div>
        </div>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value"><span id="live-distance">0.00</span> <span class="stat-unit">km</span></div>
                <div class="stat-label">Distance parcourue</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><span id="live-speed">0</span> <span class="stat-unit">km/h</span></div>
                <div class="stat-label">Vitesse actuelle</div>
            </div>
        </div>
        <span class="demo-badge">🎬 SIMULATION</span>
        <div class="demo-phase-banner aller" id="demo-phase-banner">🚚 En route vers le client...</div>
        <button id="btn-start" class="btn btn-start">DÉMARRER LE TRAJET</button>
        <button id="btn-stop" class="btn btn-stop">TERMINER LE TRAJET</button>
        <button id="btn-demo" class="btn btn-demo">🎬 LANCER LA SIMULATION DÉMO</button>
        <div class="demo-progress-bar">
            <div class="demo-progress-fill" id="demo-progress-fill"></div>
            <div class="demo-midpoint-marker" title="Point de livraison"></div>
        </div>
        <div class="status-info">
            <span class="status-dot"></span>
            <span id="status-text">GPS en attente</span>
        </div>
    </div>
    <div id="stop-modal" class="modal">
        <div class="modal-content">
            <h3>Clôturer le trajet</h3>
            <p>Êtes-vous sûr d'être arrivé ? Le tracé sera enregistré dans l'historique.</p>
            <div class="modal-stats">
                <div>
                    <strong style="display:block; font-size:1.2rem; color:white;" id="modal-time">00:00:00</strong>
                    <span style="font-size:0.7rem; color:var(--text-muted);">Durée totale</span>
                </div>
                <div>
                    <strong style="display:block; font-size:1.2rem; color:white;" id="modal-dist">0.00 km</strong>
                    <span style="font-size:0.7rem; color:var(--text-muted);">Distance</span>
                </div>
            </div>
            <div class="modal-actions">
                <button class="btn btn-secondary" onclick="window.closeStopModal()">Annuler</button>
                <button class="btn btn-start" onclick="window.confirmStop()">Confirmer l'arrêt</button>
            </div>
        </div>
    </div>

    <script src="~/lib/signalr/signalr.min.js"></script>
    <script>
        // --- ÉLÉMENTS DOM ---
        const container = document.getElementById('main-container');
        const btnStart = document.getElementById('btn-start');
        const btnStop = document.getElementById('btn-stop');
        const statusText = document.getElementById('status-text');
        const subtitleText = document.getElementById('subtitle-text');
        const chronoDisplay = document.getElementById('chrono-display');
        const chronoProgress = document.getElementById('chrono-progress');
        const uiLiveDistance = document.getElementById('live-distance');
        const uiLiveSpeed = document.getElementById('live-speed');
        const vehiculeSelect = document.getElementById('vehicule-select');
        const hiddenVehiculeId = document.getElementById('hidden-vehicule-id');
        const stopModal = document.getElementById('stop-modal');

        // --- ÉTAT ---
        let isTracking = false;
        let watchId = null;
        let activeVehiculeId = null;
        let activeTrajetId = null;
        let startTime = null;
        let chronoInterval = null;
        let totalDistanceKm = 0;
        let lastPosition = null;
        let tracePoints = [];
        let deviceId = localStorage.getItem('erp_device_id') || ('web-' + Math.random().toString(36).substr(2, 9));
        localStorage.setItem('erp_device_id', deviceId);

        // --- ÉTAT SIMULATION ---
        let isDemoMode = false;
        let demoInterval = null;
        let demoRoutePoints = [];
        let demoPointIndex = 0;

        // --- SIGNALR ---
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/logistiquehub")
            .withAutomaticReconnect()
            .build();

        connection.start().catch(err => console.error("SignalR Connection Error:", err));

        // --- ACTIONS BOUTONS ---
        btnStart.onclick = async function() {
            activeVehiculeId = hiddenVehiculeId ? hiddenVehiculeId.value : vehiculeSelect.value;
            if (!activeVehiculeId) {
                alert("Veuillez sélectionner un véhicule.");
                return;
            }
            
            if(!("geolocation" in navigator)) {
                alert("GPS non supporté.");
                return;
            }

            try {
                btnStart.disabled = true;
                btnStart.innerText = "CONNEXION...";

                if (connection.state !== signalR.HubConnectionState.Connected) {
                    await connection.start();
                }

                activeTrajetId = await connection.invoke("StartTrajet", parseInt(activeVehiculeId), deviceId, "Démarrage mobile");
                
                // État actif
                isTracking = true;
                container.classList.add('is-tracking');
                subtitleText.innerText = `Trajet #${activeTrajetId} en cours...`;
                
                // Init Stats
                startTime = Date.now();
                totalDistanceKm = 0;
                lastPosition = null;
                tracePoints = [];
                
                chronoInterval = setInterval(updateChronomètre, 1000);
                watchId = navigator.geolocation.watchPosition(onPositionReceived, onPositionError, { 
                    enableHighAccuracy: true, 
                    maximumAge: 3000, 
                    timeout: 10000 
                });

            } catch(e) {
                alert("Erreur démarrage: " + e.message);
                btnStart.disabled = false;
                btnStart.innerText = "DÉMARRER LE TRAJET";
            }
        };

        btnStop.onclick = function() {
            document.getElementById('modal-time').innerText = getCurrentDurationFormatted();
            document.getElementById('modal-dist').innerText = totalDistanceKm.toFixed(2) + " km";
            stopModal.classList.add('show');
        };

        window.closeStopModal = function() {
            stopModal.classList.remove('show');
        };

        window.confirmStop = async function() {
            window.closeStopModal();
            btnStop.disabled = true;
            btnStop.innerText = "CLÔTURE...";
            await stopTrackingAndSend();
        };

        // ============================================================
        // --- SIMULATION DÉMO (Sans GPS réel) ---
        // ============================================================
        const btnDemo = document.getElementById('btn-demo');
        const demoProgressFill = document.getElementById('demo-progress-fill');

        // Demander la position GPS réelle de l'utilisateur
        function getCurrentGPS() {
            return new Promise((resolve, reject) => {
                if (!("geolocation" in navigator)) {
                    reject(new Error("GPS non supporté"));
                    return;
                }
                navigator.geolocation.getCurrentPosition(
                    pos => resolve({ lat: pos.coords.latitude, lon: pos.coords.longitude }),
                    err => reject(err),
                    { enableHighAccuracy: true, timeout: 8000, maximumAge: 0 }
                );
            });
        }

        // Générer une route de fallback (~150m) à partir d'une position réelle
        function buildFallbackRoute(startLat, startLon) {
            const deltaLat = 0.00067; // ~75m nord
            const deltaLon = 0.00090; // ~75m est
            const endLat = startLat + deltaLat;
            const endLon = startLon + deltaLon;
            const steps = 12;
            const forward = [];
            for (let i = 0; i <= steps; i++) {
                const t = i / steps;
                forward.push({
                    lat: startLat + t * (endLat - startLat),
                    lon: startLon + t * (endLon - startLon)
                });
            }
            const backward = [...forward].slice(0, -1).reverse();
            return [...forward, ...backward];
        }

        btnDemo.onclick = async function() {
            activeVehiculeId = hiddenVehiculeId ? hiddenVehiculeId.value : (vehiculeSelect ? vehiculeSelect.value : null);
            if (!activeVehiculeId) {
                // Prendre le premier véhicule dispo si aucun sélectionné
                if (vehiculeSelect && vehiculeSelect.options.length > 1) {
                    activeVehiculeId = vehiculeSelect.options[1].value;
                } else {
                    alert("Veuillez sélectionner un véhicule pour la simulation.");
                    return;
                }
            }

            btnDemo.disabled = true;
            btnDemo.innerHTML = '📍 Localisation en cours...';

            try {
                if (connection.state !== signalR.HubConnectionState.Connected) {
                    await connection.start();
                }

                // Étape 1 : Récupérer la vraie position GPS
                let myPos;
                try {
                    myPos = await getCurrentGPS();
                    statusText.innerText = `📍 Position trouvée (${myPos.lat.toFixed(4)}, ${myPos.lon.toFixed(4)})`;
                } catch(gpsErr) {
                    console.warn('GPS indisponible, fallback Bouira :', gpsErr.message);
                    myPos = { lat: 36.3736, lon: 3.8989 };
                    statusText.innerText = "⚠️ GPS indisponible — position par défaut";
                }

                btnDemo.innerHTML = '⏳ Chargement de la route...';

                // Étape 2 : Calculer la route depuis la vraie position
                let routePoints = await fetchOSRMRoute(myPos.lat, myPos.lon);
                if (!routePoints || routePoints.length < 3) {
                    // Fallback : interpolation linéaire depuis la vraie position
                    routePoints = buildFallbackRoute(myPos.lat, myPos.lon);
                    console.log('Fallback sur route interpolée depuis position réelle');
                }

                activeTrajetId = await connection.invoke("StartTrajet", parseInt(activeVehiculeId), deviceId + '-DEMO', "Simulation Démo");

                // Initialisation état
                isDemoMode = true;
                isTracking = true;
                demoRoutePoints = routePoints;
                demoPointIndex = 0;
                startTime = Date.now();
                totalDistanceKm = 0;
                lastPosition = null;
                tracePoints = [];

                container.classList.add('is-tracking', 'is-demo');
                subtitleText.innerText = `🎬 SIMULATION #${activeTrajetId} en cours...`;
                statusText.innerText = "Simulation GPS Active";
                btnDemo.innerHTML = '🎬 LANCER LA SIMULATION DÉMO';

                chronoInterval = setInterval(updateChronomètre, 1000);

                // Lancer la simulation point par point
                const DEMO_STEP_MS = 2000; // 1 point GPS toutes les 2 secondes
                const totalSteps = demoRoutePoints.length;
                const midPoint = Math.floor(totalSteps / 2); // Point de livraison
                let deliveryPauseDone = false;
                const phaseBanner = document.getElementById('demo-phase-banner');

                // Phase initiale : aller
                phaseBanner.className = 'demo-phase-banner aller';
                phaseBanner.innerText = '🚚 En route vers le client...';

                const runDemoStep = async () => {
                    if (demoPointIndex >= demoRoutePoints.length) {
                        // Fin automatique de la simulation
                        clearInterval(demoInterval);
                        demoProgressFill.style.width = '100%';
                        phaseBanner.className = 'demo-phase-banner livraison';
                        phaseBanner.innerText = '\u2705 Arriv\u00e9 \u00e0 l\u2019entrep\u00f4t \u2014 Trajet cl\u00f4tur\u00e9';
                        statusText.innerText = "Simulation termin\u00e9e !";
                        await new Promise(r => setTimeout(r, 1500));
                        btnStop.disabled = false;
                        await stopTrackingAndSend();
                        container.classList.remove('is-demo');
                        isDemoMode = false;
                        return;
                    }

                    // Pause au point de livraison (mi-parcours)
                    if (demoPointIndex === midPoint && !deliveryPauseDone) {
                        deliveryPauseDone = true;
                        clearInterval(demoInterval);
                        // Affichage : livraison en cours
                        phaseBanner.className = 'demo-phase-banner livraison';
                        phaseBanner.innerText = '\ud83d\udce6 Livraison en cours... Arr\u00eat 3s';
                        statusText.innerText = "Arr\u00eat livraison";
                        uiLiveSpeed.innerText = '0';
                        if (activeTrajetId && connection.state === signalR.HubConnectionState.Connected) {
                            const pt = demoRoutePoints[midPoint];
                            connection.invoke("UpdatePositionWithTrace", parseInt(activeVehiculeId), parseInt(activeTrajetId), pt.lat, pt.lon, 0, chronoDisplay.innerText, totalDistanceKm).catch(() => {});
                        }
                        // Pause 3 secondes puis reprise phase retour
                        await new Promise(r => setTimeout(r, 3000));
                        phaseBanner.className = 'demo-phase-banner retour';
                        phaseBanner.innerText = '\u21a9\ufe0f Retour vers l\u2019entrep\u00f4t...';
                        statusText.innerText = "Simulation GPS Active";
                        demoInterval = setInterval(runDemoStep, DEMO_STEP_MS);
                        return;
                    }

                    const pt = demoRoutePoints[demoPointIndex];
                    // Légère variation pour simuler imprécision GPS
                    const jitterLat = (Math.random() - 0.5) * 0.00002;
                    const jitterLon = (Math.random() - 0.5) * 0.00002;
                    const lat = pt.lat + jitterLat;
                    const lon = pt.lon + jitterLon;
                    const ts = Date.now();

                    // Calculer distance et vitesse
                    let speedKmh = 0;
                    if (lastPosition) {
                        const d = haversineDistance(lastPosition.lat, lastPosition.lon, lat, lon);
                        const tSec = (ts - lastPosition.sysTimestamp) / 1000;
                        if (tSec > 0 && d > 0.0001) {
                            speedKmh = Math.min((d / (tSec / 3600)), 60);
                        }
                        if (d > 0.001) {
                            totalDistanceKm += d;
                            uiLiveDistance.innerText = totalDistanceKm.toFixed(2);
                            lastPosition = { lat, lon, sysTimestamp: ts };
                        }
                    } else {
                        lastPosition = { lat, lon, sysTimestamp: ts };
                    }

                    // Vitesse simulée réaliste (30 +-10 km/h)
                    if (speedKmh < 5) speedKmh = 25 + Math.random() * 15;
                    uiLiveSpeed.innerText = speedKmh.toFixed(0);

                    // Barre de progression
                    const progress = ((demoPointIndex + 1) / totalSteps) * 100;
                    demoProgressFill.style.width = progress + '%';

                    // Envoyer aux dashboards via SignalR
                    if (activeTrajetId && connection.state === signalR.HubConnectionState.Connected) {
                        connection.invoke("UpdatePositionWithTrace", parseInt(activeVehiculeId), parseInt(activeTrajetId), lat, lon, parseFloat(speedKmh.toFixed(0)), chronoDisplay.innerText, totalDistanceKm).catch(() => {});
                    }

                    tracePoints.push({ lat, lon, timestamp: ts });
                    demoPointIndex++;

                };

                demoInterval = setInterval(runDemoStep, DEMO_STEP_MS);

            } catch(e) {
                alert('Erreur simulation : ' + e.message);
                btnDemo.disabled = false;
                btnDemo.innerHTML = '🎬 LANCER LA SIMULATION DÉMO';
            }
        };

        // Fetcher une route OSRM depuis la vraie position de l'utilisateur
        async function fetchOSRMRoute(startLat, startLon) {
            try {
                // Destination : ~150m nord-est par rapport à la position réelle
                const endLat = startLat + 0.00067;
                const endLon = startLon + 0.00090;
                const url = `https://router.project-osrm.org/route/v1/driving/${startLon},${startLat};${endLon},${endLat}?overview=full&geometries=geojson`;
                const resp = await fetch(url, { signal: AbortSignal.timeout(6000) });
                if (!resp.ok) return null;
                const data = await resp.json();
                if (!data.routes || !data.routes[0]) return null;
                const coords = data.routes[0].geometry.coordinates;
                // OSRM retourne [lon, lat], on inverse + on ajoute le retour
                const forward = coords.map(c => ({ lat: c[1], lon: c[0] }));
                const backward = [...forward].slice(0, -1).reverse();
                return [...forward, ...backward];
            } catch(e) {
                return null;
            }
        }

        // --- LOGIQUE CORE ---
        function onPositionReceived(position) {
            const lat = position.coords.latitude;
            const lon = position.coords.longitude;
            const ts = position.timestamp;
            
            const now = Date.now();
            let speedKmh = 0;
            if (position.coords.speed && position.coords.speed > 0) {
                speedKmh = (position.coords.speed * 3.6);
            } else if (lastPosition) {
                const d = haversineDistance(lastPosition.lat, lastPosition.lon, lat, lon);
                const t = (now - lastPosition.sysTimestamp) / 1000;
                if (t > 0 && d > 0.001) { // 1 mètre minimum pour la vitesse
                    speedKmh = (d / (t / 3600));
                }
            }

            if (speedKmh > 130) speedKmh = 0;
            const speedDisplay = speedKmh.toFixed(0);
            uiLiveSpeed.innerText = speedDisplay;
            statusText.innerText = "Signal GPS Optimal";

            if (lastPosition) {
                const d = haversineDistance(lastPosition.lat, lastPosition.lon, lat, lon);
                if (d > 0.001) { // 1 mètre minimum pour la distance
                    totalDistanceKm += d;
                    uiLiveDistance.innerText = totalDistanceKm.toFixed(2);
                    lastPosition = { lat, lon, timestamp: ts, sysTimestamp: now }; // On ne met à jour la référence QUE si on a bougé
                }
            } else {
                lastPosition = { lat, lon, timestamp: ts, sysTimestamp: now };
            }

            // Sync Live Server (Inclut distance)
            if (activeTrajetId && connection.state === signalR.HubConnectionState.Connected) {
                connection.invoke("UpdatePositionWithTrace", parseInt(activeVehiculeId), parseInt(activeTrajetId), lat, lon, parseFloat(speedDisplay), chronoDisplay.innerText, totalDistanceKm).catch(err => {});
            }

            // Save Trace (Historique)
            if (tracePoints.length === 0 || haversineDistance(tracePoints[tracePoints.length-1].lat, tracePoints[tracePoints.length-1].lon, lat, lon) > 0.015) {
                tracePoints.push({ lat, lon, timestamp: ts });
            }
        }

        function onPositionError(err) {
            statusText.innerText = "Perte signal GPS";
            if(navigator.vibrate) navigator.vibrate(200);
        }

        async function stopTrackingAndSend() {
            isTracking = false;
            if (watchId) navigator.geolocation.clearWatch(watchId);
            if (chronoInterval) clearInterval(chronoInterval);

            try {
                let traceJson = JSON.stringify(tracePoints);
                if (connection.state === signalR.HubConnectionState.Connected) {
                    const tid = parseInt(activeTrajetId) || 0;
                    const vid = parseInt(activeVehiculeId) || 0;
                    try {
                        await connection.invoke("EndTrajet", vid, tid, "Terminé", totalDistanceKm, traceJson);
                    } catch(e) {
                        // Secours si trace trop lourde
                        await connection.invoke("EndTrajet", vid, tid, "Terminé (Léger)", totalDistanceKm, "[]");
                    }
                }
                
                container.classList.remove('is-tracking');
                btnStop.style.display = ''; // Laisser le CSS gérer la visibilité
                subtitleText.innerText = "Trajet terminé et véhicule libéré.";
                statusText.innerText = "Disponible";
            } catch(e) {
                alert("Erreur lors de la clôture : " + e.message);
                btnStop.disabled = false;
                btnStop.innerText = "RÉESSAYER";
            }
        }

        // --- UTILITAIRES ---
        window.onbeforeunload = function() {
            if (isTracking && typeof connection !== 'undefined' && connection.state === signalR.HubConnectionState.Connected) {
                connection.stop();
            }
        };

        function updateChronomètre() {
            if(!startTime) return;
            const diff = Date.now() - startTime;
            const s = Math.floor((diff / 1000) % 60);
            const m = Math.floor((diff / 60000) % 60);
            const h = Math.floor(diff / 3600000);
            chronoDisplay.innerText = h > 0 ? (pad(h) + ":" + pad(m) + ":" + pad(s)) : (pad(m) + ":" + pad(s));
            chronoProgress.style.strokeDashoffset = 440 - ((s/60) * 440);
        }

        function pad(n) { return n < 10 ? '0'+n : n; }
        
        function getCurrentDurationFormatted() {
            if(!startTime) return "00:00:00";
            return new Date(Date.now() - startTime).toISOString().substring(11, 19);
        }

        function haversineDistance(lat1, lon1, lat2, lon2) {
            const R = 6371;
            const dLat = (lat2-lat1) * Math.PI/180;
            const dLon = (lon2-lon1) * Math.PI/180;
            const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
            return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        }
    </script>
</body>
</html>
