        async function startTripNow() {
            const vid = document.getElementById('hidden-vehicule-id')?.value
                     || document.getElementById('vehicule-select')?.value;
            if (!vid) return;

            if (connection.state !== signalR.HubConnectionState.Connected) {
                await connection.start();
            }

            try {
                activeVehiculeId = vid;
                btnStart.disabled = true;
                activeTrajetId = await connection.invoke("StartTrajet", parseInt(activeVehiculeId), deviceId, "Démarrage mobile");

                isTracking = true;
                container.classList.add('is-tracking');
                document.getElementById('subtitle-text').innerText = `Trajet #${activeTrajetId} en cours...`;

                startTime = Date.now();
                totalDistanceKm = 0;
                lastPosition = null;
                tracePoints = [];
                idleStartTime = null;
                totalIdleMs = 0;
