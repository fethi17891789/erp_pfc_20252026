        async function confirmerItineraire() {
            if (!selectedRouteType || !rpRouteData[selectedRouteType]) return;
            const route = rpRouteData[selectedRouteType];
            plannedItineraireType = route.type;

            // Cacher le planificateur, lancer le trajet
