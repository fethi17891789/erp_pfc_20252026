        function checkCalcReady() {
            document.getElementById('btn-calc').disabled = !(rpOriginCoords && rpDestCoords);
        }

        async function calculerRoutes() {
            const btn = document.getElementById('btn-calc');
            const loading = document.getElementById('rp-loading');
            const container2 = document.getElementById('rp-routes-container');
            btn.disabled = true;
            loading.style.display = 'block';
            container2.style.display = 'none';

            const veh = getVehiculeData();
            const co2ParKm = veh?.co2ParKm || 0;

            try {
                const orig = `${rpOriginCoords.lon.toFixed(6)},${rpOriginCoords.lat.toFixed(6)}`;
                const dest = `${rpDestCoords.lon.toFixed(6)},${rpDestCoords.lat.toFixed(6)}`;
                const osrmUrl = `https://router.project-osrm.org/route/v1/driving/${orig};${dest}?overview=false&alternatives=true`;

                const resp = await fetch(osrmUrl, { signal: AbortSignal.timeout(10000) });
                const data = await resp.json();

                if (!data.routes || data.routes.length === 0) throw new Error('Aucun itinéraire trouvé.');

                const routes = data.routes;
                const r1 = routes[0];
                const r1Dist = r1.distance / 1000;
                const r1Time = Math.round(r1.duration / 60);
                const r1Co2 = co2ParKm > 0 ? Math.round(r1Dist * co2ParKm) : 0;

                // Route 2 : alternative OSRM ou synthétique (+8% dist, +15% temps, -8% CO2 via voies locales)
                let r2Dist, r2Time, r2Co2, r2Note = '', r2Synthetic = false;
                if (routes.length >= 2) {
                    r2Dist = routes[1].distance / 1000;
                    r2Time = Math.round(routes[1].duration / 60);
                    r2Co2 = co2ParKm > 0 ? Math.round(r2Dist * co2ParKm * 0.94) : 0; // voies locales ~6% moins
                } else {
                    // Pas d'alternative OSRM → itinéraire synthétique "voies locales"
                    r2Dist = Math.round(r1Dist * 1.08 * 10) / 10;
                    r2Time = Math.round(r1Time * 1.18);
                    r2Co2 = co2ParKm > 0 ? Math.round(r2Dist * co2ParKm * 0.9) : 0;
                    r2Note = 'Estimé — évite les grands axes';
                    r2Synthetic = true;
                }

                rpRouteData = {
                    fast: { dist: r1Dist, time: r1Time, co2: r1Co2, type: 'Rapide' },
                    eco:  { dist: r2Dist, time: r2Time, co2: r2Co2, note: r2Note, type: 'Ecologique' }
                };

                // Afficher Route Rapide
                document.getElementById('fast-dist').innerText = r1Dist.toFixed(1);
                document.getElementById('fast-time').innerText = r1Time;
                document.getElementById('fast-co2').innerText = r1Co2 > 0 ? `~${(r1Co2/1000).toFixed(2)} kg CO2` : 'CO2 N/A';
                document.getElementById('fast-note').innerText = '';

                // Afficher Route Écologique
                document.getElementById('eco-dist').innerText = r2Dist.toFixed(1);
                document.getElementById('eco-time').innerText = r2Time;
                document.getElementById('eco-co2').innerText = r2Co2 > 0 ? `~${(r2Co2/1000).toFixed(2)} kg CO2` : 'CO2 N/A';
                document.getElementById('eco-note').innerText = r2Note;

                const saving = document.getElementById('eco-saving');
                if (r1Co2 > 0 && r2Co2 > 0 && r2Co2 < r1Co2) {
                    const pct = Math.round((r1Co2 - r2Co2) / r1Co2 * 100);
                    saving.innerText = `${pct}% moins de CO2 que l'itinéraire rapide`;
                    saving.style.display = 'inline-block';
                } else {
                    saving.style.display = 'none';
                }

                // Reset sélection
                selectedRouteType = null;
                document.getElementById('card-fast').className = 'route-card';
                document.getElementById('card-eco').className = 'route-card';
                document.getElementById('btn-confirm-route').disabled = true;

                container2.style.display = 'block';
            } catch(e) {
                document.getElementById('dest-status').innerText = 'Erreur calcul : ' + e.message;
                document.getElementById('dest-status').style.color = '#ef4444';
            } finally {
                loading.style.display = 'none';
                btn.disabled = !(rpOriginCoords && rpDestCoords);
            }
        }

        function selectRoute(type) {
            selectedRouteType = type;
            document.getElementById('card-fast').className = 'route-card' + (type === 'fast' ? ' selected-fast' : '');
            document.getElementById('card-eco').className  = 'route-card' + (type === 'eco'  ? ' selected-eco'  : '');
