            planningMode = true;
            container.classList.add('is-planning');
            document.getElementById('btn-plan').style.display = 'none';
            selectedRouteType = null;
            rpOriginCoords = null;
            rpDestCoords = null;
            rpRouteData = {};
            document.getElementById('rp-routes-container').style.display = 'none';
            document.getElementById('btn-confirm-route').disabled = true;
            document.getElementById('btn-calc').disabled = true;
            document.getElementById('origin-label').innerText = 'Utiliser ma position GPS';
            document.getElementById('rp-dest-input').value = '';
            document.getElementById('dest-status').innerText = '';
