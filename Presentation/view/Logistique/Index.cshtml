@page
@model erp_pfc_20252026.Pages.Logistique.IndexModel
@{
    ViewData["Title"] = "Logistique - Dashboard";
}
    
@section Styles {
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="~/lib/leaflet/leaflet.min.css" asp-append-version="true" />

    <style>
    :root {
        --map-height: calc(100vh - 220px);
    }

    /* Override Leaflet for Dark Theme compatibility */
    .leaflet-container {
        background: #0a0c1a !important;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }

    .leaflet-tile-container {
        filter: invert(100%) hue-rotate(180deg) brightness(95%) contrast(90%);
    }

    /* Custom Scrollbar for Vehicle List */
    .vehicle-list-scroll::-webkit-scrollbar {
        width: 4px;
    }
    .vehicle-list-scroll::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.02);
    }
    .vehicle-list-scroll::-webkit-scrollbar-thumb {
        background: var(--accent);
        border-radius: 10px;
    }

    .vehicle-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 14px;
        padding: 12px;
        margin-bottom: 10px;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    .vehicle-card:hover {
        background: rgba(123, 94, 255, 0.08);
        border-color: rgba(123, 94, 255, 0.3);
        transform: translateX(4px);
    }

    .vehicle-card.active {
        background: rgba(123, 94, 255, 0.12);
        border-color: var(--accent);
        box-shadow: 0 0 20px rgba(123, 94, 255, 0.2);
    }

    .status-badge {
        font-size: 0.65rem;
        padding: 2px 8px;
        border-radius: 999px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .status-online { color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3); background: rgba(34, 197, 94, 0.1); }
    .status-offline { color: var(--text-muted-2); border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(255, 255, 255, 0.05); }

    .pulse-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
        animation: pulse 1.5s infinite;
    }

    @@keyframes pulse {
        0% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.5); opacity: 0.5; }
        100% { transform: scale(1); opacity: 1; }
    }

    .map-controls {
        position: absolute;
        bottom: 25px;
        right: 25px;
        z-index: 1000;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    /* Panneau de stats live sur la carte */
    .live-stats-panel {
        position: absolute;
        top: 20px;
        left: 20px;
        z-index: 1001;
        background: rgba(15, 20, 50, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(123, 94, 255, 0.4);
        border-radius: 16px;
        padding: 15px;
        color: white;
        min-width: 200px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        display: none; /* Caché par défaut */
        animation: slideIn 0.3s ease-out;
    }

    .history-section {
        margin-top: 25px;
        background: rgba(255,255,255,0.03);
        border-radius: 20px;
        padding: 20px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .history-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

    .history-table th {
        text-align: left;
        color: var(--text-muted);
        font-size: 0.75rem;
        text-transform: uppercase;
        padding: 10px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .history-table td {
        padding: 12px 10px;
        font-size: 0.85rem;
        border-bottom: 1px solid rgba(255,255,255,0.02);
    }

    .history-row:hover {
        background: rgba(123, 94, 255, 0.1);
        cursor: pointer;
    }

    /* Magie CSS : Transforme la carte claire OpenStreetMap en carte Dark Mode détaillée ! */
    .map-tiles {
        filter: invert(100%) hue-rotate(180deg) brightness(105%) contrast(90%);
    }

    /* ── Marqueurs véhicules ─────────────────────────────────────── */
    .custom-vehicle-marker { background: none !important; border: none !important; }

    .vehicle-marker-active {
        position: relative; width: 28px; height: 28px;
        display: flex; align-items: center; justify-content: center;
    }
    .vehicle-marker-pulse {
        position: absolute; width: 28px; height: 28px;
        border-radius: 50%; background: rgba(34, 197, 94, 0.35);
        animation: markerPulse 1.8s ease-out infinite;
    }
    .vehicle-marker-dot {
        width: 16px; height: 16px; border-radius: 50%;
        background: #22c55e; border: 3px solid white;
        box-shadow: 0 0 12px rgba(34, 197, 94, 0.7);
        position: relative; z-index: 1;
    }
    @@keyframes markerPulse {
        0%   { transform: scale(1); opacity: 0.8; }
        100% { transform: scale(2.6); opacity: 0; }
    }

    /* ── Tooltip véhicule premium ────────────────────────────────── */
    .vehicle-label-tooltip {
        background: rgba(8, 10, 26, 0.95) !important;
        border: 1px solid rgba(123, 94, 255, 0.65) !important;
        border-radius: 12px !important;
        color: white !important;
        padding: 8px 14px !important;
        font-family: 'Plus Jakarta Sans', sans-serif !important;
        font-size: 0.82rem !important;
        font-weight: 600 !important;
        box-shadow: 0 8px 28px rgba(0,0,0,0.6), 0 0 0 1px rgba(123,94,255,0.15) !important;
        white-space: nowrap !important;
    }
    .vehicle-label-tooltip.leaflet-tooltip-top::before {
        border-top-color: rgba(123, 94, 255, 0.65) !important;
    }
    .vehicle-label-tooltip.leaflet-tooltip-bottom::before {
        border-bottom-color: rgba(123, 94, 255, 0.65) !important;
    }
    </style>
}

@section HeaderLeft {
    <div style="display:flex; align-items:center; gap:20px;">
        <div>
            <h1>Logistique & Flotte</h1>
            <p>Suivi en temps réel et gestion des transports.</p>
        </div>
        <a asp-page="/Settings/MobileAccess" class="btn-secondary" style="display:flex; align-items:center; gap:8px; text-decoration:none; padding:8px 16px; border-radius:12px;">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7z"></path>
                <circle cx="12" cy="9" r="3"></circle>
            </svg>
            Accès Extérieur
        </a>
    </div>
}

        <section class="erp-content" style="padding: 20px;">
            <div style="display: grid; grid-template-columns: 320px 1fr; gap: 20px; height: var(--map-height);">
                
                <!-- COLONNE GAUCHE : LISTE -->
                <div style="display: flex; flex-direction: column; gap: 15px; min-height: 0;">
                    <!-- Barre de recherche -->
                    <div class="chat-search-wrapper" style="position:relative;">
                        <input type="text" placeholder="Rechercher un véhicule..." 
                               oninput="filterVehicles(this.value)"
                               style="width:100%; height:42px; padding:0 40px 0 12px; border-radius:12px; border:1px solid rgba(255,255,255,0.08); background:rgba(10,14,40,0.6); color:white; font-size:0.85rem;" />
                        <svg style="position:absolute; right:12px; top:50%; transform:translateY(-50%); width:16px; height:16px; opacity:0.5; color:var(--accent-light);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                    </div>

                    <!-- Bouton Ajouter (Déplacé ici) -->
                    <button class="module-action" style="width:100%; justify-content:center; height:40px; margin-bottom:5px;" onclick="openAddVehicule()">
                        <svg style="width:16px; height:16px; margin-right:8px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        <span>Ajouter un véhicule</span>
                    </button>

                    <div class="vehicle-list-scroll" style="flex:1; overflow-y:auto; padding-right:5px;">
                        @if (Model.Vehicules != null && Model.Vehicules.Any())
                        {
                            foreach (var v in Model.Vehicules)
                            {
                                var isOnline = v.Statut == "En Trajet";
                                <div class="vehicle-card @(isOnline ? "active" : "")" data-vehicule-id="@v.Id"
                                     data-nom="@v.Nom" data-matricule="@v.Matricule"
                                     data-marque="@v.Marque" data-modele="@v.Modele"
                                     data-annee="@v.Annee" data-carburant="@v.TypeCarburant"
                                     data-type="@v.TypeTransport"
                                     onclick="focusVehicule(@v.Id, @(v.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"), @(v.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"))">
                                    <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:8px;">
                                        <div>
                                            <h4 style="margin:0; font-size:0.95rem; font-weight:700;">@v.Nom</h4>
                                            <code style="font-size:0.7rem; color:var(--text-muted-2);">@v.Matricule</code>
                                        </div>
                                        <div class="status-badge @(isOnline ? "status-online" : "status-offline")">
                                            @if(isOnline) { <span class="pulse-dot"></span> }
                                            @(isOnline ? "En route" : "Disponible")
                                        </div>
                                    </div>
                                    <div style="font-size:0.75rem; color:var(--text-muted); display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
                                        <span style="display:inline-flex; align-items:center; gap:4px;">
                                            <svg style="width:12px;height:12px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                                            @v.TypeTransport
                                        </span>
                                        @if(!string.IsNullOrEmpty(v.TypeCarburant)) {
                                            var co2Color = v.EmissionCO2ParKm <= 50 ? "#22c55e" : v.EmissionCO2ParKm <= 130 ? "#eab308" : "#ef4444";
                                            <span style="color:@co2Color; font-size:0.65rem; background:rgba(255,255,255,0.05); padding:1px 6px; border-radius:999px; display:inline-flex; align-items:center; gap:3px;">
                                                <svg style="width:10px;height:10px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm0 6v6m0 2v2"/></svg>
                                                @v.TypeCarburant @(v.EmissionCO2ParKm.HasValue ? $"· {v.EmissionCO2ParKm:F0} g/km" : "")
                                            </span>
                                        }
                                        @if(v.Latitude.HasValue) {
                                            <span style="color:var(--accent-light); display:inline-flex; align-items:center; gap:3px;">
                                                <svg style="width:11px;height:11px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7z"/><circle cx="12" cy="9" r="3"/></svg>
                                                @v.Latitude.Value.ToString("F4"), @v.Longitude.Value.ToString("F4")
                                            </span>
                                        }
                                        <div style="margin-left:auto; display:flex; gap:5px;">
                                            <button type="button" title="Modifier" style="padding:5px 7px; font-size:0.65rem; background:rgba(123,94,255,0.12); border:1px solid rgba(123,94,255,0.25); border-radius:8px; color:var(--accent-light); cursor:pointer; display:flex; align-items:center; gap:4px;"
                                                    onclick="event.stopPropagation(); openEditVehicule(this.closest('.vehicle-card'))">
                                                <svg style="width:11px;height:11px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                Modifier
                                            </button>
                                            <button type="button" title="Reset" style="padding:5px 7px; font-size:0.65rem; background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.25); border-radius:8px; color:#f87171; cursor:pointer; display:flex; align-items:center; gap:4px;"
                                                    onclick="event.stopPropagation(); forceResetVehicule(@v.Id)">
                                                <svg style="width:11px;height:11px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3"/></svg>
                                                Reset
                                            </button>
                                            <button type="button" title="QR Code" style="padding:5px 7px; font-size:0.65rem; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); border-radius:8px; color:white; cursor:pointer; display:flex; align-items:center; gap:4px;"
                                                    onclick="event.stopPropagation(); showQrCode('@v.Id', '@Html.Raw(v.Nom.Replace("'", "\\'"))')">
                                                <svg style="width:11px;height:11px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="3" height="3"/></svg>
                                                QR
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div style="text-align:center; padding:40px 10px; color:var(--text-muted-2); font-size:0.85rem;">
                                <p>Aucun véhicule enregistré.</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- COLONNE DROITE : CARTE -->
                <div style="position: relative; border-radius: 24px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05);">
                    <div id="map" style="height: 100%; width: 100%;"></div>
                    
                    <!-- Panneau de Stats Live (Uniquement sur sélection) -->
                    <div id="live-stats-panel" class="live-stats-panel" style="min-width:240px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                            <h5 id="live-stat-name" style="margin:0; font-size:1rem; color:var(--accent-light);">Véhicule</h5>
                            <button onclick="closeLiveStats()" style="background:none; border:none; color:white; cursor:pointer; opacity:0.5;">✕</button>
                        </div>
                        <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:8px; margin-bottom:10px;">
                            <div style="background:rgba(255,255,255,0.05); padding:10px; border-radius:10px; text-align:center;">
                                <div style="font-size:0.65rem; color:var(--text-muted);">Vitesse</div>
                                <div id="live-stat-speed" style="font-size:1rem; font-weight:700;">0 km/h</div>
                            </div>
                            <div style="background:rgba(255,255,255,0.05); padding:10px; border-radius:10px; text-align:center;">
                                <div style="font-size:0.65rem; color:var(--text-muted);">Distance</div>
                                <div id="live-stat-distance" style="font-size:1rem; font-weight:700;">0.00 km</div>
                            </div>
                            <div style="background:rgba(255,255,255,0.05); padding:10px; border-radius:10px; text-align:center;">
                                <div style="font-size:0.65rem; color:var(--text-muted);">Temps</div>
                                <div id="live-stat-duration" style="font-size:1rem; font-weight:700;">00:00</div>
                            </div>
                        </div>

                        <!-- Jauge CO2 -->
                        <div id="co2-panel" style="background:rgba(255,255,255,0.04); border-radius:10px; padding:10px; margin-bottom:8px;">
                            <div style="display:flex; justify-content:space-between; margin-bottom:6px;">
                                <span style="font-size:0.68rem; color:var(--text-muted); display:inline-flex; align-items:center; gap:4px;">
                                    <svg style="width:12px;height:12px;color:#22c55e;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 0 1 0 20c-4 0-7.4-2.4-9-6"/><path d="M12 8v4l3 3"/><path d="M2 12C2 7 6 3 11 2"/></svg>
                                    CO2 Émis
                                </span>
                                <span id="live-co2-value" style="font-size:0.8rem; font-weight:700; color:#22c55e;">0 g</span>
                            </div>
                            <div style="height:6px; background:rgba(255,255,255,0.08); border-radius:999px; overflow:hidden;">
                                <div id="co2-gauge-bar" style="height:100%; width:0%; background:linear-gradient(90deg,#22c55e,#eab308); border-radius:999px; transition:width 0.8s ease, background 0.8s ease;"></div>
                            </div>
                            <div style="display:flex; justify-content:space-between; margin-top:3px;">
                                <span style="font-size:0.6rem; color:#22c55e;">Vert</span>
                                <span style="font-size:0.6rem; color:#eab308;">3 kg</span>
                                <span style="font-size:0.6rem; color:#ef4444;">8 kg</span>
                            </div>
                        </div>

                        <!-- Recommandation RSE -->
                        <div id="rse-reco-panel" style="display:none; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); border-radius:10px; padding:10px;">
                            <div style="font-size:0.7rem; color:#f87171; font-weight:600; margin-bottom:4px; display:flex; align-items:center; gap:5px;">
                                <svg style="width:13px;height:13px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                Seuil CO2 dépassé
                            </div>
                            <div id="rse-reco-text" style="font-size:0.68rem; color:var(--text-muted); line-height:1.4;"></div>
                        </div>
                    </div>

                    <div class="map-controls">
                        <a href="/Logistique/Environnement" class="header-btn" title="Dashboard RSE" style="padding:10px; border-radius:12px; text-decoration:none; display:flex; align-items:center; justify-content:center;">
                            <svg style="width:18px;height:18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
                        </a>
                        <button class="header-btn" title="Effacer les tracés" style="padding:10px; border-radius:12px;" onclick="resetMapLayers()">
                            <svg style="width:18px;height:18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3"/></svg>
                        </button>
                    </div>

                </div>
            </div>

            <!-- SECTION HISTORIQUE -->
            <div class="history-section">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <h3 style="margin:0; font-size:1.2rem;">Historique Récent des Trajets</h3>
                    <button class="btn-secondary" onclick="refreshHistory()" style="font-size: 0.75rem; padding: 6px 12px;">Actualiser</button>
                </div>
                <div id="history-container">
                    <table class="history-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Véhicule</th>
                                <th>Départ</th>
                                <th>Arrivée</th>
                                <th>Distance</th>
                                <th>CO2</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="history-tbody">
                            <!-- Rempli en JS -->
                            <tr>
                                <td colspan="6" style="text-align:center; padding:20px; color:var(--text-muted);">Chargement de l'historique...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>


<!-- MODAL : AJOUTER / MODIFIER VÉHICULE -->
<div id="add-vehicule-modal" class="logout-overlay" style="display:none; z-index:9999;">
    <div class="logout-modal" style="max-width: 520px;">
        <!-- En-tête dynamique -->
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:6px;">
            <div id="modal-icon-add" style="width:40px;height:40px;border-radius:12px;background:rgba(34,197,94,0.12);border:1px solid rgba(34,197,94,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg style="width:20px;height:20px;color:#22c55e;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </div>
            <div id="modal-icon-edit" style="width:40px;height:40px;border-radius:12px;background:rgba(123,94,255,0.12);border:1px solid rgba(123,94,255,0.25);display:none;align-items:center;justify-content:center;flex-shrink:0;">
                <svg style="width:18px;height:18px;color:var(--accent-light);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </div>
            <div>
                <h3 id="modal-title" style="margin:0;">Ajouter un nouveau véhicule</h3>
                <p id="modal-subtitle" style="margin:0; font-size:0.82rem; color:var(--text-muted);">Renseignez les informations pour intégrer le véhicule à la flotte.</p>
            </div>
        </div>

        <!-- Formulaire unique (action change dynamiquement) -->
        <form id="vehicule-form" method="post" asp-page-handler="AddVehicule" class="logout-modal-actions" style="flex-direction:column; gap:14px; align-items:stretch; margin-top:20px;">
            <input type="hidden" id="edit-vehicule-id" name="id" value="" />

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                <div class="form-group">
                    <label style="font-size:0.8rem; color:var(--text-muted); margin-bottom:4px; display:block;">Nom du véhicule *</label>
                    <input id="f-nom" name="nom" type="text" placeholder="Ex: Camion Livraison A" required
                           style="width:100%; height:40px; padding:0 14px; border-radius:12px; border:1px solid rgba(255,255,255,0.08); background:rgba(10,14,40,0.6); color:white; font-size:0.85rem;" />
                </div>
                <div class="form-group">
                    <label style="font-size:0.8rem; color:var(--text-muted); margin-bottom:4px; display:block;">Plaque *</label>
                    <input id="f-matricule" name="matricule" type="text" placeholder="Ex: 12345-113-16" required
                           style="width:100%; height:40px; padding:0 14px; border-radius:12px; border:1px solid rgba(255,255,255,0.08); background:rgba(10,14,40,0.6); color:white; font-size:0.85rem;" />
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                <div class="form-group">
                    <label style="font-size:0.8rem; color:var(--text-muted); margin-bottom:4px; display:block;">Marque</label>
                    <input id="f-marque" name="marque" type="text" placeholder="Ex: Renault, Mercedes..."
                           style="width:100%; height:40px; padding:0 14px; border-radius:12px; border:1px solid rgba(255,255,255,0.08); background:rgba(10,14,40,0.6); color:white; font-size:0.85rem;" />
                </div>
                <div class="form-group">
                    <label style="font-size:0.8rem; color:var(--text-muted); margin-bottom:4px; display:block;">Modèle</label>
                    <input id="f-modele" name="modele" type="text" placeholder="Ex: Master, Sprinter..."
                           style="width:100%; height:40px; padding:0 14px; border-radius:12px; border:1px solid rgba(255,255,255,0.08); background:rgba(10,14,40,0.6); color:white; font-size:0.85rem;" />
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px;">
                <div class="form-group">
                    <label style="font-size:0.8rem; color:var(--text-muted); margin-bottom:4px; display:block;">Année</label>
                    <input id="f-annee" name="annee" type="number" min="1980" max="2030" placeholder="Ex: 2022"
                           style="width:100%; height:40px; padding:0 14px; border-radius:12px; border:1px solid rgba(255,255,255,0.08); background:rgba(10,14,40,0.6); color:white; font-size:0.85rem;" />
                </div>
                <div class="form-group">
                    <label style="font-size:0.8rem; color:var(--text-muted); margin-bottom:4px; display:block;">Carburant</label>
                    <select id="f-carburant" name="carburant" style="width:100%; height:40px; padding:0 14px; border-radius:12px; border:1px solid rgba(255,255,255,0.08); background:rgba(10,14,40,0.6); color:white; cursor:pointer; font-size:0.85rem;">
                        <option value="">-- Choisir --</option>
                        <option value="Essence">Essence</option>
                        <option value="Diesel">Diesel</option>
                        <option value="Hybride">Hybride</option>
                        <option value="Hybride Rechargeable">Hybride Rechargeable</option>
                        <option value="Électrique">Électrique</option>
                        <option value="GNV">GNV</option>
                    </select>
                </div>
                <div class="form-group">
                    <label style="font-size:0.8rem; color:var(--text-muted); margin-bottom:4px; display:block;">Type *</label>
                    <select id="f-type" name="type" style="width:100%; height:40px; padding:0 14px; border-radius:12px; border:1px solid rgba(255,255,255,0.08); background:rgba(10,14,40,0.6); color:white; cursor:pointer; font-size:0.85rem;">
                        <option value="Camion">Camion</option>
                        <option value="Fourgonnette">Fourgonnette</option>
                        <option value="Moto">Moto</option>
                        <option value="Drone">Drone</option>
                    </select>
                </div>
            </div>

            <div style="background:rgba(123,94,255,0.08); border:1px solid rgba(123,94,255,0.2); border-radius:10px; padding:10px 14px; display:flex; gap:10px; align-items:center;">
                <svg style="width:16px; height:16px; color:var(--accent-light); flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <span id="modal-ia-note" style="font-size:0.75rem; color:var(--text-muted);">L'empreinte carbone (g CO2/km) sera estimée automatiquement par IA lors de la création.</span>
            </div>

            <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:4px;">
                <button type="button" class="btn-secondary"
                        onclick="closeVehiculeModal()"
                        style="padding: 10px 24px; border-radius: 999px; cursor: pointer; font-weight: 600;">
                    Annuler
                </button>
                <button id="modal-submit-btn" type="submit" class="btn-primary"
                        style="padding: 10px 24px; border-radius: 999px; cursor: pointer; font-weight: 600; border: none;">
                    Enregistrer le véhicule
                </button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL : QR CODE TRACKER -->
<div id="qr-code-modal" class="logout-overlay" style="display:none; z-index:10000;">
    <div class="logout-modal" style="max-width: 400px; text-align:center;">
        <h3 id="qr-vehicule-name">Véhicule</h3>
        <p style="margin-bottom:20px;">Scannez ce QR Code avec le téléphone du chauffeur pour démarrer le tracking instantanément.</p>

        <div id="qrcode-container" style="background:white; padding:16px; border-radius:12px; display:inline-block; margin-bottom:24px;"></div>

        <div style="display:flex; justify-content:center; gap: 10px;">
            <button type="button" class="btn-secondary" 
                    onclick="document.getElementById('qr-code-modal').style.display='none'"
                    style="margin-top: 0;">
                Fermer
            </button>
            <button type="button" class="btn-primary" 
                    onclick="downloadQrPdf()"
                    style="margin-top: 0;">
                <svg style="width:16px; height:16px; margin-right:8px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Télécharger en PDF
            </button>
        </div>
    </div>
</div>

@section Scripts {
<!-- Scripts -->
<script src="~/lib/leaflet/leaflet.min.js" asp-append-version="true"></script>
<script src="~/lib/signalr/signalr.min.js" asp-append-version="true"></script>
<script src="~/lib/qrcode/qrcode.min.js" asp-append-version="true"></script>
<script src="~/lib/jspdf/jspdf.umd.min.js" asp-append-version="true"></script>

<script>
    // ── Gestion modale véhicule (Ajout / Modification) ────────────────
    function openAddVehicule() {
        const form = document.getElementById('vehicule-form');
        form.setAttribute('action', form.getAttribute('action').replace('UpdateVehicule', 'AddVehicule'));
        form.setAttribute('asp-page-handler', 'AddVehicule');
        // Reset champs
        document.getElementById('edit-vehicule-id').value = '';
        document.getElementById('f-nom').value = '';
        document.getElementById('f-matricule').value = '';
        document.getElementById('f-marque').value = '';
        document.getElementById('f-modele').value = '';
        document.getElementById('f-annee').value = '';
        document.getElementById('f-carburant').value = '';
        document.getElementById('f-type').value = 'Camion';
        // UI mode Ajout
        document.getElementById('modal-icon-add').style.display = 'flex';
        document.getElementById('modal-icon-edit').style.display = 'none';
        document.getElementById('modal-title').innerText = 'Ajouter un nouveau véhicule';
        document.getElementById('modal-subtitle').innerText = 'Renseignez les informations pour intégrer le véhicule à la flotte.';
        document.getElementById('modal-submit-btn').innerText = 'Enregistrer le véhicule';
        document.getElementById('modal-ia-note').innerText = "L'empreinte carbone (g CO2/km) sera estimée automatiquement par IA lors de la création.";
        document.getElementById('add-vehicule-modal').style.display = 'flex';
    }

    function openEditVehicule(card) {
        const id       = card.dataset.vehiculeId;
        const nom      = card.dataset.nom      || '';
        const matricule= card.dataset.matricule|| '';
        const marque   = card.dataset.marque   || '';
        const modele   = card.dataset.modele   || '';
        const annee    = card.dataset.annee    || '';
        const carburant= card.dataset.carburant|| '';
        const type     = card.dataset.type     || 'Camion';

        // Remplir les champs
        document.getElementById('edit-vehicule-id').value  = id;
        document.getElementById('f-nom').value             = nom;
        document.getElementById('f-matricule').value       = matricule;
        document.getElementById('f-marque').value          = marque;
        document.getElementById('f-modele').value          = modele;
        document.getElementById('f-annee').value           = annee;
        document.getElementById('f-carburant').value       = carburant;
        document.getElementById('f-type').value            = type;

        // Changer l'action du formulaire vers UpdateVehicule
        const form = document.getElementById('vehicule-form');
        // On remplace l'attribut action directement via la valeur action du formulaire (Razor l'a déjà compilé)
        // On met à jour juste le champ caché "id" et on change le handler avec un attribut data
        form.dataset.mode = 'edit';

        // UI mode Modification
        document.getElementById('modal-icon-add').style.display = 'none';
        document.getElementById('modal-icon-edit').style.display = 'flex';
        document.getElementById('modal-title').innerText = `Modifier — ${nom}`;
        document.getElementById('modal-subtitle').innerText = `Plaque : ${matricule}  ·  ID : #${id}`;
        document.getElementById('modal-submit-btn').innerText = 'Enregistrer les modifications';
        document.getElementById('modal-ia-note').innerText = "L'empreinte CO2 sera recalculée automatiquement après la modification.";
        document.getElementById('add-vehicule-modal').style.display = 'flex';
    }

    function closeVehiculeModal() {
        document.getElementById('add-vehicule-modal').style.display = 'none';
        // Remettre le formulaire en mode Ajout pour la prochaine ouverture via le bouton "+"
        document.getElementById('vehicule-form').dataset.mode = 'add';
    }

    // Bouton Ajouter (dans la barre latérale) → mode Ajout 
    document.querySelector('[onclick*="add-vehicule-modal"]')?.setAttribute('onclick', 'openAddVehicule()');

    function showQrCode(vehiculeId, vehiculeName) {
        document.getElementById('qr-vehicule-name').innerText = "QR Code : " + vehiculeName;
        
        // Nettoyer l'ancien QR code s'il existe
        const container = document.getElementById('qrcode-container');
        container.innerHTML = "";
        
        // Construire l'URL (en utilisant l'origine actuelle)
        const baseUrl = window.location.origin;
        const trackingUrl = baseUrl + "/Logistique/Tracking?vehiculeId=" + vehiculeId + "&v=" + Date.now();
        
        // Générer le nouveau QR code
        new QRCode(container, {
            text: trackingUrl,
            width: 200,
            height: 200,
            colorDark : "#000000",
            colorLight : "#ffffff",
            correctLevel : QRCode.CorrectLevel.H
        });
        
        // Afficher la modale
        document.getElementById('qr-code-modal').style.display = 'flex';
    }

    function downloadQrPdf() {
        const qrContainer = document.getElementById('qrcode-container');
        const vehiculeName = document.getElementById('qr-vehicule-name').innerText.replace("QR Code : ", "");
        
        // Grab image data from canvas or img reliably
        let imgData = null;
        const canvas = qrContainer.querySelector('canvas');
        if (canvas) {
            imgData = canvas.toDataURL('image/png');
        } else {
            const img = qrContainer.querySelector('img');
            if (img && img.src) imgData = img.src;
        }

        if(!imgData) {
            alert("Erreur: Le QR code n'a pas encore été généré.");
            return;
        }

        const { jsPDF } = window.jspdf;
        const doc = new jsPDF();

        // 1. Titre (Gros, Gras, Mauve)
        doc.setFont("helvetica", "bold");
        doc.setFontSize(26);
        doc.setTextColor(123, 94, 255); // --accent: #7B5EFF
        doc.text("SCANNER POUR TRACKING", 105, 40, { align: 'center' });
        
        // 2. Nom du Véhicule (Gris foncé)
        doc.setFontSize(18);
        doc.setTextColor(60, 60, 60);
        doc.text(vehiculeName.toUpperCase(), 105, 52, { align: 'center' });

        // 3. Ligne de séparation
        doc.setDrawColor(230, 230, 230);
        doc.setLineWidth(0.5);
        doc.line(30, 62, 180, 62);

        // 4. Instructions
        doc.setFont("helvetica", "normal");
        doc.setFontSize(12);
        doc.setTextColor(100, 100, 100);
        doc.text("Scannez ce QR Code avec votre téléphone pour envoyer", 105, 75, { align: 'center' });
        doc.text("instantanément votre position au centre de logistique.", 105, 82, { align: 'center' });

        // 5. AJOUT DE L'IMAGE (QR CODE)
        // doc.addImage(imgData, format, x, y, width, height)
        doc.addImage(imgData, 'PNG', 55, 95, 100, 100);

        // 6. Cadre pour le QR
        doc.setDrawColor(123, 94, 255);
        doc.setLineWidth(1);
        doc.roundedRect(53, 93, 104, 104, 5, 5, 'D');

        // 7. Footer
        doc.setFontSize(9);
        doc.setTextColor(160, 160, 160);
        doc.text("Document généré par l'ERP Suite - Module Logistique", 105, 230, { align: 'center' });
        doc.text("Date de génération : " + new Date().toLocaleString('fr-FR'), 105, 236, { align: 'center' });

        // 8. Sauvegarde
        const fileName = vehiculeName.replace(/[^a-z0-9]/gi, '_').toLowerCase() + '_qr_code.pdf';
        doc.save(fileName);
    }

    var map = L.map('map').setView([46.603354, 1.888334], 6);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors',
        className: 'map-tiles'
    }).addTo(map);

    var markers = {};

    // Icône premium pour les marqueurs (pulsating dot)
    function makeVehicleIcon(isActive) {
        const dotColor = isActive ? '#22c55e' : '#7b5eff';
        const pulseColor = isActive ? 'rgba(34, 197, 94, 0.35)' : 'rgba(123, 94, 255, 0.25)';
        const pulseHtml = isActive ? `<div class="vehicle-marker-pulse" style="background:${pulseColor}"></div>` : '';
        return L.divIcon({
            className: 'custom-vehicle-marker',
            iconSize: [28, 28],
            iconAnchor: [14, 14],
            tooltipAnchor: [0, -18],
            html: `<div class="vehicle-marker-active">${pulseHtml}<div class="vehicle-marker-dot" style="background:${dotColor}; box-shadow:0 0 12px ${dotColor}80"></div></div>`
        });
    }

    // Fermer tous les tooltips ouverts sauf celui cliqué
    var currentOpenTooltipId = null;
    function closeAllTooltips(exceptId) {
        Object.keys(markers).forEach(vid => {
            if (vid != exceptId && markers[vid].isTooltipOpen()) {
                markers[vid].closeTooltip();
            }
        });
    }

    function addOrUpdateMarker(vehiculeId, lat, lon, label, extraStats) {
        let displayLabel = label || "Véhicule #" + vehiculeId;
        if (extraStats && extraStats.distance !== undefined) {
            displayLabel = `<strong>${label}</strong><br/>🏁 ${extraStats.distance.toFixed(2)} km`;
        }

        const isActive = !!extraStats;

        if (markers[vehiculeId]) {
            markers[vehiculeId].setLatLng([lat, lon]);
            markers[vehiculeId].setIcon(makeVehicleIcon(isActive));
            if (markers[vehiculeId].getTooltip()) {
                markers[vehiculeId].setTooltipContent(displayLabel);
            } else {
                markers[vehiculeId].bindTooltip(displayLabel, { permanent: false, direction: 'top', className: 'vehicle-label-tooltip', interactive: true });
            }
        } else {
            markers[vehiculeId] = L.marker([lat, lon], { icon: makeVehicleIcon(isActive) }).addTo(map)
                .bindTooltip(displayLabel, { permanent: false, direction: 'top', className: 'vehicle-label-tooltip', interactive: true });

            // Clic sur marqueur: ouvrir tooltip uniquement celui-ci
            markers[vehiculeId].on('click', function() {
                closeAllTooltips(vehiculeId);
                this.openTooltip();
                currentOpenTooltipId = vehiculeId;
            });
        }

        // MAJ du panneau Live Stats si c'est le véhicule sélectionné
        if (selectedVehiculeId == vehiculeId && extraStats) {
            document.getElementById('live-stats-panel').style.display = 'block';
            document.getElementById('live-stat-speed').innerText = extraStats.speed + " km/h";
            document.getElementById('live-stat-duration').innerText = extraStats.duration;
            if (extraStats.distance !== undefined) {
                document.getElementById('live-stat-distance').innerText = extraStats.distance.toFixed(2) + " km";
            }
            
            // Animation pulse sur le panneau
            document.getElementById('live-stats-panel').style.borderColor = 'rgba(34, 197, 94, 0.8)';
            setTimeout(() => { document.getElementById('live-stats-panel').style.borderColor = 'rgba(123, 94, 255, 0.4)'; }, 500);
        }

        // MAJ de la carte latérale (sidebar) uniquement pour le badge "En route"
        const card = document.querySelector(`.vehicle-card[data-vehicule-id="${vehiculeId}"]`);
        if (card && extraStats) {
            let statusBadge = card.querySelector('.status-badge');
            if (statusBadge && !statusBadge.classList.contains('status-online')) {
                statusBadge.innerHTML = `<span class="pulse-dot"></span> En route`;
                statusBadge.className = "status-badge status-online";
                card.classList.add('active');
            }
        }
    }

    var selectedVehiculeId = null;
    var historyLayers = [];

    function focusVehicule(id, lat, lon) {
        selectedVehiculeId = id;
        if (lat && lon && lat != 0) {
            map.setView([lat, lon], 14);
            if (markers[id]) {
                closeAllTooltips(id);
                markers[id].openTooltip();
            }
        }
        
        // Titre dans le panneau de stats
        const card = document.querySelector(`.vehicle-card[data-vehicule-id="${id}"]`);
        if (card) {
            document.getElementById('live-stat-name').innerText = card.querySelector('h4').innerText;
            // Si en route, on ouvre le panneau direct
            if (card.classList.contains('active')) {
                document.getElementById('live-stats-panel').style.display = 'block';
            } else {
                closeLiveStats();
            }
        }
    }

    function closeLiveStats() {
        document.getElementById('live-stats-panel').style.display = 'none';
        selectedVehiculeId = null;
    }

    function resetMapLayers() {
        historyLayers.forEach(l => map.removeLayer(l));
        historyLayers = [];
    }

    function filterVehicles(query) {
        const q = query.toLowerCase();
        document.querySelectorAll('.vehicle-card').forEach(card => {
            const name = card.querySelector('h4').innerText.toLowerCase();
            const matricule = card.querySelector('code').innerText.toLowerCase();
            if (name.includes(q) || matricule.includes(q)) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/logistiquehub")
        .build();

    connection.on("ReceivePositionUpdate", function (vehiculeId, lat, lon) {
        const card = document.querySelector(`.vehicle-card[data-vehicule-id="${vehiculeId}"]`);
        const label = card ? card.querySelector('h4').innerText : "Véhicule #" + vehiculeId;
        addOrUpdateMarker(vehiculeId, lat, lon, label);
    });

    // --- LOGIQUE TRACÉ TEMPS RÉEL (FLUIDIFIÉE) ---
    var activeTrajets = {}; // { trajetId : { polyline: L.polyline, startTime: Date } }

    connection.on("TrajetStarted", function (vehiculeId, trajetId, origine, startTime) {
        console.log("🚀 Trajet démarré :", vehiculeId, trajetId, "Début:", startTime);
        
        activeTrajets[trajetId] = {
            polyline: L.polyline([], {
                color: '#7b5eff', 
                weight: 5, 
                opacity: 0.85, 
                lineCap: 'round', 
                lineJoin: 'round',
                smoothFactor: 1.5
            }).addTo(map),
            startTime: new Date(startTime)
        };
        
        // 1. MAJ Badge et Classe pour passer au VERT immédiatement
        const card = document.querySelector(`.vehicle-card[data-vehicule-id="${vehiculeId}"]`);
        if (card) {
            card.classList.add('active');
            let statusBadge = card.querySelector('.status-badge');
            if (statusBadge) {
                statusBadge.innerHTML = `<span class="pulse-dot"></span> En route`;
                statusBadge.className = "status-badge status-online";
            }
        }

        // 2. Ouvrir le panneau de stats automatiquement pour ce véhicule
        selectedVehiculeId = vehiculeId;
        document.getElementById('live-stats-panel').style.display = 'block';
        if (card) document.getElementById('live-stat-name').innerText = card.querySelector('h4').innerText;
        document.getElementById('live-stat-speed').innerText = "0 km/h";
        document.getElementById('live-stat-distance').innerText = "0.00 km";
    });

    // Timer Global pour fluidifier l'affichage du temps ( interpolation )
    setInterval(() => {
        if (!selectedVehiculeId) return;

        // Trouver le trajet actif pour le véhicule sélectionné
        let currentTrajet = null;
        for (let tid in activeTrajets) {
            // Note: On pourrait stocker le mapping vehiculeId -> trajetId pour aller plus vite
            // mais ici on va simplement rafraîchir le temps si un trajet existe.
        }
        
        // Pour faire simple et robuste : on met à jour le champ de durée 
        // si le véhicule sélectionné a une classe "active"
        const card = document.querySelector(`.vehicle-card[onclick*="focusVehicule(${selectedVehiculeId}"]`);
        if (card && card.classList.contains('active')) {
             // On cherche le début du trajet dans nos données actives
             for (let tid in activeTrajets) {
                 const t = activeTrajets[tid];
                 // (Note: Idéalement vérifier que vehiculeId correspond)
                 const now = new Date();
                 const diff = Math.floor((now - t.startTime) / 1000);
                 if (diff > 0) {
                     const h = Math.floor(diff / 3600).toString().padStart(2, '0');
                     const m = Math.floor((diff % 3600) / 60).toString().padStart(2, '0');
                     const s = (diff % 60).toString().padStart(2, '0');
                     const durationStr = (h !== "00" ? h + ":" : "") + m + ":" + s;
                     
                     const uiDuration = document.getElementById('live-stat-duration');
                     if (uiDuration) uiDuration.innerText = durationStr;
                 }
             }
        }
    }, 1000);

    connection.on("ReceivePositionWithTrace", function (vehiculeId, trajetId, lat, lon, speed, duration, distanceKm, co2Grammes) {
        const card = document.querySelector(`.vehicle-card[data-vehicule-id="${vehiculeId}"]`);
        const label = card ? card.querySelector('h4').innerText : "Véhicule #" + vehiculeId;

        addOrUpdateMarker(vehiculeId, lat, lon, label, { speed: speed, duration: duration, distance: distanceKm });

        // MAJ CO2 temps réel
        if (selectedVehiculeId == vehiculeId && co2Grammes !== undefined) {
            updateCO2Gauge(co2Grammes, vehiculeId);
        }

        // MAJ Tracé
        if (activeTrajets[trajetId]) {
            activeTrajets[trajetId].polyline.addLatLng([lat, lon]);
            activeTrajets[trajetId].lastCO2 = co2Grammes || 0;
        }
    });

    connection.on("TrajetEnded", function (vehiculeId, trajetId, rawTraceJson, distanceKm, co2Grammes) {
        console.log("✅ Trajet terminé :", vehiculeId, trajetId, "Distance:", distanceKm, "CO2:", co2Grammes, "g");
        
        // 1. Reset Statut UI Direct et Instantané
        const card = document.querySelector(`.vehicle-card[data-vehicule-id="${vehiculeId}"]`);
        if (card) {
            card.classList.remove('active');
            let badge = card.querySelector('.status-badge');
            if (badge) {
                badge.innerHTML = "Disponible";
                badge.className = "status-badge status-offline";
            }
        }
        
        // 2. Cacher le panneau si c'était le véhicule suivi
        if (selectedVehiculeId == vehiculeId) closeLiveStats();

        // 3. Supprimer le tracé live de la carte (il sera visible via l'historique)
        if (activeTrajets[trajetId]) {
            map.removeLayer(activeTrajets[trajetId].polyline);
            delete activeTrajets[trajetId];
        }

        // 4. Actualiser l'historique
        refreshHistory();
    });

    async function refreshHistory() {
        try {
            const history = await connection.invoke("GetTrajetHistory");
            const tbody = document.getElementById('history-tbody');
            tbody.innerHTML = "";

            if (!history || history.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:20px;">Aucun historique disponible.</td></tr>';
                return;
            }

            history.forEach(t => {
                const row = document.createElement('tr');
                row.className = "history-row";
                row.onclick = () => showHistoryTrace(t.traceJson);
                
                const dateStart = new Date(t.dateDebut).toLocaleString('fr-FR');
                const co2Kg = (t.co2EmisGrammes || 0) / 1000;
                const co2Color = co2Kg < 3 ? '#22c55e' : co2Kg < 8 ? '#eab308' : '#ef4444';
                row.innerHTML = `
                    <td>${dateStart}</td>
                    <td><span style="background:rgba(123,94,255,0.2); color:var(--accent-light); padding:2px 8px; border-radius:4px; font-size:0.75rem;">ID #${t.vehiculeId}</span></td>
                    <td>${t.origine || 'N/A'}</td>
                    <td>${t.destination || 'N/A'}</td>
                    <td><strong>${t.distanceParcourueKm.toFixed(2)} km</strong></td>
                    <td><span style="color:${co2Color}; font-weight:700; font-size:0.8rem;">${co2Kg > 0 ? co2Kg.toFixed(2) + ' kg' : '—'}</span></td>
                    <td style="color:var(--accent-light); font-weight:bold; font-size:0.75rem;">VOIR TRACÉ ➔</td>
                `;
                tbody.appendChild(row);
            });
        } catch (err) {
            console.error("Error fetching history:", err);
        }
    }

    function showHistoryTrace(traceJson) {
        if (!traceJson) {
            alert("Aucun tracé enregistré pour ce trajet.");
            return;
        }
        resetMapLayers();
        
        try {
            let poly;
            // Est-ce du GeoJSON LineString ou du JSON brut ?
            if (traceJson.trim().startsWith('{')) {
                const geo = JSON.parse(traceJson);
                poly = L.geoJSON(geo, { style: { color: '#94a3b8', weight: 5, opacity: 0.6 } }).addTo(map);
            } else {
                const points = JSON.parse(traceJson);
                const latLons = points.map(p => [p.lat, p.lon]);
                poly = L.polyline(latLons, { color: '#94a3b8', weight: 5, opacity: 0.6 }).addTo(map);
            }
            
            historyLayers.push(poly);
            map.fitBounds(poly.getBounds(), { padding: [50, 50] });
        } catch (e) {
            console.error("Erreur parsing trace:", e);
        }
    }

    // ── CO2 Gauge ────────────────────────────────────────────────────────
    // Stocker les données véhicules pour recommandations RSE
    var vehiculesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Vehicules.Select(v => new {
            id = v.Id,
            nom = v.Nom,
            typeCarburant = v.TypeCarburant ?? "",
            emissionCO2ParKm = v.EmissionCO2ParKm ?? 0
        })
    ));

    function updateCO2Gauge(co2Grammes, vehiculeId) {
        const co2Kg = co2Grammes / 1000;
        const valEl = document.getElementById('live-co2-value');
        const barEl = document.getElementById('co2-gauge-bar');
        const recoPanel = document.getElementById('rse-reco-panel');
        const recoText = document.getElementById('rse-reco-text');
        if (!valEl || !barEl) return;

        // Affichage
        valEl.innerText = co2Kg >= 1 ? co2Kg.toFixed(2) + ' kg' : co2Grammes.toFixed(0) + ' g';

        // Jauge : 0 → 8 kg = 0 → 100%
        const pct = Math.min(100, (co2Kg / 8) * 100);
        barEl.style.width = pct + '%';

        if (co2Kg < 3) {
            barEl.style.background = 'linear-gradient(90deg,#22c55e,#22c55e)';
            valEl.style.color = '#22c55e';
            recoPanel.style.display = 'none';
        } else if (co2Kg < 8) {
            barEl.style.background = 'linear-gradient(90deg,#22c55e,#eab308)';
            valEl.style.color = '#eab308';
            recoPanel.style.display = 'none';
        } else {
            barEl.style.background = 'linear-gradient(90deg,#eab308,#ef4444)';
            valEl.style.color = '#ef4444';

            // Recommandation : trouver un véhicule moins polluant
            const currentVeh = vehiculesData.find(v => v.id == vehiculeId);
            if (currentVeh && currentVeh.emissionCO2ParKm > 0) {
                const alternatives = vehiculesData
                    .filter(v => v.id != vehiculeId && v.emissionCO2ParKm > 0 && v.emissionCO2ParKm < currentVeh.emissionCO2ParKm)
                    .sort((a, b) => a.emissionCO2ParKm - b.emissionCO2ParKm);
                if (alternatives.length > 0) {
                    const best = alternatives[0];
                    const saving = ((currentVeh.emissionCO2ParKm - best.emissionCO2ParKm) / currentVeh.emissionCO2ParKm * 100).toFixed(0);
                    recoText.innerHTML = `Alternatif suggéré : <strong>${best.nom}</strong> (${best.typeCarburant || 'N/A'}, ${best.emissionCO2ParKm} g/km) — économiserait environ <strong>${saving}%</strong> de CO2 sur ce trajet.`;
                    recoPanel.style.display = 'block';
                }
            }
        }
    }

    async function forceResetVehicule(id) {
        if(!confirm("Voulez-vous forcer la remise à zéro de ce véhicule (Base de données) ?")) return;
        try {
            await connection.invoke("ForceResetVehicule", id);
            // Pas besoin de MAJ locale ici, le signal "TrajetEnded" envoyé par 
            // le serveur s'en chargera pour tout le monde (dont nous).
            console.log("Ordre de Reset envoyé au serveur.");
        } catch(e) { 
            console.error(e); 
            alert("Erreur lors du reset : " + e);
        }
    }

    connection.start().then(() => {
        console.log("SignalR Connected");
        refreshHistory();
    }).catch(err => console.error(err.toString()));

    // Initialiser les marqueurs
    @foreach(var veh in Model.Vehicules.Where(x => x.Latitude.HasValue && x.Longitude.HasValue))
    {
        <text>addOrUpdateMarker(@veh.Id, @veh.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture), @veh.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture), "@veh.Nom");</text>
    }
</script>
}
