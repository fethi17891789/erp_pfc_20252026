@page
@model erp_pfc_20252026.Pages.Settings.MobileAccessModel
@{
    ViewData["Title"] = "Paramètres Mobile";
}

                    </div>
                    <div>
                        <h2 style="font-size: 1.2rem; margin: 0; color: white;">Zero-Trust Tunnel</h2>
                        <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">Connectez le serveur de l'ERP au réseau mondial sans ouvrir de ports sur le routeur local.</p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    var isSuccess = Model.IsSuccess;
                    <div style="padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 0.9rem; @(isSuccess ? "background:rgba(34,197,94,0.15); color:#22c55e; border:1px solid rgba(34,197,94,0.3);" : "background:rgba(248,113,113,0.15); color:#f97373; border:1px solid rgba(248,113,113,0.3);")">
                        @(isSuccess ? "✅" : "❌") @Model.Message
                    </div>
                }

                <!-- ETAPE 1 -->
                <div style="margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <div style="display:flex; align-items:flex-start; gap: 16px;">
                        <div style="width:32px; height:32px; border-radius:50%; background:rgba(255,255,255,0.1); display:flex; align-items:center; justify-content:center; font-weight:bold; color:white; flex-shrink:0;">1</div>
                        <div>
                            <h3 style="margin:0 0 8px 0; font-size:1.1rem; color:white;">Préparation de l'environnement</h3>
                            <ul style="font-size:0.9rem; color:var(--text-muted); margin:0 0 16px 0; padding-left: 20px; line-height: 1.6;">
                                <li>Assurez-vous que cet ERP est actuellement ouvert <b>en tant qu'Administrateur</b>. C'est indispensable pour l'installation du service.</li>
                                <li>Téléchargez et installez l'agent Cloudflare officiel sur ce PC : <a href="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-windows-amd64.msi" target="_blank" style="color:var(--accent-light);">cloudflared-windows-amd64.msi</a>.</li>
                                <li>Une fois installé, <b>redémarrez complètement l'ERP</b> si c'est votre première installation.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- ETAPE 2 -->
                <div style="margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <div style="display:flex; align-items:flex-start; gap: 16px;">
                        <div style="width:32px; height:32px; border-radius:50%; background:var(--accent); display:flex; align-items:center; justify-content:center; font-weight:bold; color:white; flex-shrink:0;">2</div>
                        <div>
                            <h3 style="margin:0 0 8px 0; font-size:1.1rem; color:white;">Obtenir un Jeton Sécurisé</h3>
                            <ol style="font-size:0.9rem; color:var(--text-muted); margin:0 0 16px 0; padding-left: 20px; line-height: 1.6;">
                                <li>Ouvrez le gestionnaire <b>Cloudflare Zero Trust</b>.</li>
                                <li>Allez dans le menu <b>Networks</b> > <b>Tunnels</b>, puis cliquez sur <b>Create a tunnel</b>.</li>
                                <li>Sélectionnez <b>Cloudflared</b>, type <b>Windows</b>.</li>
                                <li>Dans le bloc de code qui s'affiche (<i>Run the following command</i>), <b>copiez uniquement le très long "Token"</b> caché juste à la fin du texte.</li>
                            </ol>
                            <a href="https://one.dash.cloudflare.com/" target="_blank" rel="noopener noreferrer" class="btn-secondary" style="display:inline-flex; align-items:center; gap:8px; padding:10px 20px; border-radius:8px; text-decoration:none; margin-top:5px;">
                                <svg style="width:16px;height:16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                Ouvrir Cloudflare Zero Trust
                            </a>
                        </div>
                    </div>
                </div>

                <!-- ETAPE 3 -->
                <div style="margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <div style="display:flex; align-items:flex-start; gap: 16px;">
                        <div style="width:32px; height:32px; border-radius:50%; background:var(--accent); display:flex; align-items:center; justify-content:center; font-weight:bold; color:white; flex-shrink:0;">3</div>
                        <div style="flex:1;">
                            <h3 style="margin:0 0 8px 0; font-size:1.1rem; color:white;">Connecter le Serveur ERP</h3>
                            <p style="font-size:0.9rem; color:var(--text-muted); margin-bottom:16px;">
                                Collez le Jeton (Token) copié à l'étape 2. Le système prendra le relais et l'installera silencieusement sur votre PC.
                            </p>

                            <form method="post" style="display: flex; flex-direction: column; gap: 16px;">
                                <div class="form-group">
                                    <textarea name="cloudflareToken" required class="job-input" placeholder="Collez le Token Cloudflare ici (ex: eyJhIjoi...)" 
                                              style="width: 100%; min-height: 100px; padding: 14px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08); background: rgba(10,14,40,0.6); color: white; resize: vertical; font-family: monospace; font-size: 0.8rem;"></textarea>
                                </div>
            
                                <button type="submit" class="btn-primary" style="padding: 12px; border-radius: 12px; font-weight: 700; font-size: 1rem; width: 100%;">
                                    Démarrer le Tunnel en arrière-plan
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- ETAPE 4 -->
                <div>
                    <div style="display:flex; align-items:flex-start; gap: 16px;">
                        <div style="width:32px; height:32px; border-radius:50%; background:var(--success); box-shadow: 0 0 10px rgba(34,197,94,0.4); display:flex; align-items:center; justify-content:center; font-weight:bold; color:white; flex-shrink:0;">4</div>
                        <div>
                            <h3 style="margin:0 0 8px 0; font-size:1.1rem; color:white;">Configurer la Route (Dernière étape)</h3>
                            <ol style="font-size:0.9rem; color:var(--text-muted); margin:0 0 0 0; padding-left: 20px; line-height: 1.6;">
                                <li>Une fois le message de succès affiché ci-dessus, retournez sur Cloudflare et passez à l'étape de routage (ou bouton <b>+ Add Route</b> > <b>Published application</b>).</li>
                                <li>Entrez le sous-domaine souhaité (ex: <b>logistique</b>) et sélectionnez votre domaine.</li>
                                <li>Dans Service, choisissez le Type <b>HTTP</b> et copiez l'URL de votre ERP actuel (ex: <b>localhost:7142</b>).</li>
                                <li>Enregistrez. L'adresse est maintenant mondiale et définitive, le bouton <b>QR Tracker</b> intégrera désormais cette nouvelle adresse magiquement !</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
        </section>
