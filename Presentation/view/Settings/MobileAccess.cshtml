@page
@model erp_pfc_20252026.Pages.Settings.MobileAccessModel
@{
    ViewData["Title"] = "Paramètres Mobile";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/Common.css" />
<link rel="stylesheet" href="~/css/Home.css" />

<div class="erp-shell">
    <!-- BARRE LATERALE GAUCHE -->
    <aside class="erp-sidebar">
        <div class="erp-logo">
            <span class="erp-logo-mark">E</span>
            <span class="erp-logo-text">ERP Suite</span>
        </div>

        <nav class="erp-nav">
            <a asp-page="/Home" class="nav-item">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"></path>
                    <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
                <span>Accueil</span>
            </a>
            <button class="nav-item nav-item-active" type="button">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7z"></path>
                    <circle cx="12" cy="9" r="3"></circle>
                </svg>
                <span>Accès Extérieur</span>
            </button>
        </nav>
        
        <div class="erp-sidebar-footer">
            <button class="sidebar-quick secondary" type="button" onclick="openLogoutModal()">
                <svg style="width: 14px; height: 14px; display: inline-block; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 3 16 10 13 7"></polyline>
                </svg>
                Déconnexion
            </button>
        </div>
    </aside>

    <!-- CONTENU PRINCIPAL -->
    <main class="erp-main">
        <header class="erp-header">
            <div class="header-left">
                <h1>Configuration Accès Mobile</h1>
                <p>Automatisation de la connexion sécurisée via Cloudflare Tunnel.</p>
            </div>
            <div class="header-right">
                <div class="header-db">
                    <span class="header-db-label">Service</span>
                    <span class="header-db-name" style="color:var(--accent);">Cloudflared</span>
                </div>
            </div>
        </header>

        <section class="erp-content" style="padding: 20px;">
            <div class="product-card" style="max-width: 600px; margin: 0 auto; padding: 30px;">
                <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 24px;">
                    <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(56, 189, 248, 0.15); display: flex; align-items: center; justify-content: center; color: #38bdf8;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 24px; height: 24px;">
                            <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
                        </svg>
                    </div>
                    <div>
                        <h2 style="font-size: 1.2rem; margin: 0; color: white;">Zero-Trust Tunnel</h2>
                        <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">Connectez le serveur de l'ERP au réseau mondial sans ouvrir de ports sur le routeur local.</p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    var isSuccess = Model.IsSuccess;
                    <div style="padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 0.9rem; @(isSuccess ? "background:rgba(34,197,94,0.15); color:#22c55e; border:1px solid rgba(34,197,94,0.3);" : "background:rgba(248,113,113,0.15); color:#f97373; border:1px solid rgba(248,113,113,0.3);")">
                        @(isSuccess ? "✅" : "❌") @Model.Message
                    </div>
                }

                <div style="margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.1);">
                    <div style="display:flex; align-items:flex-start; gap: 16px;">
                        <div style="width:32px; height:32px; border-radius:50%; background:var(--accent); display:flex; align-items:center; justify-content:center; font-weight:bold; color:white; flex-shrink:0;">1</div>
                        <div>
                            <h3 style="margin:0 0 8px 0; font-size:1.1rem; color:white;">Obtenir un Jeton Sécurisé</h3>
                            <p style="font-size:0.9rem; color:var(--text-muted); margin-bottom:16px;">
                                Ouvrez le gestionnaire Cloudflare Zero Trust. Créez un nouveau tunnel "Cloudflared" (Windows), et copiez uniquement le très long "Token" fourni lors de l'instruction d'installation.
                            </p>
                            <a href="https://one.dash.cloudflare.com/" target="_blank" rel="noopener noreferrer" class="btn-secondary" style="display:inline-flex; align-items:center; gap:8px; padding:10px 20px; border-radius:8px; text-decoration:none;">
                                <svg style="width:16px;height:16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                Ouvrir Cloudflare
                            </a>
                        </div>
                    </div>
                </div>

                <div style="display:flex; align-items:flex-start; gap: 16px;">
                    <div style="width:32px; height:32px; border-radius:50%; background:var(--accent); display:flex; align-items:center; justify-content:center; font-weight:bold; color:white; flex-shrink:0;">2</div>
                    <div style="flex:1;">
                        <h3 style="margin:0 0 8px 0; font-size:1.1rem; color:white;">Connecter le Serveur ERP</h3>
                        <p style="font-size:0.9rem; color:var(--text-muted); margin-bottom:16px;">Collez votre Jeton ci-dessous. L'ERP se chargera de l'installer en arrière-plan sans demander de commandes CMD.</p>

                        <form method="post" style="display: flex; flex-direction: column; gap: 16px;">
                            <div class="form-group">
                                <textarea name="cloudflareToken" required class="job-input" placeholder="Collez le Token Cloudflare ici (ex: eyJhIjoiNGEy...)" 
                                          style="width: 100%; min-height: 100px; padding: 14px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08); background: rgba(10,14,40,0.6); color: white; resize: vertical; font-family: monospace; font-size: 0.8rem;"></textarea>
                            </div>
        
                            <button type="submit" class="btn-primary" style="padding: 12px; border-radius: 12px; font-weight: 700; font-size: 1rem; width: 100%;">
                                Démarrer le Tunnel en arrière-plan
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>
</div>
