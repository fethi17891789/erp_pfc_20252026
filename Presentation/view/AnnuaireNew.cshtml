@page "{id?}"
@model erp_pfc_20252026.Pages.AnnuaireNewModel
@{
    var isEdit = RouteData.Values["id"] != null;
    ViewData["Title"] = isEdit ? "Modifier fiche contact" : "Nouveau contact";
}

@section Styles {
    <style>
        .tags-container {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 10px;
            min-height: 28px;
        }

        .tag-pill {
            display: inline-flex;
            align-items: center;
            background: rgba(148, 163, 253, 0.15);
            border: 1px solid rgba(148, 163, 253, 0.3);
            color: #c7d2fe;
            padding: 3px 10px;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.02em;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
            animation: tagAppear 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .tag-pill .remove-tag {
            margin-left: 6px;
            cursor: pointer;
            color: #ef4444;
            font-weight: bold;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: rgba(239, 68, 68, 0.15);
            transition: all 0.15s;
            font-size: 0.7rem;
            line-height: 1;
        }

        .tag-pill .remove-tag:hover {
            background: rgba(239, 68, 68, 0.4);
            color: #fca5a5;
        }

        @@keyframes tagAppear {
            from { opacity: 0; transform: scale(0.85) translateY(4px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        /* Style sombre pour les options du select */
        .select-wrapper select option {
            background: #0f172a;
            color: #e2e8f0;
            padding: 8px 14px;
        }

        /* Animation d'ouverture du select */
        .select-wrapper select {
            transition: border-color 140ms cubic-bezier(0.2, 0.8, 0.2, 1),
                        box-shadow 200ms cubic-bezier(0.2, 0.8, 0.2, 1),
                        background 140ms cubic-bezier(0.2, 0.8, 0.2, 1),
                        transform 100ms ease-out;
        }

        .select-wrapper select:focus {
            transform: translateY(-1px);
        }

        /* Bouton Ajouter avec style primaire */
        .btn-add-role {
            padding: 0 18px;
            height: var(--input-height);
            border-radius: var(--radius-sm);
            border: none;
            cursor: pointer;
            font-weight: 700;
            font-size: 0.8rem;
            letter-spacing: 0.02em;
            text-transform: uppercase;
            color: #FFFFFF;
            background: linear-gradient(135deg, var(--accent), var(--accent-hover));
            box-shadow: 0 6px 18px rgba(123, 94, 255, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.15);
            transition: transform 100ms cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 140ms, filter 140ms;
            white-space: nowrap;
        }

        .btn-add-role:hover {
            transform: translateY(-1px) scale(1.02);
            box-shadow: 0 10px 28px rgba(123, 94, 255, 0.45);
            filter: brightness(1.08);
        }

        .btn-add-role:active {
            transform: translateY(0);
            box-shadow: 0 3px 10px rgba(123, 94, 255, 0.3);
        }

        /* --- MAGIC AI CARD STYLE --- */
        .ai-magic-section {
            background: linear-gradient(135deg, rgba(123, 94, 255, 0.1), rgba(18, 22, 54, 0.4));
            backdrop-filter: blur(10px);
            border: 1px solid rgba(123, 94, 255, 0.3);
            border-radius: var(--radius-md);
            padding: 20px;
            margin-bottom: 25px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        .ai-magic-section::before {
            content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(123, 94, 255, 0.05) 0%, transparent 70%);
            animation: pulse-bg 8s infinite alternate;
            z-index: 0;
        }
        @@keyframes pulse-bg { 0% { transform: translate(-10%, -10%); } 100% { transform: translate(10%, 10%); } }

        .ai-header { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; position: relative; z-index: 1; }
        .ai-title { font-size: 0.95rem; font-weight: 800; color: #fff; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 8px; }
        .ai-sparkle { color: #facc15; animation: sparkle 2s infinite; }
        @@keyframes sparkle { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(1.2); } }

        .ai-textarea {
            width: 100%;
            background: rgba(2, 6, 23, 0.6);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: var(--radius-sm);
            padding: 12px;
            color: #fff;
            font-size: 0.9rem;
            resize: none;
            outline: none;
            transition: border-color 0.2s;
            position: relative; z-index: 1;
        }
        .ai-textarea:focus { border-color: var(--accent); }

        .ai-btn {
            margin-top: 10px;
            background: linear-gradient(90deg, #7B5EFF, #9C8CFF);
            border: none;
            border-radius: var(--radius-sm);
            padding: 10px 20px;
            color: #fff;
            font-weight: 700;
            cursor: pointer;
            display: flex; align-items: center; gap: 8px;
            transition: 0.2s;
            position: relative; z-index: 1;
        }
        .ai-btn:hover { transform: scale(1.02); box-shadow: 0 0 20px rgba(123, 94, 255, 0.4); }
        .ai-btn:disabled { opacity: 0.6; cursor: not-allowed; }

        .ai-loading-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(8, 11, 32, 0.8);
            display: none; align-items: center; justify-content: center;
            flex-direction: column; gap: 10px; z-index: 5;
            backdrop-filter: blur(4px);
        }

        /* --- VALIDATION STATES --- */
        .input-valid { border-color: #22c55e !important; box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.2) !important; }
        .input-invalid { border-color: #ef4444 !important; box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.2) !important; }
        
        .validation-icon {
            position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
            width: 18px; height: 18px; display: none;
        }
        .validation-icon.success { color: #22c55e; }
        .validation-icon.error { color: #ef4444; }
        
        .validation-msg { font-size: 0.75rem; margin-top: 4px; display: none; }
        .validation-msg.error { color: #fca5a5; }
    </style>
}

@section HeaderLeft {
    <h1>@(Model.CurrentContact.Id == 0 ? "Nouveau contact" : "Modifier le contact")</h1>
    <p>@(Model.CurrentContact.Id == 0 ? "Créer un nouveau contact professionnel." : "Mettre à jour les informations de l'entité.")</p>
}

<section class="erp-content">
    <div class="product-form-card">
        
        <!-- SECTION ASSISTANT GEMINI -->
        <div class="ai-magic-section" id="ai-section">
            <div class="ai-header">
                <span class="ai-title">
                    <svg class="ai-sparkle" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 6.91-1.01L12 2z"></path>
                    </svg>
                    Assistant Intelligent GEMINI
                </span>
            </div>
            <p style="font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-bottom: 12px; position: relative; z-index: 1;">
                Décrivez le contact (nom, entreprise, email, mobile, site...) et l'ERP remplira le formulaire automatiquement.
            </p>
            <textarea id="ai-prompt" class="ai-textarea" rows="2" placeholder="Ex: C'est le directeur de la Sarl Dubois à Nice, Vincent Dubois. Son mobile est le 06..."></textarea>
            <button type="button" class="ai-btn" onclick="callAiAssistant()" id="ai-btn">
                <span id="ai-btn-text">Générer la fiche</span>
            </button>
            <div id="ai-status-bar" style="display:none; margin-top: 8px; font-size: 0.7rem; color: rgba(255,255,255,0.5); display: flex; align-items: center; gap: 6px;">
                <span style="width: 6px; height: 6px; background: #22c55e; border-radius: 50%; display: inline-block; box-shadow: 0 0 5px #22c55e;"></span>
                Intelligence : <span id="ai-model-name" style="color: var(--accent); font-weight: 600;">Détection...</span>
            </div>

            <div class="ai-loading-overlay" id="ai-loader">
                <svg viewBox="0 0 50 50" style="width:40px;height:40px;animation: spin 1s linear infinite; color:var(--accent);">
                    <circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" stroke-dasharray="31.4 31.4" stroke-linecap="round"></circle>
                </svg>
                <div style="text-align: center; margin-top: 10px;">
                    <span style="font-weight: 700; color: #fff; font-size: 0.9rem; display: block;">Orchestration des données en cours...</span>
                    <span style="font-size: 0.75rem; color: rgba(255,255,255,0.6);">Étape 1 : Localisation du site officiel via Gemini</span>
                    <span style="font-size: 0.75rem; color: rgba(255,255,255,0.4); display: block;">Étape 2 : Extraction des données sources (Nom, Bio, Tel)</span>
                </div>
            </div>
        </div>

        <form id="contact-new-form" method="post" enctype="multipart/form-data" onsubmit="handleFormSubmit()">
            <input type="hidden" asp-for="CurrentContact.Id" />

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div style="color: #ef4444; background: rgba(239, 68, 68, 0.1); padding: 10px; margin-bottom: 15px; border-radius: 6px; font-weight: 500;">@Model.ErrorMessage</div>
            }
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div style="color: #22c55e; background: rgba(34, 197, 94, 0.1); padding: 10px; margin-bottom: 15px; border-radius: 6px; font-weight: 500;">@Model.SuccessMessage</div>
            }

            <div class="form-row form-row-2">
                <div class="form-group">
                    <label asp-for="CurrentContact.FullName" class="form-label">Nom complet / Raison Sociale</label>
                    <input asp-for="CurrentContact.FullName" id="CurrentContact_FullName" class="form-input" placeholder="ex: John Doe" required />
                </div>
                <div class="form-group">
                    <label asp-for="CurrentContact.Website" class="form-label">Site Web (Auto-Enrichissement)</label>
                    <div style="position:relative;">
                        <input asp-for="CurrentContact.Website" id="input-website" class="form-input" placeholder="ex: tesla.com" onblur="enrichWebsite()" />
                        <span id="spinner-website" style="display:none; position:absolute; right:12px; top:50%; transform:translateY(-50%); color:var(--accent);">
                            <svg viewBox="0 0 50 50" style="width:18px;height:18px;animation: spin 1s linear infinite;"><circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" stroke-dasharray="31.4 31.4" stroke-linecap="round"></circle></svg>
                        </span>
                    </div>
                    <div id="msg-website" style="font-size:0.8rem; color:#22c55e; margin-top:6px; display:none;">Données récupérées avec succès !</div>
                </div>
            </div>

            <div class="form-row form-row-2">
                <div class="form-group">
                    <label asp-for="CurrentContact.Email" class="form-label">Adresse Email</label>
                    <div style="position:relative;">
                        <input asp-for="CurrentContact.Email" id="input-email" class="form-input" placeholder="nom@@domaine.com" onblur="validateEmail()" />
                        <span id="spinner-email" style="display:none; position:absolute; right:12px; top:50%; transform:translateY(-50%); color:var(--accent);">
                            <svg viewBox="0 0 50 50" style="width:18px;height:18px;animation: spin 1s linear infinite;"><circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" stroke-dasharray="31.4 31.4" stroke-linecap="round"></circle></svg>
                        </span>
                        <span id="icon-email" class="validation-icon"></span>
                    </div>
                    <div id="msg-email" class="validation-msg error">L'adresse email semble invalide (serveur de messagerie introuvable).</div>
                </div>
                <div class="form-group">
                    <label asp-for="CurrentContact.Phone" class="form-label">Téléphone</label>
                    <div style="position:relative;">
                        <input asp-for="CurrentContact.Phone" id="input-phone" class="form-input" placeholder="+33 6 ..." onblur="validatePhone()" />
                        <span id="spinner-phone" style="display:none; position:absolute; right:12px; top:50%; transform:translateY(-50%); color:var(--accent);">
                            <svg viewBox="0 0 50 50" style="width:18px;height:18px;animation: spin 1s linear infinite;"><circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" stroke-dasharray="31.4 31.4" stroke-linecap="round"></circle></svg>
                        </span>
                        <span id="icon-phone" class="validation-icon"></span>
                    </div>
                    <div id="msg-phone" class="validation-msg error">Format de numéro de téléphone incorrect.</div>
                </div>
            </div>

            <div class="form-row form-row-2">
                <div class="form-group">
                    <label class="form-label">Types de contact</label>
                    <div style="display:flex; gap:8px;">
                        <div class="select-wrapper" style="flex:1;">
                            <select id="role-select" class="form-input">
                                <option value="">Choisir un type à ajouter...</option>
                                <option value="Client">Client</option>
                                <option value="Fournisseur">Fournisseur</option>
                                <option value="Employe">Employé</option>
                                <option value="Partenaire">Partenaire</option>
                                <option value="Investisseur">Investisseur</option>
                            </select>
                            <span class="select-icon">
                                <svg viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                                </svg>
                            </span>
                        </div>
                        <button type="button" class="btn-add-role" onclick="addRoleTag()">Ajouter</button>
                    </div>

                    <div class="tags-container" id="tags-container">
                    </div>

                    <input type="hidden" asp-for="SelectedRoles" id="SelectedRoles" />
                </div>

                <div class="form-group">
                    <label for="AvatarImage" class="form-label">Photo ou Logo</label>
                    <input id="AvatarImage" name="AvatarImage" type="file" accept="image/*" class="file-input-hidden" style="display:none;" />
                    <label for="AvatarImage" class="file-input-button-mini">
                        <svg style="width: 12px; height: 12px; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="17 8 12 3 7 8"></polyline>
                            <line x1="12" y1="3" x2="12" y2="15"></line>
                        </svg>
                        <span>Choisir un fichier</span>
                    </label>
                    <div style="margin-top:12px; color:var(--text-muted); font-size:0.8rem;">
                        (Optionnel. Format : 500x500px).
                    </div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group form-row-span-2">
                    <label for="Comment" class="form-label">Notes internes</label>
                    <textarea asp-for="CurrentContact.Comment" id="CurrentContact_Comment" class="form-input form-textarea" placeholder="Description de l'entité..." rows="4"></textarea>
                </div>
            </div>

            <div class="form-footer" style="margin-top: 16px;">
                <button type="submit" id="btn-submit" class="btn-primary" style="display:flex; align-items:center; justify-content:center;">
                    <span id="btn-spinner" style="display:none; margin-right:8px;">
                        <svg viewBox="0 0 50 50" style="width:16px;height:16px;animation: spin 1s linear infinite;"><circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" stroke-dasharray="31.4 31.4" stroke-linecap="round"></circle></svg>
                    </span>
                    <span id="btn-text">Enregistrer</span>
                </button>
                <a asp-page="/AnnuaireList" class="btn-secondary btn-cancel">Annuler</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
<script>
    var tagsSet = {};

    function handleFormSubmit() {
        var btn = document.getElementById('btn-submit');
        var spinner = document.getElementById('btn-spinner');
        var txt = document.getElementById('btn-text');
        
        btn.style.opacity = '0.8';
        btn.style.pointerEvents = 'none';
        
        spinner.style.display = 'inline-block';
        txt.innerText = 'Enregistrement...';
    }

    // Initialisation depuis le modèle existant
    window.onload = function() {
        var initialRoles = document.getElementById('SelectedRoles').value;
        if (initialRoles) {
            var roles = initialRoles.split(',');
            for (var i = 0; i < roles.length; i++) {
                if(roles[i].trim() !== "") {
                    tagsSet[roles[i].trim()] = true;
                }
            }
            renderTags();
        }
    };

    function addRoleTag() {
        var select = document.getElementById('role-select');
        var val = select.value;
        if (!val) return;

        if (!tagsSet[val]) {
            tagsSet[val] = true;
            renderTags();
        }
        select.value = '';
    }

    function removeTag(val) {
        delete tagsSet[val];
        renderTags();
    }

    function renderTags() {
        var container = document.getElementById('tags-container');
        container.innerHTML = '';

        var arr = Object.keys(tagsSet);
        document.getElementById('SelectedRoles').value = arr.join(',');

        for (var i = 0; i < arr.length; i++) {
            var tag = arr[i];
            var span = document.createElement('span');
            span.className = 'tag-pill';

            var textNode = document.createTextNode(tag + ' ');
            span.appendChild(textNode);

            var removeBtn = document.createElement('span');
            removeBtn.className = 'remove-tag';
            removeBtn.title = 'Supprimer';
            removeBtn.textContent = '\u00D7';
            removeBtn.setAttribute('data-tag', tag);
            removeBtn.onclick = function () {
                removeTag(this.getAttribute('data-tag'));
            };
            span.appendChild(removeBtn);

            container.appendChild(span);
        }
    }

    /* === VALIDATION AJAX (EMAIL / PHONE) === */
    const svgCheck = `<svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>`;
    const svgCross = `<svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>`;

    async function validateEmail() {
        const input = document.getElementById('input-email');
        const spinner = document.getElementById('spinner-email');
        const icon = document.getElementById('icon-email');
        const msg = document.getElementById('msg-email');
        const email = input.value;

        // Reset
        input.classList.remove('input-valid', 'input-invalid');
        icon.style.display = 'none';
        icon.className = 'validation-icon';
        msg.style.display = 'none';

        if (!email) return;

        spinner.style.display = 'inline-block';

        try {
            const response = await fetch(`?handler=ValidateEmail&email=${encodeURIComponent(email)}`);
            const data = await response.json();
            
            spinner.style.display = 'none';
            icon.style.display = 'inline-block';
            
            if (data.isValid) {
                input.classList.add('input-valid');
                icon.classList.add('success');
                icon.innerHTML = svgCheck;
            } else {
                input.classList.add('input-invalid');
                icon.classList.add('error');
                icon.innerHTML = svgCross;
                msg.style.display = 'block';
            }
        } catch (e) {
            spinner.style.display = 'none';
        }
    }

    async function validatePhone() {
        const input = document.getElementById('input-phone');
        const spinner = document.getElementById('spinner-phone');
        const icon = document.getElementById('icon-phone');
        const msg = document.getElementById('msg-phone');
        const phone = input.value;

        // Reset
        input.classList.remove('input-valid', 'input-invalid');
        icon.style.display = 'none';
        icon.className = 'validation-icon';
        msg.style.display = 'none';

        if (!phone) return;

        spinner.style.display = 'inline-block';

        try {
            const response = await fetch(`?handler=ValidatePhone&phone=${encodeURIComponent(phone)}`);
            const data = await response.json();
            
            spinner.style.display = 'none';
            icon.style.display = 'inline-block';
            
            if (data.isValid) {
                input.classList.add('input-valid');
                icon.classList.add('success');
                icon.innerHTML = svgCheck;
            } else {
                input.classList.add('input-invalid');
                icon.classList.add('error');
                icon.innerHTML = svgCross;
                msg.style.display = 'block';
            }
        } catch (e) {
            spinner.style.display = 'none';
        }
    }

    /* === AUTO ENRICHISSEMENT === */
    async function enrichWebsite() {
        const input = document.getElementById('input-website');
        const spinner = document.getElementById('spinner-website');
        const msg = document.getElementById('msg-website');
        const fullnameInput = document.getElementById('CurrentContact_FullName');
        const commentInput = document.getElementById('CurrentContact_Comment');

        const website = input.value;
        
        msg.style.display = 'none';
        if (!website) return;

        spinner.style.display = 'inline-block';

        try {
            console.log("Enrichissement pour:", website);
            const response = await fetch(`?handler=EnrichFromWebsite&website=${encodeURIComponent(website)}`);
            const data = await response.json();
            console.log("Données reçues:", data);
            
            spinner.style.display = 'none';

            let updated = false;

            if (fullnameInput && data.fullName && (!fullnameInput.value || fullnameInput.value.length < 3)) {
                fullnameInput.value = data.fullName;
                fullnameInput.classList.add('input-valid');
                updated = true;
            }

            if (commentInput && data.comment && (!commentInput.value || commentInput.value.length < 5)) {
                commentInput.value = data.comment;
                commentInput.classList.add('input-valid');
                updated = true;
            }

            if (updated) {
                msg.style.display = 'block';
                input.classList.add('input-valid');
                
                setTimeout(() => {
                    fullnameInput.classList.remove('input-valid');
                    commentInput.classList.remove('input-valid');
                    input.classList.remove('input-valid');
                    msg.style.display = 'none';
                }, 4000);
            } else {
                console.warn("Aucune donnée nouvelle à insérer.");
            }
        } catch (e) {
            console.error("Erreur enrichWebsite:", e);
            spinner.style.display = 'none';
        }
    }

    /* === ASSISTANT IA MAGIQUE === */
    async function callAiAssistant() {
        const promptInput = document.getElementById('ai-prompt');
        const loader = document.getElementById('ai-loader');
        const btn = document.getElementById('ai-btn');
        const description = promptInput.value.trim();

        if (!description) return;

        loader.style.display = 'flex';
        btn.disabled = true;

        try {
            const response = await fetch('?handler=AiMagicEnrich', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify(description)
            });

            const data = await response.json();
            console.log("IA Result:", data);

            if (data.error) {
                console.error("Détails de l'erreur IA :", data.error);
                alert("L'assistant a rencontré un problème technique :\n\n" + data.error + "\n\nRegardez la console noire de l'ERP pour plus de détails.");
            } else {
                // Mise à jour du tag de modèle
                const modelTag = document.getElementById('ai-status-bar');
                const modelName = document.getElementById('ai-model-name');
                if (data.ModelUsed) {
                    modelTag.style.display = 'flex';
                    modelName.innerText = data.ModelUsed;
                }

                // Remplissage des champs
                if (data.FullName) fillField('CurrentContact_FullName', data.FullName);
                if (data.Email) fillField('input-email', data.Email);
                if (data.Phone) fillField('input-phone', data.Phone);
                if (data.Website) fillField('input-website', data.Website);
                if (data.Comment) fillField('CurrentContact_Comment', data.Comment);

                // Les rôles sont désactivés pour l'instant (saisie manuelle souhaitée par l'utilisateur)

                // Petit message de succès
                promptInput.value = "";
                promptInput.placeholder = "Fiche générée avec succès ! ✨";
            }
        } catch (e) {
            console.error("AI Error:", e);
            alert("L'assistant Gemini est temporairement indisponible.");
        } finally {
            loader.style.display = 'none';
            btn.disabled = false;
        }
    }

    function fillField(id, value) {
        const el = document.getElementById(id);
        if (el) {
            el.value = value;
            el.classList.add('input-valid');
            el.style.animation = 'pulse-fill 0.5s ease';
            setTimeout(() => el.classList.remove('input-valid'), 3000);
        }
    }
</script>
<style>
    @@keyframes pulse-fill {
        0% { transform: scale(1); }
        50% { transform: scale(1.02); background: rgba(123, 94, 255, 0.2); }
        100% { transform: scale(1); }
    }
</style>
}
