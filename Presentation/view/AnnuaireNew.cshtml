{
@:/* ══════════════════════════════════════════════════════════════
@:   RELATIONS — DATA
@:══════════════════════════════════════════════════════════════ */
@:const CURRENT_CONTACT_ID   = @Model.CurrentContact.Id;
@:const CURRENT_CONTACT_NAME = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CurrentContact.FullName));
@:let allContacts   = [];
@:let relationsData = [];

@:async function loadRelations() {
@:    var resp = await fetch('?handler=Relations&contactId=' + CURRENT_CONTACT_ID);
@:    relationsData = await resp.json();
@:    renderRelations(relationsData);
@:    buildMiniGraph(relationsData);
@:}

@:async function loadContactsCache() {
@:    var resp = await fetch('?handler=AllContactsForRelation&excludeId=' + CURRENT_CONTACT_ID);
@:    allContacts = await resp.json();
@:}

@:/* ─── Dropdown contact ──────────────────────────────────────── */
@:function showContactDropdown()    { filterContactSuggestions(document.getElementById('rel-contact-search').value); }
@:function hideContactDropdown()    { document.getElementById('rel-contact-dropdown').style.display = 'none'; }

@:function filterContactSuggestions(q) {
@:    var dd       = document.getElementById('rel-contact-dropdown');
@:    var filtered = q.trim()
@:        ? allContacts.filter(function (c) { return c.name.toLowerCase().includes(q.toLowerCase()); })
@:        : allContacts.slice(0, 30);
@:    if (!filtered.length) { dd.style.display = 'none'; return; }
@:    dd.innerHTML = filtered.map(function (c) {
@:        return '<div class="rel-dd-item" onclick="selectContact(' + c.id + ', \'' + c.name.replace(/'/g, "\\'") + '\')">' + c.name + '</div>';
@:    }).join('');
@:    dd.style.display = 'block';
@:}

@:function selectContact(id, name) {
@:    document.getElementById('rel-target-id').value     = id;
@:    document.getElementById('rel-contact-search').value = name;
@:    document.getElementById('rel-contact-search').classList.add('input-valid');
@:    setTimeout(function () { document.getElementById('rel-contact-search').classList.remove('input-valid'); }, 2000);
@:    hideContactDropdown();
@:}

@:/* ─── Rendu liste relations ─────────────────────────────────── */
@:function renderRelations(relations) {
@:    var list  = document.getElementById('relations-list');
@:    var empty = document.getElementById('relations-empty');
@:    list.querySelectorAll('.relation-row').forEach(function (el) { el.remove(); });
@:    if (!relations || !relations.length) { empty.style.display = 'block'; return; }
@:    empty.style.display = 'none';
@:    relations.forEach(function (r) { list.insertBefore(buildRelationRow(r), empty); });
@:}

@:function buildRelationRow(r) {
@:    var row = document.createElement('div');
@:    row.className    = 'relation-row';
@:    row.dataset.id   = r.id;
@:    var src  = document.createElement('span'); src.className  = 'rel-contact-name'; src.textContent = r.sourceName;
@:    var arr1 = document.createElement('span'); arr1.className = 'rel-arrow';         arr1.textContent = '→';
@:    var pill = document.createElement('span'); pill.className = 'rel-type-pill';     pill.textContent = r.relationType;
@:    var arr2 = document.createElement('span'); arr2.className = 'rel-arrow';         arr2.textContent = '→';
@:    var tgt  = document.createElement('span'); tgt.className  = 'rel-contact-name'; tgt.textContent = r.targetName;
@:    var btn  = document.createElement('button');
@:    btn.type = 'button'; btn.title = 'Supprimer'; btn.className = 'rel-delete-btn';
@:    btn.innerHTML = '✕';
@:    btn.onclick = function () { deleteRelation(r.id, btn); };
@:    row.append(src, arr1, pill, arr2, tgt, btn);
@:    return row;
@:}

@:/* ─── CRUD relations ────────────────────────────────────────── */
@:async function addRelation() {
@:    var targetId = parseInt(document.getElementById('rel-target-id').value);
@:    var relType  = document.getElementById('rel-type-input').value.trim();
@:    var btn      = document.getElementById('btn-add-relation');
@:    if (!targetId) { showToast('Sélectionnez un contact cible.', 'error'); return; }
@:    if (!relType)  { showToast('Saisissez un type de relation.', 'error'); return; }
@:    btn.disabled = true; btn.style.opacity = '0.6';
@:    try {
@:        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
@:        var resp  = await fetch('?handler=AddRelation', {
@:            method: 'POST',
@:            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
@:            body: JSON.stringify({ sourceId: CURRENT_CONTACT_ID, targetId: targetId, relationType: relType })
@:        });
@:        var data = await resp.json();
@:        if (data.ok) {
@:            document.getElementById('relations-empty').style.display = 'none';
@:            var list = document.getElementById('relations-list');
@:            list.insertBefore(buildRelationRow(data), document.getElementById('relations-empty'));
@:            document.getElementById('rel-contact-search').value = '';
@:            document.getElementById('rel-target-id').value      = '';
@:            document.getElementById('rel-type-input').value     = '';
@:            relationsData.push(data);
@:            buildMiniGraph(relationsData);
@:            showToast('Relation ajoutée.', 'success');
@:        } else {
@:            showToast(data.message || 'Erreur lors de l\'ajout.', 'error');
@:        }
@:    } catch { showToast('Erreur technique.', 'error'); }
@:    finally { btn.disabled = false; btn.style.opacity = '1'; }
@:}

@:async function deleteRelation(id, btnEl) {
@:    btnEl.disabled = true; btnEl.textContent = '…';
@:    try {
@:        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
@:        var resp  = await fetch('?handler=DeleteRelation', {
@:            method: 'POST',
@:            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
@:            body: JSON.stringify(id)
@:        });
@:        var data = await resp.json();
@:        if (data.ok) {
@:            var row = document.querySelector('.relation-row[data-id="' + id + '"]');
@:            if (row) row.remove();
@:            if (!document.getElementById('relations-list').querySelector('.relation-row'))
@:                document.getElementById('relations-empty').style.display = 'block';
@:            relationsData = relationsData.filter(function (r) { return r.id !== id; });
@:            buildMiniGraph(relationsData);
@:            showToast('Relation supprimée.', 'success');
@:        }
@:    } catch { showToast('Erreur technique.', 'error'); btnEl.disabled = false; btnEl.textContent = '✕'; }
@:}

@:/* ══════════════════════════════════════════════════════════════
@:   MINI-GRAPHE EGO NETWORK
@:══════════════════════════════════════════════════════════════ */
@:let miniCanvas, miniCtx, miniAnim = null;
@:let miniNodes = [], miniEdges = [];
@:let miniZoom = 1, miniPanX = 0, miniPanY = 0;
@:let miniDragging = false, miniDragStart = {x:0,y:0}, miniPanStart = {x:0,y:0};
@:let miniHovered = null;

@:const ROLE_COLOR_MAP = { 0:'#9C8CFF', 1:'#4ade80', 2:'#c084fc', 4:'#7dd3fc', 8:'#fb923c', 16:'#fde047' };

@:function getRoleColorMini(roles) {
@:    if (!roles) return '#9C8CFF';
@:    for (var bit of [1, 2, 16, 8, 4]) { if (roles & bit) return ROLE_COLOR_MAP[bit]; }
@:    return '#9C8CFF';
@:}

@:function initMiniGraph() {
@:    miniCanvas = document.getElementById('miniGraphCanvas');
@:    if (!miniCanvas) return;
@:    miniCtx = miniCanvas.getContext('2d');
@:    var wrap = miniCanvas.parentElement;
@:    miniCanvas.width  = wrap.offsetWidth;
@:    miniCanvas.height = wrap.offsetHeight;
@:    setupMiniGraphEvents();
@:}

@:function buildMiniGraph(relations) {
@:    if (!miniCanvas) return;
@:    var emptyEl = document.getElementById('mini-graph-empty');

@:    if (!relations || !relations.length) {
@:        if (emptyEl) emptyEl.style.display = 'block';
@:        miniNodes = []; miniEdges = [];
@:        drawMiniGraph();
@:        return;
@:    }
@:    if (emptyEl) emptyEl.style.display = 'none';

@:    // Nœud central (le contact courant)
@:    var nodeMap = {};
@:    nodeMap[CURRENT_CONTACT_ID] = {
@:        id: CURRENT_CONTACT_ID,
@:        name: CURRENT_CONTACT_NAME,
@:        roles: 0,
@:        initials: CURRENT_CONTACT_NAME.length >= 2 ? CURRENT_CONTACT_NAME.substring(0,2).toUpperCase() : '?',
@:        isCurrent: true,
@:        x: miniCanvas.width / 2, y: miniCanvas.height / 2,
@:        vx: 0, vy: 0, r: 32
@:    };

@:    // Nœuds connectés
@:    relations.forEach(function (r) {
@:        [{ id: r.sourceId, name: r.sourceName }, { id: r.targetId, name: r.targetName }].forEach(function (n) {
@:            if (!nodeMap[n.id]) {
@:                var contact = allContacts.find(function(c) { return c.id === n.id; });
@:                nodeMap[n.id] = {
@:                    id: n.id, name: n.name,
@:                    roles: contact ? contact.roles || 0 : 0,
@:                    initials: n.name.length >= 2 ? n.name.substring(0,2).toUpperCase() : '?',
@:                    isCurrent: false,
@:                    x: miniCanvas.width  / 2 + (Math.random() - 0.5) * miniCanvas.width  * 0.5,
@:                    y: miniCanvas.height / 2 + (Math.random() - 0.5) * miniCanvas.height * 0.5,
@:                    vx: 0, vy: 0, r: 24
@:                };
@:            }
@:        });
@:    });

@:    miniNodes = Object.values(nodeMap);
@:    miniEdges = relations.map(function (r) { return { source: r.sourceId, target: r.targetId, type: r.relationType }; });

@:    miniReSimulate();
@:}

@:function miniReSimulate() {
@:    if (!miniCanvas || !miniNodes.length) return;
@:    if (miniAnim) cancelAnimationFrame(miniAnim);
@:    miniNodes.forEach(function (n) {
@:        if (n.isCurrent) { n.x = miniCanvas.width / 2; n.y = miniCanvas.height / 2; }
@:        else {
@:            var angle = Math.random() * Math.PI * 2;
@:            var r = Math.min(miniCanvas.width, miniCanvas.height) * 0.3;
@:            n.x = miniCanvas.width  / 2 + r * Math.cos(angle);
@:            n.y = miniCanvas.height / 2 + r * Math.sin(angle);
@:        }
@:        n.vx = 0; n.vy = 0;
@:    });
@:    var frame = 0, maxFrames = 150;
@:    function tick() {
@:        miniSimulateStep(Math.max(0, 1 - frame / maxFrames));
@:        drawMiniGraph();
@:        frame++;
@:        if (frame < maxFrames) miniAnim = requestAnimationFrame(tick);
@:    }
@:    miniAnim = requestAnimationFrame(tick);
@:}

@:function miniSimulateStep(alpha) {
@:    var W = miniCanvas.width, H = miniCanvas.height;
@:    var cx = W / 2, cy = H / 2;
@:    for (var i = 0; i < miniNodes.length; i++) {
@:        for (var j = i + 1; j < miniNodes.length; j++) {
@:            var a = miniNodes[i], b = miniNodes[j];
@:            var dx = b.x - a.x, dy = b.y - a.y;
@:            var dist = Math.max(Math.sqrt(dx*dx + dy*dy), 1);
@:            var force = (6000 / (dist * dist)) * alpha * 0.015;
@:            var fx = (dx/dist)*force, fy = (dy/dist)*force;
@:            a.vx -= fx; a.vy -= fy; b.vx += fx; b.vy += fy;
@:        }
@:    }
@:    miniEdges.forEach(function (e) {
@:        var s = miniNodes.find(function(n) { return n.id === e.source; });
@:        var t = miniNodes.find(function(n) { return n.id === e.target; });
@:        if (!s || !t) return;
@:        var dx = t.x - s.x, dy = t.y - s.y;
@:        var dist = Math.max(Math.sqrt(dx*dx + dy*dy), 1);
@:        var ideal = 120, force = (dist - ideal) * 0.01 * alpha;
@:        var fx = (dx/dist)*force, fy = (dy/dist)*force;
@:        s.vx += fx; s.vy += fy; t.vx -= fx; t.vy -= fy;
@:    });
@:    miniNodes.forEach(function (n) {
@:        if (n.isCurrent) { n.vx = 0; n.vy = 0; n.x = W/2; n.y = H/2; return; }
@:        n.vx += (cx - n.x) * 0.002 * alpha;
@:        n.vy += (cy - n.y) * 0.002 * alpha;
@:        n.vx *= 0.85; n.vy *= 0.85;
@:        n.x  += n.vx;  n.y  += n.vy;
@:        n.x = Math.max(n.r + 8, Math.min(W - n.r - 8, n.x));
@:        n.y = Math.max(n.r + 8, Math.min(H - n.r - 8, n.y));
@:    });
@:}

@:function drawMiniGraph() {
@:    if (!miniCtx) return;
@:    miniCtx.clearRect(0, 0, miniCanvas.width, miniCanvas.height);
@:    if (!miniNodes.length) return;
@:    miniCtx.save();
@:    miniCtx.translate(miniPanX, miniPanY);
@:    miniCtx.scale(miniZoom, miniZoom);

@:    // Arêtes
@:    miniEdges.forEach(function (e) {
@:        var s = miniNodes.find(function(n){return n.id===e.source;}),
@:            t = miniNodes.find(function(n){return n.id===e.target;});
@:        if (!s || !t) return;
@:        var dx = t.x-s.x, dy = t.y-s.y, dist = Math.max(Math.sqrt(dx*dx+dy*dy),1);
@:        var ux = dx/dist, uy = dy/dist;
@:        var sx = s.x + ux*s.r, sy = s.y + uy*s.r;
@:        var tx2 = t.x - ux*t.r, ty2 = t.y - uy*t.r;
@:        miniCtx.beginPath(); miniCtx.moveTo(sx, sy); miniCtx.lineTo(tx2, ty2);
@:        miniCtx.strokeStyle = 'rgba(148,163,184,0.3)'; miniCtx.lineWidth = 1.5; miniCtx.stroke();
@:        // Flèche
@:        var al = 7, aa = 0.4, ang = Math.atan2(uy, ux);
@:        miniCtx.beginPath();
@:        miniCtx.moveTo(tx2, ty2);
@:        miniCtx.lineTo(tx2 - al*Math.cos(ang-aa), ty2 - al*Math.sin(ang-aa));
@:        miniCtx.moveTo(tx2, ty2);
@:        miniCtx.lineTo(tx2 - al*Math.cos(ang+aa), ty2 - al*Math.sin(ang+aa));
@:        miniCtx.strokeStyle = 'rgba(148,163,184,0.5)'; miniCtx.lineWidth = 1.2; miniCtx.stroke();
@:        // Label
@:        if (e.type) {
@:            var mx = (sx+tx2)/2, my = (sy+ty2)/2;
@:            miniCtx.fillStyle = 'rgba(148,163,184,0.6)';
@:            miniCtx.font = '9px "Plus Jakarta Sans", sans-serif';
@:            miniCtx.textAlign = 'center'; miniCtx.fillText(e.type, mx, my - 4);
@:        }
@:    });

@:    // Nœuds
@:    miniNodes.forEach(function (n) {
@:        var isHov     = miniHovered && miniHovered.id === n.id;
@:        var color     = n.isCurrent ? '#7B5EFF' : getRoleColorMini(n.roles);
@:        var r         = isHov ? n.r + 3 : n.r;
@:        // Halo (nœud courant ou hover)
@:        if (n.isCurrent || isHov) {
@:            var haloGrad = miniCtx.createRadialGradient(n.x, n.y, r*0.5, n.x, n.y, r*2.2);
@:            haloGrad.addColorStop(0, color + '44');
@:            haloGrad.addColorStop(1, 'transparent');
@:            miniCtx.beginPath(); miniCtx.arc(n.x, n.y, r*2.2, 0, Math.PI*2);
@:            miniCtx.fillStyle = haloGrad; miniCtx.fill();
@:        }
@:        // Cercle
@:        var grad = miniCtx.createRadialGradient(n.x-r*0.3, n.y-r*0.3, r*0.1, n.x, n.y, r);
@:        grad.addColorStop(0, color + 'CC');
@:        grad.addColorStop(1, color + (n.isCurrent ? 'AA' : '66'));
@:        miniCtx.beginPath(); miniCtx.arc(n.x, n.y, r, 0, Math.PI*2);
@:        miniCtx.fillStyle = grad; miniCtx.fill();
@:        miniCtx.beginPath(); miniCtx.arc(n.x, n.y, r, 0, Math.PI*2);
@:        miniCtx.strokeStyle = isHov || n.isCurrent ? color : color + '88';
@:        miniCtx.lineWidth   = n.isCurrent ? 2.5 : (isHov ? 2 : 1.5);
@:        miniCtx.stroke();
@:        // Initiales
@:        miniCtx.fillStyle = '#fff';
@:        miniCtx.font = '700 ' + Math.round(r*0.42) + 'px "Plus Jakarta Sans", sans-serif';
@:        miniCtx.textAlign = 'center'; miniCtx.textBaseline = 'middle';
@:        miniCtx.fillText(n.initials, n.x, n.y);
@:        // Nom sous le nœud
@:        var label = n.name.length > 14 ? n.name.slice(0,12) + '…' : n.name;
@:        miniCtx.fillStyle = isHov || n.isCurrent ? '#fff' : 'rgba(196,206,231,0.75)';
@:        miniCtx.font      = (n.isCurrent ? '700' : '500') + ' 10px "Plus Jakarta Sans", sans-serif';
@:        miniCtx.textAlign = 'center'; miniCtx.textBaseline = 'top';
@:        miniCtx.fillText(label, n.x, n.y + r + 5);
@:    });

@:    miniCtx.restore();
@:}

@:function miniResetZoom() { miniZoom = 1; miniPanX = 0; miniPanY = 0; drawMiniGraph(); }

@:function getMiniNodeAt(mx, my) {
@:    var wx = (mx - miniPanX) / miniZoom, wy = (my - miniPanY) / miniZoom;
@:    return miniNodes.find(function(n) { return Math.hypot(n.x-wx, n.y-wy) <= n.r + 4; }) || null;
@:}

@:function setupMiniGraphEvents() {
@:    if (!miniCanvas) return;
@:    miniCanvas.addEventListener('wheel', function(e) {
@:        e.preventDefault();
@:        miniZoom = Math.max(0.4, Math.min(2.5, miniZoom * (e.deltaY < 0 ? 1.1 : 0.9)));
@:        drawMiniGraph();
@:    }, { passive: false });
@:    miniCanvas.addEventListener('mousedown', function(e) {
@:        miniDragging = true;
@:        miniDragStart = { x: e.offsetX, y: e.offsetY };
@:        miniPanStart  = { x: miniPanX,  y: miniPanY  };
@:        miniCanvas.style.cursor = 'grabbing';
@:    });
@:    miniCanvas.addEventListener('mousemove', function(e) {
@:        if (miniDragging) {
@:            miniPanX = miniPanStart.x + (e.offsetX - miniDragStart.x);
@:            miniPanY = miniPanStart.y + (e.offsetY - miniDragStart.y);
@:            drawMiniGraph(); return;
@:        }
@:        var node = getMiniNodeAt(e.offsetX, e.offsetY);
@:        if (node !== miniHovered) { miniHovered = node; miniCanvas.style.cursor = node ? 'pointer' : 'default'; drawMiniGraph(); }
@:    });
@:    miniCanvas.addEventListener('mouseup',    function() { miniDragging = false; miniCanvas.style.cursor = miniHovered ? 'pointer' : 'default'; });
@:    miniCanvas.addEventListener('mouseleave', function() { miniDragging = false; miniHovered = null; drawMiniGraph(); });
@:    miniCanvas.addEventListener('click', function(e) {
@:        var node = getMiniNodeAt(e.offsetX, e.offsetY);
@:        if (node && !node.isCurrent) window.location.href = '/AnnuaireNew/' + node.id;
@:    });
@:}
}
</script>
}

