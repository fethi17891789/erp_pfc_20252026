    async function onOAUserSearchInput(value) {
        const suggestions = document.getElementById('oa-user-suggestions');
        const hiddenId = document.getElementById('oa-selected-user-id');
        if (!suggestions || !hiddenId) return;

        hiddenId.value = '';

        const term = (value || '').toLowerCase().trim();
        if (!term) {
            suggestions.innerHTML = '';
            suggestions.style.display = 'none';
            return;
        }

        try {
            const params = new URLSearchParams(window.location.search);
            const planId = params.get('id') || '';
            const url = `/MRPDetail?id=${encodeURIComponent(planId)}&handler=SearchUsers&term=${encodeURIComponent(term)}`;

            const resp = await fetch(url, { method: 'GET' });
            if (!resp.ok) {
                console.warn('Erreur HTTP SearchUsers:', resp.status);
                suggestions.innerHTML = '';
                suggestions.style.display = 'none';
                return;
            }

            const users = await resp.json();
            if (!Array.isArray(users) || users.length === 0) {
                suggestions.innerHTML = '';
                suggestions.style.display = 'none';
                return;
            }

            suggestions.innerHTML = '';

            users.forEach(u => {
                const item = document.createElement('div');
                item.textContent = u.nomAffiche || u.login || u.email || ('User ' + u.id);
                item.style.padding = '6px 10px';
                item.style.cursor = 'pointer';
                item.style.fontSize = '0.85rem';
                item.addEventListener('click', () => {
                    const input = document.getElementById('oa-user-search');
                    if (input) input.value = item.textContent;
                    hiddenId.value = (u.id || '').toString();
                    suggestions.style.display = 'none';
                });
                item.addEventListener('mouseover', () => {
                    item.style.backgroundColor = 'rgba(51,65,85,0.85)';
                });
                item.addEventListener('mouseout', () => {
                    item.style.backgroundColor = 'transparent';
                });
                suggestions.appendChild(item);
            });

            suggestions.style.display = 'block';
        } catch (err) {
            console.error('Erreur SearchUsers:', err);
            suggestions.innerHTML = '';
            suggestions.style.display = 'none';
        }
    }

    async function sendOAProposal() {
        const selectedUserId = document.getElementById('oa-selected-user-id');
        const searchInput = document.getElementById('oa-user-search');
        const message = document.getElementById('oa-message');

        if (!selectedUserId || !searchInput) return;

        const userIdStr = selectedUserId.value;
        if (!userIdStr) {
            alert("Veuillez selectionner un utilisateur dans la liste.");
            return;
        }

        const destUserId = parseInt(userIdStr, 10);
        if (!destUserId || isNaN(destUserId)) {
            alert("Utilisateur selectionne invalide.");
            return;
        }

        if (!currentOAProduct.codeArticle) {
            alert("Produit OA invalide.");
            return;
        }

        const commentaire = message && message.value ? message.value.trim() : '';
        const quantite = currentOAProduct.quantite || 0;

        if (!quantite || quantite <= 0) {
            alert("Quantite OA invalide.");
            return;
        }

        const token = getAntiForgeryToken();

        const formData = new URLSearchParams();
        formData.append("CodeArticle", currentOAProduct.codeArticle);
        formData.append("LibelleArticle", currentOAProduct.libelle || "");
        formData.append("Quantite", quantite.toString());
        formData.append("DestUserId", destUserId.toString());
        formData.append("Commentaire", commentaire);

        try {
            const params = new URLSearchParams(window.location.search);
            const planId = params.get('id') || '';
            const url = `/MRPDetail?id=${encodeURIComponent(planId)}&handler=SendOAProposal`;

            const resp = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': token
                },
                body: formData.toString()
            });

            if (!resp.ok) {
                console.error('Erreur HTTP SendOAProposal:', resp.status);
                alert("Erreur HTTP lors de l'envoi de la proposition OA.");
                return;
            }

            const res = await resp.json();
            if (!res.ok) {
                alert("Erreur lors de l'envoi de la proposition OA : " + (res.message || ''));
                return;
            }

            alert("Proposition d'OA envoyee avec succes.");
            closeOAPopup();
        } catch (err) {
            console.error('Erreur SendOAProposal:', err);
            alert("Erreur technique lors de l'envoi de la proposition OA.");
        }
    }

    function openLogoutModal() {
        document.getElementById('logout-overlay').style.display = 'flex';
        document.body.classList.add('logout-blur-active');
    }

    function closeLogoutModal() {
        document.getElementById('logout-overlay').style.display = 'none';
        document.body.classList.remove('logout-blur-active');
    }
</script>

