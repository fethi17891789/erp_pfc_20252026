    function buildMrpTablesForProduct(rootCodeArticle, rootLibelle, callbackAfterBuild) {
        const wrapper = document.getElementById('mrp-grid-wrapper');
        if (!wrapper) return;

        wrapper.innerHTML = "";

        const niveaux = {};
        const queue = [rootCodeArticle];
        niveaux[rootCodeArticle] = 0;

        while (queue.length > 0) {
            const current = queue.shift();
            const currentLevel = niveaux[current] ?? 0;
            const children = mrpChildrenByParent[current] || [];
            children.forEach(function (c) {
                if (niveaux[c.childCode] === undefined) {
                    niveaux[c.childCode] = currentLevel + 1;
                    queue.push(c.childCode);
                }
            });
        }

        const articlesParNiveau = {};
        Object.keys(niveaux).forEach(function (code) {
            const lvl = niveaux[code];
            if (!articlesParNiveau[lvl]) {
                articlesParNiveau[lvl] = [];
            }
            articlesParNiveau[lvl].push(code);
        });

        const niveauxOrdonnes = Object.keys(articlesParNiveau)
            .map(x => parseInt(x, 10))
            .sort((a, b) => a - b);

        const libelles = {};
        libelles[rootCodeArticle] = rootLibelle || rootCodeArticle;

        mrpBomDetails.forEach(function (bd) {
            const pfCode = bd.codeArticlePF || bd.CodeArticlePF;
            if (!pfCode) return;
            const comps = bd.composants || bd.Composants || [];
            comps.forEach(function (c) {
                const cc = c.codeArticle || c.CodeArticle;
                const nn = c.nom || c.Nom || cc;
                if (cc && !libelles[cc]) {
                    libelles[cc] = nn;
                }
            });
        });

        niveauxOrdonnes.forEach(function (level) {
            const codes = articlesParNiveau[level];
            if (!codes || !codes.length) return;

            const levelRow = document.createElement('div');
            levelRow.className = 'mrp-level-row';

            const levelLabel = document.createElement('div');
            levelLabel.className = 'mrp-level-title';
            levelLabel.textContent = "Niveau " + level;
            wrapper.appendChild(levelLabel);

            codes.forEach(function (codeArticle) {
                const isPf = (codeArticle === rootCodeArticle);

                const block = document.createElement('div');
                block.className = 'mrp-grid-block';

                const title = document.createElement('div');
                title.className = 'mrp-grid-block-title';

                if (isPf) {
                    title.textContent = "Produit fini : " + codeArticle + " - " + (libelles[codeArticle] || "");
                } else {
                    title.textContent = codeArticle + " - " + (libelles[codeArticle] || "");
                }

                const table = document.createElement('table');
                table.className = "erp-table mrp-grid-table";
                table.style.borderCollapse = "collapse";
                table.style.width = "max-content";
                table.style.minWidth = "700px";

                const thead = document.createElement('thead');
                const trHead = document.createElement('tr');

                const thLabel = document.createElement('th');
                thLabel.style.width = "160px";
                thLabel.style.minWidth = "160px";
                thLabel.textContent = "Ligne / Periode";
                trHead.appendChild(thLabel);

                @if (Model.Periodes != null && Model.Periodes.Any())
                {
                            foreach (var p in Model.Periodes)
                            {
                                                @: {
                                                @:     const th = document.createElement('th');
                                                @:     th.style.minWidth = "90px";
                                                @:     th.style.width = "90px";
                                                @:     th.title = "@p.LabelLong";
                                                @:     th.textContent = "@p.LabelCourt";
                                                @:     trHead.appendChild(th);
                                                @: }
                            }
                }
                else
                {
                                    @: {
                                    @:     const th = document.createElement('th');
                                    @:     th.style.minWidth = "90px";
                                    @:     th.style.width = "90px";
                                    @:     th.textContent = "-";
                                    @:     trHead.appendChild(th);
                                    @: }
                }

                thead.appendChild(trHead);
                table.appendChild(thead);

                const tbody = document.createElement('tbody');

                const rowDefs = [
                    { key: "BB", label: "Besoin brut (BB)", editable: isPf },
                    { key: "SP", label: "Stock previsionnel (SP)", editable: false },
                    { key: "BN", label: "Besoin net (BN)", editable: false },
                    { key: "FIN", label: "Fin ordre (receptions)", editable: false },
                    { key: "DEB", label: "Debut ordre (lancements)", editable: false },
                    { key: "DEL", label: "Delai (jours)", editable: true }
                ];

                const stockInitial = findStockForArticle(codeArticle);

                rowDefs.forEach(function (r) {
                    const tr = document.createElement('tr');

                    const tdLabel = document.createElement('td');
                    tdLabel.className = "mrp-grid-row-label";
                    tdLabel.style.minWidth = "160px";
                    tdLabel.textContent = r.label;
                    tr.appendChild(tdLabel);

                    @if (Model.Periodes != null && Model.Periodes.Any())
                    {
                                for (int iPer = 0; iPer < Model.Periodes.Count; iPer++)
                                {
                                                    @: {
                                                    @:     const td = document.createElement('td');
                                                    @:     td.style.minWidth = "90px";
                                                    @:     td.style.width = "90px";
                                                    @:     const input = document.createElement('input');
                                                    @:     input.type = "number";
                                                    @:     input.className = "mrp-grid-input" + (r.editable ? "" : " mrp-grid-input-disabled");
                                                    @:     input.style.width = "100%";
                                                    @:     input.style.minWidth = "70px";
                                                    @:     input.min = "0";
                                                    @:     input.step = "1";
                                                    @:     input.dataset.rowKey = r.key;
                                                    @:     input.dataset.periodIndex = "@iPer";
                                                    @:     if (r.key === "SP") {
                                                    @:         input.value = stockInitial.toString();
                                                    @:         input.disabled = true;
                                                    @:         input.className = "mrp-grid-input mrp-grid-input-disabled";
                                                    @:     } else {
                                                    @:         input.placeholder = r.editable ? "0" : "-";
                                                    @:         if (!r.editable) { input.disabled = true; }
                                                    @:     }
                                                    @:     input.dataset.articleCode = codeArticle;
                                                    @:     td.appendChild(input);
                                                    @:     tr.appendChild(td);
                                                    @: }
                                }
                    }
                    else
                    {
                                        @: {
                                        @:     const td = document.createElement('td');
                                        @:     td.style.minWidth = "90px";
                                        @:     td.style.width = "90px";
                                        @:     const input = document.createElement('input');
                                        @:     input.type = "number";
                                        @:     input.className = "mrp-grid-input" + (r.editable ? "" : " mrp-grid-input-disabled");
                                        @:     input.style.width = "100%";
                                        @:     input.style.minWidth = "70px";
                                        @:     input.min = "0";
                                        @:     input.step = "1";
                                        @:     input.dataset.rowKey = r.key;
                                        @:     input.dataset.periodIndex = "0";
                                        @:     if (r.key === "SP") {
                                        @:         input.value = stockInitial.toString();
                                        @:         input.disabled = true;
                                        @:         input.className = "mrp-grid-input mrp-grid-input-disabled";
                                        @:     } else {
                                        @:         input.placeholder = r.editable ? "0" : "-";
                                        @:         if (!r.editable) { input.disabled = true; }
                                        @:     }
                                        @:     input.dataset.articleCode = codeArticle;
                                        @:     td.appendChild(input);
                                        @:     tr.appendChild(td);
                                        @: }
                    }

                    tbody.appendChild(tr);
                });

                table.appendChild(tbody);
                block.appendChild(title);
                block.appendChild(table);
                levelRow.appendChild(block);

                const recalcFn = attachMrpLogicToTable(codeArticle, table, stockInitial, isPf);
                mrpTablesByArticle[codeArticle] = {
                    table: table,
                    stockInitial: stockInitial,
                    isPf: isPf,
                    recalc: recalcFn
                };
            });

            wrapper.appendChild(levelRow);
        });

        const rootInfo = mrpTablesByArticle[rootCodeArticle];
        if (rootInfo && rootInfo.recalc) {
            rootInfo.recalc();
        }

        if (typeof callbackAfterBuild === 'function') {
            callbackAfterBuild();
        }
    }

    function attachMrpLogicToTable(articleCode, table, stockInitial, isProductFini) {
        const inputs = table.querySelectorAll('input.mrp-grid-input');

        const recalc = function () {
            const perCount = table.querySelectorAll('thead th').length - 1;
            const BB = new Array(perCount).fill(0);
            const SP = new Array(perCount).fill(0);
            const BN = new Array(perCount).fill(0);
            const FIN = new Array(perCount).fill(0);
            const DEB = new Array(perCount).fill(0);
            const DEL = new Array(perCount).fill(0);

            inputs.forEach(function (inp) {
                const rowKey = inp.dataset.rowKey;
                const idx = parseInt(inp.dataset.periodIndex || "0", 10);
                if (isNaN(idx)) return;
                const val = inp.value === "" ? 0 : parseFloat(inp.value);
                if (rowKey === "BB") BB[idx] = isNaN(val) ? 0 : val;
                if (rowKey === "DEL") DEL[idx] = isNaN(val) ? 0 : val;
            });

            SP[0] = stockInitial - BB[0];
            if (SP[0] < 0) {
                BN[0] = -SP[0];
                FIN[0] = BN[0];
                SP[0] = 0;
            }
            for (let t = 1; t < perCount; t++) {
                SP[t] = SP[t - 1] + FIN[t] - BB[t];
                if (SP[t] < 0) {
                    BN[t] = -SP[t];
                    FIN[t] = BN[t];
                    SP[t] = 0;
                }
            }

            for (let t = 0; t < perCount; t++) {
                if (FIN[t] > 0) {
                    const d = DEL[t] || 0;
                    const startIdx = t - d;
                    if (startIdx >= 0) {
                        DEB[startIdx] += FIN[t];
                    }
                }
            }

            inputs.forEach(function (inp) {
                const rowKey = inp.dataset.rowKey;
                const idx = parseInt(inp.dataset.periodIndex || "0", 10);
                if (isNaN(idx)) return;
                if (rowKey === "SP") inp.value = SP[idx] || 0;
                if (rowKey === "BN") inp.value = BN[idx] || 0;
                if (rowKey === "FIN") inp.value = FIN[idx] || 0;
                if (rowKey === "DEB") inp.value = DEB[idx] || 0;
            });

            propagateToChildren(articleCode, DEB);
        };

        inputs.forEach(function (inp) {
            const rowKey = inp.dataset.rowKey;
            if (rowKey === "BB" || rowKey === "DEL") {
                inp.addEventListener('input', recalc);
            }
        });

        return recalc;
    }

    function propagateToChildren(parentCode, parentDebArray) {
        const children = mrpChildrenByParent[parentCode] || [];
        if (!children.length) return;

        children.forEach(function (rel) {
            const childCode = rel.childCode;
            const qParParent = rel.quantiteParParent || 1;

            const childInfo = mrpTablesByArticle[childCode];
            if (!childInfo) return;

            const table = childInfo.table;
            const inputs = table.querySelectorAll('input.mrp-grid-input');
            const perCount = table.querySelectorAll('thead th').length - 1;

            const newBB = new Array(perCount).fill(0);
            for (let t = 0; t < perCount; t++) {
                newBB[t] = (parentDebArray[t] || 0) * qParParent;
            }

            inputs.forEach(function (inp) {
                const rowKey = inp.dataset.rowKey;
                if (rowKey !== "BB") return;
                const idx = parseInt(inp.dataset.periodIndex || "0", 10);
                if (isNaN(idx)) return;
                inp.value = newBB[idx] || 0;
            });

            if (childInfo.recalc) {
                childInfo.recalc();
            }
        });
    }

    async function loadMrpTableauxFromServer(codeArticle) {
        if (!currentPlanId || !codeArticle) return;
        try {
            const url = mrpDetailPageUrl + `?handler=LoadMrpTableaux&planId=${currentPlanId}&codeArticle=${encodeURIComponent(codeArticle)}`;
            const resp = await fetch(url, { method: 'GET' });
            if (!resp.ok) return;
            const data = await resp.json();
            if (!Array.isArray(data) || data.length === 0) return;

            const info = mrpTablesByArticle[codeArticle];
            if (!info) return;
            const table = info.table;
            const inputs = table.querySelectorAll('input.mrp-grid-input');

            const perValues = {};
            data.forEach(d => {
                const idx = d.numeroPeriode ?? d.NumeroPeriode ?? 0;
                perValues[idx] = {
                    BB: d.besoinBrut ?? d.BesoinBrut ?? 0,
                    SP: d.stockPrevisionnel ?? d.StockPrevisionnel ?? 0,
                    BN: d.besoinNet ?? d.BesoinNet ?? 0,
                    FIN: d.finOrdre ?? d.FinOrdre ?? 0,
                    DEB: d.debutOrdre ?? d.DebutOrdre ?? 0,
                    DEL: d.delaiJours ?? d.DelaiJours ?? 0
                };
            });

            inputs.forEach(function (inp) {
                const rowKey = inp.dataset.rowKey;
                const idx = parseInt(inp.dataset.periodIndex || "0", 10);
                if (isNaN(idx)) return;
                const pv = perValues[idx];
                if (!pv) return;
                if (rowKey === "BB") inp.value = pv.BB;
                if (rowKey === "SP") inp.value = pv.SP;
                if (rowKey === "BN") inp.value = pv.BN;
                if (rowKey === "FIN") inp.value = pv.FIN;
                if (rowKey === "DEB") inp.value = pv.DEB;
                if (rowKey === "DEL") inp.value = pv.DEL;
            });

            if (info.recalc) {
                info.recalc();
            }
        } catch (e) {
            console.error('Erreur chargement MRP tableaux', e);
        }
    }

    function getAntiForgeryToken() {
        const form = document.getElementById('antiForgeryForm');
        if (!form) return '';
        const tokenInput = form.querySelector('input[name="__RequestVerificationToken"]');
        return tokenInput ? tokenInput.value : '';
    }

    async function saveCurrentMrpTables() {
        if (!currentPlanId) {
            alert('Plan introuvable.');
            return;
        }

        const token = getAntiForgeryToken();
        const payload = [];

        Object.keys(mrpTablesByArticle).forEach(codeArticle => {
            const info = mrpTablesByArticle[codeArticle];
            const table = info.table;
            const inputs = table.querySelectorAll('input.mrp-grid-input');
            const perCount = table.querySelectorAll('thead th').length - 1;

            const perRow = {};
            for (let i = 0; i < perCount; i++) {
                perRow[i] = { BB: 0, SP: 0, BN: 0, FIN: 0, DEB: 0, DEL: 0 };
            }

            inputs.forEach(function (inp) {
                const rowKey = inp.dataset.rowKey;
                const idx = parseInt(inp.dataset.periodIndex || "0", 10);
                if (isNaN(idx)) return;
                const val = inp.value === "" ? 0 : parseFloat(inp.value);
                if (!perRow[idx]) {
                    perRow[idx] = { BB: 0, SP: 0, BN: 0, FIN: 0, DEB: 0, DEL: 0 };
                }
                if (rowKey === "BB") perRow[idx].BB = isNaN(val) ? 0 : val;
                if (rowKey === "SP") perRow[idx].SP = isNaN(val) ? 0 : val;
                if (rowKey === "BN") perRow[idx].BN = isNaN(val) ? 0 : val;
                if (rowKey === "FIN") perRow[idx].FIN = isNaN(val) ? 0 : val;
                if (rowKey === "DEB") perRow[idx].DEB = isNaN(val) ? 0 : val;
                if (rowKey === "DEL") perRow[idx].DEL = isNaN(val) ? 0 : val;
            });

            Object.keys(perRow).forEach(k => {
                const idx = parseInt(k, 10);
                const v = perRow[idx];
                payload.push({
                    planId: currentPlanId,
                    codeArticle: codeArticle,
                    numeroPeriode: idx,
                    datePeriode: null,
                    besoinBrut: v.BB,
                    stockPrevisionnel: v.SP,
                    besoinNet: v.BN,
                    finOrdre: v.FIN,
                    debutOrdre: v.DEB,
                    delaiJours: v.DEL
                });
            });
        });

        try {
            const url = mrpDetailPageUrl + '?handler=SaveMrpTableaux';
            const resp = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(payload)
            });
            if (!resp.ok) {
                alert('Erreur HTTP lors de la sauvegarde MRP.');
                return;
            }
            const res = await resp.json();
            if (!res.ok) {
                alert('Erreur sauvegarde MRP: ' + (res.message || ''));
            } else {
                updateQuantitesALancerInMainGrid();
                alert('Tableaux MRP sauvegardes avec succes.');
            }
        } catch (e) {
            console.error('Erreur sauvegarde MRP', e);
            alert('Erreur technique lors de la sauvegarde MRP.');
        }
    }

    function updateQuantitesALancerInMainGrid() {
        Object.keys(mrpTablesByArticle).forEach(codeArticle => {
            const info = mrpTablesByArticle[codeArticle];
            if (!info || !info.table) return;

            const table = info.table;
            const inputs = table.querySelectorAll('input.mrp-grid-input');

            let sommeDeb = 0;
            inputs.forEach(inp => {
                if (inp.dataset.rowKey === "DEB") {
                    const val = inp.value === "" ? 0 : parseFloat(inp.value);
                    if (!isNaN(val)) {
                        sommeDeb += val;
                    }
                }
            });

            const allRows = document.querySelectorAll('tr.mrp-row-root, tr.mrp-row-child');

            allRows.forEach(row => {
                const refCell = row.querySelector('td:nth-child(3)');
                if (!refCell) return;
                const codeInRow = (refCell.textContent || '').trim();
                if (codeInRow !== codeArticle) return;

                const qteCell = row.querySelector('td:nth-child(7)');
                if (qteCell) {
                    qteCell.textContent = sommeDeb.toString();
                }
            });
        });
    }

