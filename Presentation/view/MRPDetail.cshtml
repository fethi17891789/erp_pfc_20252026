@page
@model erp_pfc_20252026.Pages.MRPDetailModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Detail planification MRP";

    var lignes = Model.Lignes ?? new List<erp_pfc_20252026.Pages.MRPDetailModel.LigneMrpVm>();
    var planifOK = Model.PlanifAutoriseLancement();
    var racines = lignes.Where(l => l.Niveau == 0).ToList();

    var dictByCode = lignes
        .Where(l => !string.IsNullOrEmpty(l.CodeArticle))
        .GroupBy(l => l.CodeArticle)
        .ToDictionary(g => g.Key, g => g.First());

    var enfantsParRootList = new Dictionary<string, List<erp_pfc_20252026.Pages.MRPDetailModel.LigneMrpVm>>();

    foreach (var root in racines)
    {
        var liste = new List<erp_pfc_20252026.Pages.MRPDetailModel.LigneMrpVm>();

        foreach (var ligne in lignes.Where(l => l.Niveau > 0))
        {
            var parent = ligne.ParentCodeArticle;
            var appartient = false;

            while (!string.IsNullOrEmpty(parent))
            {
                if (parent == root.CodeArticle)
                {
                    appartient = true;
                    break;
                }

                if (!dictByCode.TryGetValue(parent, out var parentLigne))
                    break;

                parent = parentLigne.ParentCodeArticle;
            }

            if (appartient)
            {
                liste.Add(ligne);
            }
        }

        enfantsParRootList[root.CodeArticle] = liste
            .OrderBy(l => l.Niveau)
            .ThenBy(l => l.CodeArticle)
            .ToList();
    }
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" />
<link rel="stylesheet" href="~/css/Common.css" />
<link rel="stylesheet" href="~/css/Home.css" />
<link rel="stylesheet" href="~/css/Fabrication.css" />

<div class="erp-shell">
    <!-- BARRE LATERALE GAUCHE -->
