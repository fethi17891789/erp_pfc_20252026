    <!-- CONTENU PRINCIPAL -->
    <main class="erp-main">
        <header class="erp-header">
            <div class="header-left">
                <h1>Detail planification MRP</h1>
                <p>
                    Visualisation des besoins pour
                    <strong>@Model.Planification?.Reference</strong>.
                </p>
            </div>

            <div class="header-right">
                <div class="header-db">
                    <span class="header-db-label">Base active</span>
                    <span class="header-db-name">erp_db</span>
                </div>

                <button class="header-btn" type="button" onclick="window.location.href='@Url.Page("/MRP")'">
                    <svg style="width: 14px; height: 14px; display: inline-block; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="15 18 9 12 15 6"></polyline>
                        <path d="M20 19V5"></path>
                    </svg>
                    Retour aux planifications
                </button>
                <button class="header-profile-btn" type="button">
                    <div class="header-avatar">P</div>
                </button>
            </div>
        </header>

        <section class="erp-content" style="display:flex; flex-direction:column; gap:16px;">
            <!-- RECTANGLE RESUME -->
            <div class="mrp-plan-resume">
                <div class="mrp-plan-resume-left">
                    <div class="mrp-plan-resume-header">
                        <span class="mrp-plan-chip">
                            Planification MRP
                        </span>
                        <span class="mrp-plan-ref">
                            Ref : <strong>@Model.Planification?.Reference</strong>
                        </span>
                    </div>

                    <div class="mrp-plan-resume-infos">
                        <div>
                            Horizon :
                            <strong>@Model.Planification?.HorizonJours jours</strong>
                        </div>
                        <div>
                            Periode :
                            <strong>
                                @Model.Planification?.DateDebut.ToString("dd/MM/yyyy")
                                ->
                                @Model.Planification?.DateFin.ToString("dd/MM/yyyy")
                            </strong>
                        </div>
                        <div>
                            Statut :
                            <span class="@Model.GetStatutBadgeCss()">
                                @Model.Planification?.Statut
                            </span>
                        </div>
                        <div>
                            Produits planifies :
                            <strong>@Model.NbProduitsPlanifies</strong>
                        </div>
                        <div>
                            Propositions OF :
                            <strong>@Model.NbPropositionsOF</strong>
                        </div>
                        <div>
                            Propositions OA :
                            <strong>@Model.NbPropositionsOA</strong>
                        </div>
                    </div>
                </div>

                <div class="mrp-plan-resume-actions">
                    <form method="post" asp-page-handler="Enregistrer" style="display:inline;">
                        <input type="hidden" name="planId" value="@Model.Planification?.Id" />
                        <button type="submit"
                                class="btn-secondary"
                                style="min-width:170px;"
                                @(Model.Planification?.Statut == "Terminee" ? "disabled" : "")>
                            Enregistrer
                        </button>
                    </form>
                    <form method="post" asp-page-handler="Annuler" style="display:inline;">
                        <input type="hidden" name="planId" value="@Model.Planification?.Id" />
                        <button type="submit"
                                class="btn-secondary"
                                style="min-width:170px;"
                                @(Model.Planification?.Statut == "Terminee" ? "disabled" : "")>
                            Annuler
                        </button>
                    </form>
                </div>
            </div>

            <!-- BARRE D INFO -->
            <div style="display:flex; align-items:center; justify-content:space-between; margin-top:4px;">
                <div style="font-size:0.9rem; color:var(--text-muted);">
                    @lignes.Count lignes MRP (produits + composants)
                </div>
            </div>

            <!-- TABLEAU DES LIGNES -->
            <div class="erp-card mrp-table-card">
                <div class="mrp-table-wrapper">
                    <table class="erp-table mrp-table">
                        <thead>
                            <tr>
                                <th style="width:40px;"></th>
                                <th style="width:60px;">Niv.</th>
                                <th style="width:130px;">Reference</th>
                                <th>Nom produit</th>
                                <th style="width:120px;">Type</th>
                                <th style="width:110px;">Stock dispo</th>
                                <th style="width:110px;">Qte a lancer</th>
                                <th style="width:120px;">Prix</th>
                                <th style="width:130px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!lignes.Any() || !racines.Any())
                            {
                                <tr>
                                    <td colspan="9" style="text-align:center; padding:32px; color:var(--text-muted);">
                                        Aucune ligne MRP a afficher pour le moment.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var root in racines)
                                {
                                    var isOFRoot = root.EstOrdreFabrication;
                                    var isOARoot = root.EstOrdreAchat;
                                    var boutonTexteRoot = isOFRoot ? "Lancer OF" : (isOARoot ? "Lancer OA" : "");
                                    var boutonDisabledRoot = !planifOK || root.QuantiteALancer <= 0 || string.IsNullOrEmpty(boutonTexteRoot);
                                    var boutonTitleRoot = "";

                                    if (!planifOK)
                                    {
                                        boutonTitleRoot = "Impossible de lancer un ordre : la planification n est pas en attente.";
                                    }
                                    else if (root.QuantiteALancer <= 0)
                                    {
                                        boutonTitleRoot = "Quantite a lancer nulle ou negative.";
                                    }

                                    <tr class="mrp-row mrp-row-root"
                                        data-article="@root.CodeArticle"
                                        data-label="@root.LibelleArticle"
                                        onclick="openMrpPopup('@root.CodeArticle', '@root.LibelleArticle')">
                                        <td onclick="event.stopPropagation();">
                                            <button type="button"
                                                    class="mrp-chevron-btn hover-lift-sm"
                                                    onclick="toggleBom('@root.CodeArticle'); event.stopPropagation();">
                                                <span id="chevron-@root.CodeArticle">▸</span>
                                            </button>
                                        </td>
                                        <td>@root.Niveau</td>
                                        <td>@root.CodeArticle</td>
                                        <td>@root.LibelleArticle</td>
                                        <td>@root.TypeProduit</td>
                                        <td>@root.StockDisponible</td>
                                        <td>@root.QuantiteALancer</td>
                                        <td>@root.Prix.ToString("N2")</td>
                                        <td onclick="event.stopPropagation();">
                                            @if (isOFRoot)
                                            {
                                                <form method="post"
                                                      asp-page-handler="LancerOF"
                                                      style="display:inline;"
                                                      onsubmit="event.stopPropagation();">
                                                    <input type="hidden" name="planId" value="@Model.Planification?.Id" />
                                                    <input type="hidden" name="codeArticle" value="@root.CodeArticle" />
                                                    <input type="hidden" name="quantite" value="@root.QuantiteALancer" />
                                                    <button type="submit"
                                                            class="btn-primary"
                                                            style="width:110px; padding-inline:8px; font-size:0.8rem;"
                                                            @(boutonDisabledRoot ? "disabled" : "")
                                                            title="@boutonTitleRoot">
                                                        Lancer OF
                                                    </button>
                                                </form>
                                            }
                                            else if (isOARoot)
                                            {
                                                <button type="button"
                                                        class="btn-primary"
                                                        style="width:110px; padding-inline:8px; font-size:0.8rem;"
                                                        @(boutonDisabledRoot ? "disabled" : "")
                                                        title="@boutonTitleRoot"
                                                        onclick="if(!this.disabled){openOAPopup('@root.CodeArticle','@root.LibelleArticle','@root.QuantiteALancer');}">
                                                    Lancer OA
                                                </button>
                                            }
                                        </td>
                                    </tr>

                                    if (enfantsParRootList.TryGetValue(root.CodeArticle, out var enfantsDuRoot) && enfantsDuRoot.Any())
                                    {
                                        foreach (var c in enfantsDuRoot)
                                        {
                                            var isOF = c.EstOrdreFabrication;
                                            var isOA = c.EstOrdreAchat;
                                            var boutonTexte = isOF ? "Lancer OF" : (isOA ? "Lancer OA" : "");
                                            var boutonDisabled = !planifOK || c.QuantiteALancer <= 0 || string.IsNullOrEmpty(boutonTexte);
                                            var boutonTitle = "";

                                            if (!planifOK)
                                            {
                                                boutonTitle = "Impossible de lancer un ordre : la planification n est pas en attente.";
                                            }
                                            else if (c.QuantiteALancer <= 0)
                                            {
                                                boutonTitle = "Quantite a lancer nulle ou negative.";
                                            }

                                            <tr class="mrp-row mrp-row-child"
                                                data-parent="@c.ParentCodeArticle"
                                                data-root="@root.CodeArticle">
                                                <td></td>
                                                <td>@c.Niveau</td>
                                                <td>@c.CodeArticle</td>
                                                <td>@c.LibelleArticle</td>
                                                <td>@c.TypeProduit</td>
                                                <td>@c.StockDisponible</td>
                                                <td>@c.QuantiteALancer</td>
                                                <td>@c.Prix.ToString("N2")</td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(boutonTexte))
                                                    {
                                                        if (isOF)
                                                        {
                                                            <button type="button"
                                                                    class="btn-primary"
                                                                    style="width:110px; padding-inline:8px; font-size:0.8rem;"
                                                                    @(boutonDisabled ? "disabled" : "")
                                                                    title="@boutonTitle"
                                                                    onclick="if(!this.disabled){alert('TODO: Lancer OF pour @c.CodeArticle');}">
                                                                Lancer OF
                                                            </button>
                                                        }
                                                        else if (isOA)
                                                        {
                                                            <button type="button"
                                                                    class="btn-primary"
                                                                    style="width:110px; padding-inline:8px; font-size:0.8rem;"
                                                                    @(boutonDisabled ? "disabled" : "")
                                                                    title="@boutonTitle"
                                                                    onclick="if(!this.disabled){openOAPopup('@c.CodeArticle','@c.LibelleArticle','@c.QuantiteALancer');}">
                                                                Lancer OA
                                                            </button>
                                                        }
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- TABLEAU DES FICHIERS D'ORDRES DE FABRICATION -->
            <div class="erp-card mrp-table-card" style="margin-top: 12px;">
                <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 16px 0 16px;">
                    <div>
                        <h3 style="margin:0; font-size:0.95rem;">Fichiers d'ordres de fabrication</h3>
                        <p style="margin:2px 0 0; font-size:0.8rem; color:var(--text-muted);">
                            Liste des fichiers PDF generes pour cette planification.
                        </p>
                    </div>
                </div>

                <div class="mrp-table-wrapper" style="max-height: 24vh;">
                    <table class="erp-table mrp-table">
                        <thead>
                            <tr>
                                <th style="width: 25%;">Produit</th>
                                <th style="width: 25%;">Reference OF</th>
                                <th style="width: 20%;">Date de l'ordre</th>
                                <th style="width: 30%;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.FichiersOF != null && Model.FichiersOF.Any())
                            {
                                foreach (var f in Model.FichiersOF)
                                {
                                    <tr>
                                        <td>@f.CodeArticle</td>
                                        <td>@f.ReferenceOF</td>
                                        <td>@f.DateOrdre.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <div style="display:flex; gap:8px; justify-content:flex-start;">
                                                <a asp-page-handler="DownloadOF"
                                                   asp-route-id="@f.Id"
                                                   class="btn-secondary"
                                                   style="padding:6px 14px; font-size:0.8rem; margin-top:0;"
                                                   target="_blank">
                                                    Visualiser PDF
                                                </a>
                                                <a asp-page-handler="DownloadOF"
                                                   asp-route-id="@f.Id"
                                                   class="btn-primary"
                                                   style="padding:6px 14px; font-size:0.8rem; margin-top:0;">
                                                    Telecharger
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" style="text-align:center; padding:20px; font-size:0.85rem; color:var(--text-muted);">
                                        Aucun fichier d'ordre de fabrication enregistre pour le moment.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </section>
    </main>
</div>

<!-- POPUP MRP PAR PRODUIT -->
<div id="mrp-product-overlay" class="logout-overlay" style="display:none;">
    <div class="logout-modal" style="max-width: 1000px; width: 95%; max-height: 90vh; display:flex; flex-direction:column;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
            <div>
                <h3 style="margin-bottom:4px;">Tableaux MRP produit / composants</h3>
                <p id="mrp-product-header"
                   style="font-size:0.9rem; color:var(--text-muted);">
                    Produit : <strong id="mrp-product-ref"></strong> - <span id="mrp-product-name"></span>
                </p>
            </div>
            <button type="button"
                    class="mrp-close-btn"
                    onclick="closeMrpPopup()">
                X
            </button>
        </div>

        <div style="font-size:0.8rem; color:var(--text-muted); margin-bottom:8px;">
            Les colonnes representent les periodes (jours) selon la configuration de la planification.
            La ligne <strong>Besoin brut (BB)</strong> est saisissable uniquement pour le produit fini, et la ligne <strong>Delai</strong> est saisissable pour tous.
        </div>

        <div class="mrp-grid-wrapper" id="mrp-grid-wrapper">
            @* Contenu genere dynamiquement en JS *@
        </div>

        <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:12px;">
            <button type="button" class="btn-secondary" onclick="closeMrpPopup()">Fermer</button>
            <button type="button"
                    class="btn-primary"
                    onclick="saveCurrentMrpTables()">
                Appliquer les valeurs
            </button>
        </div>
    </div>
</div>

<!-- POPUP PROPOSITION ORDRE D'ACHAT -->
<div id="oa-overlay" class="logout-overlay" style="display:none;">
    <div class="logout-modal" style="max-width: 480px; width: 95%; display:flex; flex-direction:column; gap:12px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <h3 style="margin-bottom:4px;">Proposition d'ordre d'achat</h3>
                <p style="margin:0; font-size:0.85rem; color:var(--text-muted);">
                    Produit : <strong id="oa-product-ref"></strong> -
                    <span id="oa-product-name"></span><br />
                    Besoin : <strong id="oa-quantity"></strong> unite(s)
                </p>
            </div>
            <button type="button"
                    class="mrp-close-btn"
                    onclick="closeOAPopup()">
                X
            </button>
        </div>

        <div style="display:flex; flex-direction:column; gap:6px;">
            <label for="oa-user-search" style="font-size:0.85rem; color:var(--text-muted);">
                Envoyer a un utilisateur
            </label>
            <input id="oa-user-search"
                   type="text"
                   class="mrp-grid-input"
                   placeholder="Rechercher un nom de profil..."
                   autocomplete="off"
                   oninput="onOAUserSearchInput(this.value)" />
            <div id="oa-user-suggestions"
                 style="max-height:160px; overflow:auto; margin-top:4px; border-radius:8px; border:1px solid var(--border-soft); background:rgba(15,23,42,0.98); display:none;">
                @* Sera rempli en JS (liste de profils) *@
            </div>
            <input type="hidden" id="oa-selected-user-id" value="" />
        </div>

        <div style="display:flex; flex-direction:column; gap:6px;">
            <label for="oa-message" style="font-size:0.85rem; color:var(--text-muted);">
                Message (optionnel)
            </label>
            <textarea id="oa-message"
                      rows="3"
                      class="mrp-grid-input"
                      style="resize:vertical;"
                      placeholder="Ajouter un commentaire pour la demande d'achat..."></textarea>
        </div>

        <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:4px;">
            <button type="button"
                    class="btn-secondary"
                    onclick="closeOAPopup()">
                Annuler
            </button>
            <button type="button"
                    class="btn-primary"
                    onclick="sendOAProposal()">
                Envoyer
            </button>
        </div>
    </div>
</div>

<!-- POPUP DECONNEXION -->
<div id="logout-overlay" class="logout-overlay" style="display:none;">
    <div class="logout-modal">
        <h3>Confirmer la deconnexion</h3>
        <p>Voulez-vous vraiment vous deconnecter et revenir a l ecran de choix du profil ?</p>

        <form method="post" asp-page-handler="Logout" class="logout-modal-actions">
            <button type="button" class="btn-secondary" onclick="closeLogoutModal()">Non, rester</button>
            <button type="submit" class="btn-primary">Oui, se deconnecter</button>
        </form>
    </div>
</div>

<script src="~/js/Home.js"></script>

<form id="antiForgeryForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<script>
    const mrpBomInfos = @Html.Raw(Model.BomInfosJson ?? "[]");
    const stockMrpByArticle = @Html.Raw(Model.StockMrpJson ?? "[]");
    const mrpBomDetails = @Html.Raw(Model.BomDetailsJson ?? "[]");
    const mrpBomRatios = @Html.Raw(Model.BomRatiosJson ?? "[]");

    const mrpTablesByArticle = {};
    const mrpChildrenByParent = {};

    const currentPlanId = @Model.Planification?.Id ?? 0;
    const mrpDetailPageUrl = '@Url.Page("MRPDetail")';

    mrpBomRatios.forEach(function (r) {
        const parent = r.parentCodeArticle || r.ParentCodeArticle;
        const child = r.enfantCodeArticle || r.EnfantCodeArticle;
        const qty = r.quantiteParParent || r.QuantiteParParent || 1;
        if (!parent || !child) return;
        if (!mrpChildrenByParent[parent]) {
            mrpChildrenByParent[parent] = [];
        }
        mrpChildrenByParent[parent].push({
            childCode: child,
            quantiteParParent: qty
        });
    });

    function findStockForArticle(codeArticle) {
        if (!codeArticle) return 0;
        const item = stockMrpByArticle.find(x =>
            x.codeArticle === codeArticle ||
            x.CodeArticle === codeArticle);
        return item ? (item.stockDisponible ?? item.StockDisponible ?? 0) : 0;
