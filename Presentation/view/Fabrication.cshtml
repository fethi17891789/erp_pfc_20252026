@page
@model erp_pfc_20252026.Pages.FabricationModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Module Fabrication";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Fabrication.css" />
}

@section HeaderLeft {
    <h1>Module Fabrication</h1>
    <p>Gestion des nomenclatures et ordres de production.</p>
}

<section class="erp-content">
            <div class="section-header">
                <h2>Fonctionnalités de fabrication</h2>
            </div>

            <div class="modules-grid">
                <!-- Carte Produits -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <!-- Icône boîte / produit -->
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="7" width="18" height="13" rx="2" ry="2"></rect>
                                <path d="M16 3H8v4h8V3z"></path>
                            </svg>
                        </div>
                        <span class="module-badge">Produits</span>
                    </div>
                    <h3>Produits</h3>
                    <p>Créer et gérer les fiches produits avant leur nomenclature.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">Actif</span>
                        <a asp-page="/ProduitCreate" class="module-action-link">
                            <button class="module-action" type="button">Ouvrir</button>
                        </a>
                    </div>
                </article>

                <!-- Carte BOM -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <!-- Icône cube / structure -->
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="12 2 19 7 12 12 5 7 12 2"></polyline>
                                <polyline points="5 7 5 17 12 22 19 17 19 7"></polyline>
                                <line x1="12" y1="12" x2="12" y2="22"></line>
                            </svg>
                        </div>
                        <span class="module-badge">BOM</span>
                    </div>
                    <h3>BOM (Nomenclature)</h3>
                    <p>Définir la structure des produits et des composants.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">Actif</span>
                        <a asp-page="/BOM" class="module-action-link">
                            <button class="module-action" type="button">Ouvrir</button>
                        </a>
                    </div>
                </article>

                <!-- NOUVELLE CARTE MRP - Planification -->
                <article class="module-tile">
                    <div class="module-tile-header">
                        <div class="module-circle">
                            <!-- Icône calendrier + flèches (planification MRP) -->
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                                <!-- Flèches MRP spécifiques -->
                                <polyline points="9,14 12,17 15,14"></polyline>
                                <line x1="12" y1="17" x2="12" y2="20"></line>
                            </svg>
                        </div>
                        <span class="module-badge">MRP</span>
                    </div>
                    <h3>Planification MRP</h3>
                    <p>Calcul des besoins nets, ordres de fabrication et approvisionnements automatisés.</p>
                    <div class="module-tile-footer">
                        <span class="module-status-dot"></span>
                        <span class="module-status-text">Actif</span>
                        <a asp-page="/MRP" class="module-action-link">
                            <button class="module-action" type="button">Ouvrir</button>
                        </a>
                    </div>
                </article>
            </div>
        </section>
