@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="@Antiforgery.GetAndStoreTokens(HttpContextAccessor.HttpContext!).RequestToken" />
    <title>@ViewData["Title"] - SKYRA</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/images/favicon-32x32.png" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="128x128" href="~/images/favicon-128x128.png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/favicon-128x128.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/fonts/plus-jakarta-sans.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Home.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="erp-shell" id="erp-shell">
        <script>
            if (localStorage.getItem('sidebar-collapsed') === 'true') {
                document.getElementById('erp-shell').classList.add('sidebar-collapsed');
            }
        </script>
        <!-- BARRE LATERALE GAUCHE -->
        <aside class="erp-sidebar">
            @{
                var currentUserLogin = HttpContextAccessor.HttpContext?.Session.GetString("CurrentUserLogin") ?? "SKYRA";
                var currentUserInitial = currentUserLogin.Length > 0 ? currentUserLogin[0].ToString().ToUpper() : "S";
            }
            <div class="erp-logo">
                <span class="erp-logo-mark">@currentUserInitial</span>
                <span class="erp-logo-text">@currentUserLogin</span>
            </div>

            <nav class="erp-nav">
                <a asp-page="/Home" class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Home" ? "nav-item-active" : "")">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                    <span>Accueil</span>
                </a>
                <!-- MODULES (ACCORDION) -->
                <div class="nav-group">
                    <button class="nav-item nav-item-toggle" type="button" onclick="toggleNavGroup('modules')">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M6 9h12M6 12h12M6 15h12M3 3h18a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"></path>
                        </svg>
                        <span>Modules</span>
                        <svg class="nav-chevron" id="chevron-modules" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </button>
                    <div class="nav-sub" id="nav-sub-modules">
                        <!-- FABRICATION (SOUS-ACCORDION) -->
                        <div class="nav-group">
                            <button class="nav-sub-item nav-item-toggle" type="button" onclick="event.stopPropagation(); toggleNavGroup('fabrication')">
                                <svg class="nav-icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M2 20h20M5 20V10l7-6 7 6v10"></path>
                                    <path d="M9 20v-4h6v4"></path>
                                </svg>
                                <span>Fabrication</span>
                                <svg class="nav-chevron" id="chevron-fabrication" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <polyline points="6 9 12 15 18 9"></polyline>
                                </svg>
                            </button>
                            <div class="nav-sub nav-sub-nested" id="nav-sub-fabrication">
                                <a asp-page="/BOM" class="nav-sub-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/BOM" ? "nav-sub-link-active" : "")">
                                    <span class="nav-dot"></span> Nomenclatures (BOM)
                                </a>
                                <a asp-page="/ProduitCreate" class="nav-sub-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/ProduitCreate" ? "nav-sub-link-active" : "")">
                                    <span class="nav-dot"></span> Produits
                                </a>
                                <a asp-page="/MRP" class="nav-sub-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/MRP" || ViewContext.RouteData.Values["page"]?.ToString() == "/MRPDetail" ? "nav-sub-link-active" : "")">
                                    <span class="nav-dot"></span> Planification MRP
                                </a>
                            </div>
                        </div>
                        <!-- TRACKING -->
                        <a asp-page="/Logistique/Index" class="nav-sub-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Logistique/Index" ? "nav-sub-link-active" : "")">
                            <svg class="nav-icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="10" r="3"></circle>
                                <path d="M12 2a8 8 0 0 0-8 8c0 5.4 8 12 8 12s8-6.6 8-12a8 8 0 0 0-8-8z"></path>
                            </svg>
                            <span>Tracking & Logistique</span>
                        </a>
                        <!-- RSE / ENVIRONNEMENT -->
                        <a asp-page="/Logistique/Environnement" class="nav-sub-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Logistique/Environnement" ? "nav-sub-link-active" : "")">
                            <svg class="nav-icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M2 20c4-8 8-12 10-12s6 4 10 12"></path>
                                <path d="M12 8c0-4 2-6 4-6-2 2-2 4 0 6-2-2-4-2-4 0z"></path>
                            </svg>
                            <span>Bilan Carbone RSE</span>
                        </a>
                        
                        <!-- ANNUAIRE CRM -->
                        <a asp-page="/AnnuaireList" class="nav-sub-item @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Annuaire") == true ? "nav-sub-link-active" : "")">
                            <svg class="nav-icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="7" r="4"></circle>
                                <path d="M5 22v-2a7 7 0 0 1 14 0v2"></path>
                            </svg>
                            <span>Annuaire (CRM)</span>
                        </a>
                    </div>
                </div>

                <button class="nav-item" type="button">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    <span>Profils</span>
                </button>

            </nav>

            <div class="erp-sidebar-footer">
                <button class="sidebar-quick" type="button">
                    <svg style="width: 14px; height: 14px; display: inline-block; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="15" x2="12" y2="21" />
                        <line x1="15" y1="11" x2="21" y2="12" />
                    </svg>
                    Nouveau profil
                </button>
                <button class="sidebar-quick secondary" type="button" onclick="openLogoutModal()">
                    <svg style="width: 14px; height: 14px; display: inline-block; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <polyline points="16 3 16 10 13 7"></polyline>
                        <path d="M16 10v7a2 2 0 0 1-2 2h-2"></path>
                    </svg>
                    Déconnexion
                </button>
            </div>
        </aside>

        <!-- CONTENU PRINCIPAL -->
        <main class="erp-main">
            <!-- HEADER GLOBAL -->
            <header class="erp-header">
                <div class="header-left" style="display: flex; align-items: center; gap: 12px;">
                    <button class="header-btn" type="button" onclick="toggleSidebar()" title="Rétracter/Ouvrir la barre latérale">
                        <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="3" y1="12" x2="21" y2="12"></line>
                            <line x1="3" y1="6" x2="21" y2="6"></line>
                            <line x1="3" y1="18" x2="21" y2="18"></line>
                        </svg>
                    </button>
                    <div>
                        @await RenderSectionAsync("HeaderLeft", required: false)
                    </div>
                </div>

                <div class="header-right">

                    <!-- BOUTON MESSAGERIE AVEC LIEN -->
                    <a asp-page="/Messagerie" class="header-btn-link">
                        <button class="header-btn" type="button" id="btn-messagerie">
                            <svg style="width: 14px; height: 14px; display: inline-block; margin-right: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8.5z"></path>
                            </svg>
                            Messagerie
                        </button>
                    </a>
                    <!-- FIN BOUTON MESSAGERIE -->

                    <!-- BOUTON NOTIFICATIONS (CLOCHE) -->
                    <div class="header-notif-wrapper">
                        <button class="header-btn header-notif-btn" type="button" id="header-notification-btn" onclick="toggleNotifDrawer()">
                            <svg style="width:16px;height:16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                            </svg>
                        </button>
                        <span id="notif-badge" class="notif-badge">0</span>
                        
                        <!-- Le petit tiroir qui descend à la réception d'un message -->
                        <div id="iphone-mini-toast" class="iphone-mini-toast"></div>

                        <!-- Historique des notifications -->
                        <div id="notif-drawer" class="notif-drawer">
                            <div class="notif-drawer-header">
                                <h3>Notifications</h3>
                                <button onclick="clearAllNotifications()" style="background:none;border:none;color:var(--accent,#7B5EFF);font-size:11px;cursor:pointer;">Tout effacer</button>
                            </div>
                            <div id="notif-list" class="notif-list">
                                <div class="notif-empty">Aucune notification</div>
                            </div>
                        </div>
                    </div>

                    <button class="header-profile-btn" type="button">
                        <div class="header-avatar">P</div>
                    </button>
                </div>
            </header>

            <!-- CONTENU SPECIFIQUE A LA PAGE -->
            @RenderBody()

        </main>
    </div>
    
    @RenderSection("Popups", required: false)

    <!-- POPUP DE DÉCONNEXION -->
    <div id="logout-overlay" class="logout-overlay" style="display:none;">
        <div class="logout-modal">
            <h3>Confirmer la déconnexion</h3>
            <p>Voulez-vous vraiment vous déconnecter et revenir à l'écran de choix du profil&nbsp;?</p>

            <form method="post" action="/logout" class="logout-modal-actions">
                <button type="button" class="btn-secondary" onclick="closeLogoutModal()">Non, rester</button>
                <button type="submit" class="btn-primary">Oui, se déconnecter</button>
            </form>
        </div>
    </div>

    <script>
        function openLogoutModal() {
            var overlay = document.getElementById('logout-overlay');
            if(overlay) overlay.style.display = 'flex';
            document.body.classList.add('logout-blur-active');
        }
        function closeLogoutModal() {
            var overlay = document.getElementById('logout-overlay');
            if(overlay) overlay.style.display = 'none';
            document.body.classList.remove('logout-blur-active');
        }
        function toggleSidebar() {
            var shell = document.getElementById('erp-shell');
            if(shell) {
                shell.classList.toggle('sidebar-collapsed');
                var isCollapsed = shell.classList.contains('sidebar-collapsed');
                localStorage.setItem('sidebar-collapsed', isCollapsed ? 'true' : 'false');
            }
        }
        function toggleNavGroup(groupName) {
            var sub = document.getElementById('nav-sub-' + groupName);
            var chevron = document.getElementById('chevron-' + groupName);
            if (!sub) return;
            var isOpen = sub.classList.contains('nav-sub-open');
            if (isOpen) {
                sub.classList.remove('nav-sub-open');
                if (chevron) chevron.classList.remove('nav-chevron-open');
                localStorage.setItem('nav-' + groupName, 'closed');
            } else {
                sub.classList.add('nav-sub-open');
                if (chevron) chevron.classList.add('nav-chevron-open');
                localStorage.setItem('nav-' + groupName, 'open');
            }
        }
        // Restore nav group states on load
        (function() {
            ['modules', 'fabrication'].forEach(function(g) {
                if (localStorage.getItem('nav-' + g) === 'open') {
                    var sub = document.getElementById('nav-sub-' + g);
                    var chevron = document.getElementById('chevron-' + g);
                    if (sub) sub.classList.add('nav-sub-open');
                    if (chevron) chevron.classList.add('nav-chevron-open');
                }
            });
        })();
    </script>
    @{
        var currentUserId = HttpContextAccessor.HttpContext?.Session.GetInt32("CurrentUserId") ?? 0;
    }
    <script>
        window.currentUserIdFromServer   = @currentUserId;
        window.currentUserNameFromServer = "@currentUserLogin";
    </script>
    <input type="file" id="drawer-img-input" accept="image/*" style="display:none;">

    @if (currentUserId > 0)
    {
        <script src="~/lib/signalr/signalr.min.js" asp-append-version="true"></script>
        <script src="~/lib/marked/marked.min.js" asp-append-version="true"></script>
        <script src="~/js/Notifications.js" asp-append-version="true"></script>
        <script src="~/js/Presence.js" asp-append-version="true"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/EasterEgg.js" asp-append-version="true"></script>
</body>
</html>
