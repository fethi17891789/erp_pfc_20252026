@page
@model erp_pfc_20252026.Pages.MRPConfigModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Module MRP";
}


            <div class="mrp-config-card">
                <h2>Configuration MRP</h2>
                <p>Définir l'horizon de planification par défaut du module MRP.</p>

                <form method="post" asp-page-handler="SaveConfig" class="mrp-config-form">
                    <div class="form-group">
                        <label asp-for="Input.HorizonParDefautJours" class="control-label"></label>
                        <input asp-for="Input.HorizonParDefautJours"
                               class="form-control"
                               type="number"
                               min="1"
                               max="365" />
                        <span asp-validation-for="Input.HorizonParDefautJours" class="text-danger"></span>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn-primary">Enregistrer</button>
                    </div>
                </form>
            </div>
        </section>

