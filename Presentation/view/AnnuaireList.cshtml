@page
@model erp_pfc_20252026.Pages.AnnuaireListModel
@using Donnees
@using System.Text.Json
@{
    ViewData["Title"] = "Annuaire Contacts";

    // Sérialisation des données pour le graphe (inlinée, pas de fetch supplémentaire)
    var graphNodes = Model.Contacts.Select(c => new {
        id = c.Id,
        name = c.FullName,
        roles = (int)c.Roles,
        domain = !string.IsNullOrEmpty(c.Website)
            ? c.Website.Replace("https://","").Replace("http://","").Split('/')[0]
            : (!string.IsNullOrEmpty(c.Email) && c.Email.Contains('@') ? c.Email.Split('@')[1] : ""),
        email = c.Email ?? "",
        initials = c.FullName.Length >= 2 ? c.FullName[..2].ToUpper() : (c.FullName.Length == 1 ? c.FullName.ToUpper() : "?")
    });
    var graphEdges = Model.Relations.Select(r => new {
        source = r.SourceContactId,
        target = r.TargetContactId,
        type = r.RelationType
    });
    var graphDataJson = JsonSerializer.Serialize(new { nodes = graphNodes, edges = graphEdges });

    // Données contacts pour JS (filtrage/tri côté client)
    var contactsJson = JsonSerializer.Serialize(Model.Contacts.Select(c => new {
        id       = c.Id,
        name     = c.FullName,
        email    = c.Email ?? "",
        phone    = c.Phone ?? "",
        website  = c.Website ?? "",
        roles    = (int)c.Roles,
        date     = c.DateCreation.ToString("dd/MM/yyyy"),
        dateTs   = c.DateCreation.Ticks,
        initials = c.FullName.Length >= 2 ? c.FullName[..2].ToUpper() : "?",
        domain   = !string.IsNullOrEmpty(c.Website)
            ? c.Website.Replace("https://","").Replace("http://","").Split('/')[0]
            : (!string.IsNullOrEmpty(c.Email) && c.Email.Contains('@') ? c.Email.Split('@')[1] : "")
    }));
}

@section Styles {
<style>
/* ─── TOOLBAR ───────────────────────────────────────────── */
.ann-toolbar {
    display: flex; align-items: center; gap: 10px; margin-bottom: 20px;
}
/* Dropdown filtre */
.filter-dd-item { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 8px 12px; border: none; background: transparent; color: var(--text-muted); font-size: 0.83rem; font-weight: 500; cursor: pointer; border-radius: 7px; font-family: inherit; transition: background .15s, color .15s; }
.filter-dd-item:hover { background: rgba(123,94,255,0.1); color: var(--text); }
.filter-dd-item.active { background: rgba(123,94,255,0.12); color: var(--accent-light); font-weight: 600; }
.filter-dd-count { background: rgba(255,255,255,0.07); border-radius: 999px; padding: 1px 8px; font-size: 0.75rem; font-weight: 700; }
.ann-view-toggle {
    display: flex; gap: 2px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px; padding: 3px;
}
.ann-view-btn {
    width: 32px; height: 32px; border: none;
    background: transparent; border-radius: 7px;
    color: var(--text-muted); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all .15s;
}
.ann-view-btn:hover { color: var(--text); }
.ann-view-btn.active { background: rgba(123,94,255,0.2); color: var(--accent-light); }

/* ─── BADGES ────────────────────────────────────────────── */
.role-badge {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 2px 7px; border-radius: 999px; font-size: 0.6rem;
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px;
    margin: 1px 1px 0 0; line-height: 1.4;
}
.badge-client      { background: rgba(34,197,94,0.15);  color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
.badge-fournisseur { background: rgba(168,85,247,0.15); color: #c084fc; border: 1px solid rgba(168,85,247,0.3); }
.badge-employe     { background: rgba(56,189,248,0.15); color: #7dd3fc; border: 1px solid rgba(56,189,248,0.3); }
.badge-investisseur{ background: rgba(250,204,21,0.15); color: #fde047; border: 1px solid rgba(250,204,21,0.3); }
.badge-partenaire  { background: rgba(251,146,60,0.15); color: #fb923c; border: 1px solid rgba(251,146,60,0.3); }

/* ─── LIST VIEW ─────────────────────────────────────────── */
.ann-list-wrap {
    max-height: 65vh; overflow-y: auto; padding-right: 4px;
    scrollbar-width: thin; scrollbar-color: rgba(123,94,255,0.3) transparent;
}
.ann-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.ann-table thead th {
    padding: 10px 14px; text-align: left;
    color: var(--text-muted); font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.4px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    cursor: pointer; user-select: none; white-space: nowrap;
    transition: color .15s;
}
.ann-table thead th:hover { color: var(--accent-light); }
.ann-table thead th .sort-arrow { display: inline-block; margin-left: 4px; opacity: 0.4; font-size: 0.75rem; }
.ann-table thead th.sorted .sort-arrow { opacity: 1; color: var(--accent-light); }
.ann-table tbody tr {
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background .12s;
}
.ann-table tbody tr:hover td { background: rgba(123,94,255,0.04); }
.ann-table tbody td { padding: 10px 14px; color: var(--text); vertical-align: middle; }
.ann-table .td-name { font-weight: 600; white-space: nowrap; }
.ann-table .td-muted { color: var(--text-muted); font-size: 0.82rem; white-space: nowrap; max-width: 180px; overflow: hidden; text-overflow: ellipsis; }
.ann-avatar-mini {
    width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; font-weight: 700; border: 1px solid rgba(255,255,255,0.1);
}

/* ─── GRAPH VIEW ────────────────────────────────────────── */
.ann-graph-wrap {
    position: relative;
    width: 100%; height: calc(68vh - 60px);
    background: radial-gradient(ellipse at 50% 30%, rgba(18,12,40,1) 0%, rgba(2,3,10,1) 70%);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px; overflow: hidden;
}
#graphCanvas { width: 100%; height: 100%; display: block; cursor: default; }
.graph-tooltip {
    position: absolute; pointer-events: none;
    background: rgba(10,14,40,0.95);
    border: 1px solid rgba(123,94,255,0.45);
    border-radius: 10px; padding: 10px 14px;
    font-size: 0.82rem; box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    max-width: 220px; z-index: 10; opacity: 0; transition: opacity .15s;
}
.graph-tooltip.visible { opacity: 1; }
.graph-legend {
    position: absolute; bottom: 16px; left: 16px;
    display: flex; gap: 10px; flex-wrap: wrap;
}
.graph-legend-item {
    display: flex; align-items: center; gap: 5px;
    font-size: 0.72rem; color: var(--text-muted);
}
.graph-legend-dot {
    width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
}
.graph-controls {
    position: absolute; top: 14px; right: 14px;
    display: flex; gap: 6px;
}
.graph-ctrl-btn {
    width: 32px; height: 32px; border: 1px solid rgba(255,255,255,0.1);
    background: rgba(8,11,32,0.9); border-radius: 8px;
    color: var(--text-muted); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all .15s; font-size: 1rem;
}
.graph-ctrl-btn:hover { border-color: var(--accent); color: var(--accent); }

/* ─── EMPTY STATE ───────────────────────────────────────── */
.ann-empty {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; padding: 60px 20px; gap: 14px;
    color: var(--text-muted);
}
.ann-empty svg { opacity: 0.3; }
.ann-empty p { font-size: 0.9rem; margin: 0; }

/* ─── SCROLLBAR ─────────────────────────────────────────── */
#viewGrid::-webkit-scrollbar,
.ann-list-wrap::-webkit-scrollbar { width: 6px; }
#viewGrid::-webkit-scrollbar-thumb,
.ann-list-wrap::-webkit-scrollbar-thumb { background: rgba(123,94,255,0.3); border-radius: 3px; }
</style>
}

@section HeaderLeft {
    <h1>Annuaire Contacts</h1>
    <p>@Model.TotalContacts contact@(Model.TotalContacts > 1 ? "s" : "") — Clients, Fournisseurs, Partenaires et plus</p>
}

<section class="erp-content">

    <!-- ═══ TOOLBAR ═════════════════════════════════════════════════ -->
    <div class="ann-toolbar">

        <!-- Filtre dropdown (gauche) -->
        <div style="position:relative; flex-shrink:0;">
            <button id="btnFilter" onclick="toggleFilterDropdown(event)"
                    style="display:inline-flex;align-items:center;gap:7px;padding:7px 13px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:var(--text-muted);font-size:0.8rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .18s;"
                    onmouseover="this.style.borderColor='rgba(123,94,255,0.45)';this.style.color='var(--text)';"
                    onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='var(--text-muted)';">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                Filtre
                <span id="filterActiveLabel" style="color:var(--accent-light);font-weight:700;font-size:0.78rem;"></span>
                <svg id="filterArrow" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" style="transition:transform .2s;margin-left:2px;"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div id="filterDropdown"
                 style="display:none;position:absolute;left:0;top:calc(100% + 6px);background:#0c1124;border:1px solid rgba(123,94,255,0.22);border-radius:10px;padding:5px;box-shadow:0 14px 36px rgba(0,0,0,0.55);min-width:200px;z-index:200;">
                @{
                    var filterOpts = new[] {
                        new { Label = "Tous",          Count = Model.TotalContacts,   Role = 0 },
                        new { Label = "Clients",       Count = Model.NbClients,       Role = 1 },
                        new { Label = "Fournisseurs",  Count = Model.NbFournisseurs,  Role = 2 },
                        new { Label = "Employés",      Count = Model.NbEmployes,      Role = 4 },
                        new { Label = "Partenaires",   Count = Model.NbPartenaires,   Role = 8 },
                        new { Label = "Investisseurs", Count = Model.NbInvestisseurs, Role = 16 },
                    };
                }
                @foreach (var f in filterOpts)
                {
                    <button class="filter-dd-item @(f.Role == 0 ? "active" : "")"
                            data-role="@f.Role"
                            onclick="filterByRole(@f.Role); closeFilterDropdown();">
                        <span>@f.Label</span>
                        <span class="filter-dd-count">@f.Count</span>
                    </button>
                }
            </div>
        </div>

        <!-- Recherche (centré) -->
        <div style="flex:1; display:flex; justify-content:center;">
            <div class="job-input-wrapper" style="max-width:420px; width:100%;">
                <input type="text" id="searchInput" class="job-input" placeholder="Rechercher nom, email, domaine..."
                       oninput="applyFilters()">
                <span class="job-input-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;">
                        <circle cx="11" cy="11" r="6"/><line x1="16" y1="16" x2="20" y2="20"/>
                    </svg>
                </span>
            </div>
        </div>

        <!-- Vue + toggle + actions (droite) -->
        <div style="display:flex; align-items:center; gap:10px; flex-shrink:0;">
            <!-- Vue toggle -->
            <div style="display:flex; align-items:center; gap:7px;">
                <span style="font-size:0.78rem; color:var(--text-muted); font-weight:600;">Vue</span>
                <div class="ann-view-toggle">
                    <button class="ann-view-btn active" id="btnGrid" onclick="setView('grid')" title="Grille">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15"><path d="M3 3h7v7H3zm0 11h7v7H3zm11-11h7v7h-7zm0 11h7v7h-7z"/></svg>
                    </button>
                    <button class="ann-view-btn" id="btnList" onclick="setView('list')" title="Liste">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                    </button>
                    <button class="ann-view-btn" id="btnGraph" onclick="setView('graph')" title="Graphe">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                    </button>
                </div>
            </div>

            <!-- Export CSV -->
            <a href="/AnnuaireList?handler=ExportCsv"
               style="display:inline-flex;align-items:center;gap:5px;padding:7px 13px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:var(--text-muted);font-size:0.8rem;font-weight:600;text-decoration:none;transition:all .18s;"
               onmouseover="this.style.borderColor='rgba(123,94,255,0.45)';this.style.color='var(--text)';"
               onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='var(--text-muted)';">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Export CSV
            </a>

            <!-- Créer Contact -->
            <a asp-page="/AnnuaireNew"
               class="sidebar-quick"
               style="display:inline-flex;align-items:center;gap:6px;padding-inline:16px;text-decoration:none;">
                <span>Créer Contact</span>
                <span style="font-size:16px;line-height:1">+</span>
            </a>
        </div>
    </div>

    <!-- ═══ VUE GRILLE ═══════════════════════════════════════════════ -->
    <div id="viewGrid"
         style="display:grid; grid-template-columns:repeat(4, minmax(0, 1fr)); gap:16px; max-height:65vh; overflow-y:auto; padding-right:8px;">
        <!-- Contenu injecté par JS via renderGrid() -->
    </div>

    <!-- ═══ VUE LISTE ════════════════════════════════════════════════ -->
    <div id="viewList" style="display:none;">
        <div class="ann-list-wrap">
            <table class="ann-table">
                <thead>
                    <tr>
                        <th style="width:42px;"></th>
                        <th onclick="sortBy('name')" data-col="name">Nom <span class="sort-arrow">↕</span></th>
                        <th onclick="sortBy('email')" data-col="email">Email <span class="sort-arrow">↕</span></th>
                        <th onclick="sortBy('phone')" data-col="phone">Téléphone <span class="sort-arrow">↕</span></th>
                        <th onclick="sortBy('domain')" data-col="domain">Domaine <span class="sort-arrow">↕</span></th>
                        <th>Rôles</th>
                        <th onclick="sortBy('dateTs')" data-col="dateTs">Créé le <span class="sort-arrow">↕</span></th>
                        <th style="width:70px;"></th>
                    </tr>
                </thead>
                <tbody id="listBody">
                    <!-- Contenu injecté par JS via renderList() -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- ═══ VUE GRAPHE ═══════════════════════════════════════════════ -->
    <div id="viewGraph" style="display:none;">
        <div class="ann-graph-wrap">
            <canvas id="graphCanvas"></canvas>
            <div id="graphTooltip" class="graph-tooltip">
                <div id="ttName" style="font-weight:700; color:var(--text); margin-bottom:4px;"></div>
                <div id="ttDomain" style="color:var(--text-muted); font-size:0.78rem;"></div>
                <div id="ttEmail" style="color:var(--text-muted); font-size:0.78rem; margin-top:2px;"></div>
                <div id="ttRoles" style="margin-top:6px; display:flex; gap:3px; flex-wrap:wrap;"></div>
            </div>
            <div class="graph-controls">
                <button class="graph-ctrl-btn" onclick="resetZoom()" title="Recentrer">⊕</button>
                <button class="graph-ctrl-btn" onclick="reSimulate()" title="Réorganiser">↺</button>
            </div>
            <div class="graph-legend" id="graphLegend"></div>
        </div>
    </div>

</section>

<!-- MODAL APERÇU LOGO -->
<div id="contact-image-overlay" class="logout-overlay" style="display:none; background:rgba(3,6,23,0.8);" onclick="this.style.display='none'">
    <div class="logout-modal" style="max-width:520px; width:90%; padding:12px 12px 16px 12px;" onclick="event.stopPropagation();">
        <h3 style="margin-bottom:10px;">Aperçu du Logo</h3>
        <div style="border-radius:16px; overflow:hidden; border:1px solid var(--border-soft); background:#fff; max-height:70vh; display:flex; align-items:center; justify-content:center;">
            <img id="contact-image-modal-img" src="" alt="Logo" style="max-width:100%; max-height:70vh; object-fit:contain; padding:20px;" />
        </div>
        <div class="logout-modal-actions" style="margin-top:12px;">
            <button type="button" class="btn-primary" onclick="document.getElementById('contact-image-overlay').style.display='none'">Fermer</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ═══════════════════════════════════════════════════════════════════
//  DONNÉES
// ═══════════════════════════════════════════════════════════════════
const ALL_CONTACTS = @Html.Raw(contactsJson);
const GRAPH_DATA   = @Html.Raw(graphDataJson);

const ROLE_META = {
    0:  { label: 'Tous',         color: '#9C8CFF', cls: '' },
    1:  { label: 'Client',       color: '#4ade80', cls: 'badge-client' },
    2:  { label: 'Fournisseur',  color: '#c084fc', cls: 'badge-fournisseur' },
    4:  { label: 'Employé',      color: '#7dd3fc', cls: 'badge-employe' },
    8:  { label: 'Partenaire',   color: '#fb923c', cls: 'badge-partenaire' },
    16: { label: 'Investisseur', color: '#fde047', cls: 'badge-investisseur' },
};

let currentRole = 0;
let currentSort = { col: 'dateTs', dir: -1 };
let filteredContacts = [...ALL_CONTACTS];
let currentView = 'grid';

// ═══════════════════════════════════════════════════════════════════
//  UTILITAIRES
// ═══════════════════════════════════════════════════════════════════
function getRoleColor(roles) {
    if (!roles) return '#94a3b8';
    for (const bit of [1, 2, 16, 8, 4]) {
        if (roles & bit) return ROLE_META[bit].color;
    }
    return '#94a3b8';
}

function getRoleBadges(roles) {
    if (!roles) return '';
    let html = '';
    for (const bit of [1, 2, 4, 8, 16]) {
        if (roles & bit) {
            const m = ROLE_META[bit];
            html += `<span class="role-badge ${m.cls}">${m.label}</span>`;
        }
    }
    return html;
}

function getClearbitUrl(c) {
    return c.domain ? `https://logo.clearbit.com/${c.domain}` : null;
}

function openContactImageModal(url) {
    if (!url) return;
    document.getElementById('contact-image-modal-img').src = url;
    document.getElementById('contact-image-overlay').style.display = 'flex';
}

// ═══════════════════════════════════════════════════════════════════
//  FILTRAGE & RECHERCHE
// ═══════════════════════════════════════════════════════════════════
// ─── DROPDOWN FILTRE ──────────────────────────────────────────────
let filterOpen = false;

function toggleFilterDropdown(e) {
    e.stopPropagation();
    filterOpen = !filterOpen;
    const dd = document.getElementById('filterDropdown');
    const arrow = document.getElementById('filterArrow');
    dd.style.display = filterOpen ? 'block' : 'none';
    arrow.style.transform = filterOpen ? 'rotate(180deg)' : '';
}

function closeFilterDropdown() {
    filterOpen = false;
    const dd = document.getElementById('filterDropdown');
    const arrow = document.getElementById('filterArrow');
    if (dd) dd.style.display = 'none';
    if (arrow) arrow.style.transform = '';
}

function filterByRole(role) {
    currentRole = role;

    // Sync dropdown items
    document.querySelectorAll('.filter-dd-item').forEach(item => {
        item.classList.toggle('active', parseInt(item.dataset.role) === role);
    });

    // Mettre à jour le label actif sur le bouton
    const activeItem = document.querySelector(`.filter-dd-item[data-role="${role}"]`);
    const labelEl = document.getElementById('filterActiveLabel');
    if (labelEl) {
        labelEl.textContent = (role === 0 || !activeItem) ? '' : '· ' + activeItem.querySelector('span').textContent;
    }

    applyFilters();
}

function applyFilters() {
    const q = (document.getElementById('searchInput')?.value || '').toLowerCase().trim();
    filteredContacts = ALL_CONTACTS.filter(c => {
        const matchRole = currentRole === 0 || (c.roles & currentRole);
        const matchSearch = !q ||
            c.name.toLowerCase().includes(q) ||
            c.email.toLowerCase().includes(q) ||
            c.domain.toLowerCase().includes(q) ||
            c.phone.includes(q);
        return matchRole && matchSearch;
    });
    if (currentView === 'grid')  renderGrid();
    if (currentView === 'list')  renderList();
    if (currentView === 'graph') updateGraphFilter();
}

// ═══════════════════════════════════════════════════════════════════
//  VUE GRILLE
// ═══════════════════════════════════════════════════════════════════
function renderGrid() {
    const container = document.getElementById('viewGrid');
    if (!filteredContacts.length) {
        container.style.gridTemplateColumns = '1fr';
        container.innerHTML = `
            <div class="ann-empty">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                <p>Aucun contact correspond à la recherche.</p>
            </div>`;
        return;
    }
    container.style.gridTemplateColumns = 'repeat(4, minmax(0, 1fr))';
    container.innerHTML = filteredContacts.map(c => {
        const logoUrl = getClearbitUrl(c);
        const logo = logoUrl
