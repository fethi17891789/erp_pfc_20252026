    }).join('');
}

// ═══════════════════════════════════════════════════════════════════
//  VUE LISTE
// ═══════════════════════════════════════════════════════════════════
function sortBy(col) {
    if (currentSort.col === col) {
        currentSort.dir *= -1;
    } else {
        currentSort.col = col;
        currentSort.dir = 1;
    }
    document.querySelectorAll('.ann-table th[data-col]').forEach(th => {
        th.classList.toggle('sorted', th.dataset.col === col);
        if (th.dataset.col === col) {
            th.querySelector('.sort-arrow').textContent = currentSort.dir === 1 ? '↑' : '↓';
        } else if (th.querySelector('.sort-arrow')) {
            th.querySelector('.sort-arrow').textContent = '↕';
        }
    });
    renderList();
}

function renderList() {
    const sorted = [...filteredContacts].sort((a, b) => {
        const va = a[currentSort.col] ?? '';
        const vb = b[currentSort.col] ?? '';
        if (va < vb) return -1 * currentSort.dir;
        if (va > vb) return  1 * currentSort.dir;
        return 0;
    });

    const tbody = document.getElementById('listBody');
    if (!sorted.length) {
        tbody.innerHTML = `<tr><td colspan="8"><div class="ann-empty" style="padding:40px 0;"><p>Aucun contact correspond à la recherche.</p></div></td></tr>`;
        return;
    }

    tbody.innerHTML = sorted.map(c => {
        const logoUrl = getClearbitUrl(c);
        const avatar = logoUrl
            ? `<img src="${logoUrl}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                    style="width:32px;height:32px;border-radius:8px;object-fit:contain;border:1px solid rgba(255,255,255,0.1);background:#fff;padding:2px;"/>
               <div class="ann-avatar-mini" style="display:none;background:rgba(123,94,255,0.15);color:#9C8CFF;">${c.initials}</div>`
            : `<div class="ann-avatar-mini" style="background:rgba(123,94,255,0.15);color:#9C8CFF;">${c.initials}</div>`;

        return `<tr>
            <td><div style="display:flex;align-items:center;">${avatar}</div></td>
            <td class="td-name"><a href="/AnnuaireNew/${c.id}" style="color:var(--text);text-decoration:none;">${c.name}</a></td>
            <td class="td-muted">${c.email || '—'}</td>
            <td class="td-muted">${c.phone || '—'}</td>
            <td class="td-muted">${c.domain || '—'}</td>
            <td>${getRoleBadges(c.roles) || '<span style="color:var(--text-muted);font-size:0.8rem;">—</span>'}</td>
            <td class="td-muted">${c.date}</td>
            <td>
                <div style="display:flex;gap:6px;">
                    <a href="/AnnuaireNew/${c.id}" style="color:var(--text-muted);transition:color .15s;" title="Modifier"
                       onmouseover="this.style.color='var(--accent-light)'" onmouseout="this.style.color='var(--text-muted)'">
                        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </a>
                    <form method="post" asp-page-handler="Delete" style="margin:0;display:inline;">
                        <input type="hidden" name="id" value="${c.id}"/>
                        <button type="submit" onclick="return confirm('Supprimer ?')"
                                style="background:none;border:none;color:var(--text-muted);cursor:pointer;padding:0;transition:color .15s;"
                                title="Supprimer"
                                onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='var(--text-muted)'">
                            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                        </button>
                    </form>
                </div>
            </td>
        </tr>`;
    }).join('');
}

// ═══════════════════════════════════════════════════════════════════
//  GESTION DES VUES
// ═══════════════════════════════════════════════════════════════════
function setView(view) {
    currentView = view;
    document.getElementById('viewGrid').style.display  = view === 'grid'  ? 'grid'  : 'none';
    document.getElementById('viewList').style.display  = view === 'list'  ? 'block' : 'none';
    document.getElementById('viewGraph').style.display = view === 'graph' ? 'block' : 'none';

    document.getElementById('btnGrid').classList.toggle('active',  view === 'grid');
    document.getElementById('btnList').classList.toggle('active',  view === 'list');
    document.getElementById('btnGraph').classList.toggle('active', view === 'graph');

    if (view === 'grid')  renderGrid();
    if (view === 'list')  renderList();
    if (view === 'graph') initGraph();
}

// ═══════════════════════════════════════════════════════════════════
//  GRAPHE DE RÉSEAU (force-directed, Canvas pur)
// ═══════════════════════════════════════════════════════════════════
let graphNodes = [], graphEdges = [];
let canvas, ctx, simAnim = null;
let zoom = 1, panX = 0, panY = 0;
let isDragging = false, dragStart = { x: 0, y: 0 }, panStart = { x: 0, y: 0 };
let hoveredNode = null;

function initGraph() {
    canvas = document.getElementById('graphCanvas');
    ctx    = canvas.getContext('2d');

    // Resize canvas to container
    const wrap = canvas.parentElement;
    canvas.width  = wrap.offsetWidth;
    canvas.height = wrap.offsetHeight;

    // Build nodes from current filtered contacts
    updateGraphFilter();
    buildLegend();
}

function updateGraphFilter() {
    if (!canvas) return;

    const filteredIds = new Set(filteredContacts.map(c => c.id));

    // Nœud "Moi" — toujours présent au centre, ancré, jamais déplacé
    const moiNode = {
        id: -1, name: 'Mon Entreprise', initials: 'MOI',
        roles: 0, domain: '', email: '', isMoi: true,
        x: canvas.width / 2, y: canvas.height / 2,
        vx: 0, vy: 0, r: 36
    };

    graphNodes = [moiNode, ...GRAPH_DATA.nodes
        .filter(n => filteredIds.has(n.id))
        .map(n => ({
            ...n,
            x: canvas.width  / 2 + (Math.random() - 0.5) * canvas.width  * 0.6,
            y: canvas.height / 2 + (Math.random() - 0.5) * canvas.height * 0.6,
            vx: 0, vy: 0, r: 28
        }))];

    // Arêtes implicites : Moi → chaque contact visible
    const moiEdges = filteredContacts.map(c => ({
        source: -1, target: c.id, type: '', isMoiEdge: true
    }));

    // Relations explicites entre contacts
    const relationEdges = GRAPH_DATA.edges
        .filter(e => filteredIds.has(e.source) && filteredIds.has(e.target))
        .map(e => ({ ...e, isMoiEdge: false }));

    graphEdges = [...moiEdges, ...relationEdges];

    reSimulate();
}

function reSimulate() {
    if (!canvas) return;
    if (simAnim) cancelAnimationFrame(simAnim);

    // Re-scatter nodes (Moi reste ancré au centre)
    graphNodes.forEach(n => {
        if (n.isMoi) { n.x = canvas.width / 2; n.y = canvas.height / 2; n.vx = 0; n.vy = 0; return; }
        const angle = Math.random() * Math.PI * 2;
        const r = Math.min(canvas.width, canvas.height) * 0.28;
        n.x = canvas.width  / 2 + r * Math.cos(angle) * (0.5 + Math.random());
        n.y = canvas.height / 2 + r * Math.sin(angle) * (0.5 + Math.random());
        n.vx = 0; n.vy = 0;
    });

    let frame = 0;
    const maxFrames = 180;

    function tick() {
        const alpha = Math.max(0, 1 - frame / maxFrames);
        simulateStep(alpha);
        drawGraph();
        frame++;
        if (frame < maxFrames) simAnim = requestAnimationFrame(tick);
    }
    simAnim = requestAnimationFrame(tick);
}

function simulateStep(alpha) {
    const W = canvas.width, H = canvas.height;
    const cx = W / 2, cy = H / 2;

    // Répulsion entre toutes les paires
    for (let i = 0; i < graphNodes.length; i++) {
        for (let j = i + 1; j < graphNodes.length; j++) {
            const a = graphNodes[i], b = graphNodes[j];
            const dx = b.x - a.x, dy = b.y - a.y;
            const dist = Math.max(Math.sqrt(dx * dx + dy * dy), 1);
            const force = (7500 / (dist * dist)) * alpha * 0.015;
            const fx = (dx / dist) * force, fy = (dy / dist) * force;
            a.vx -= fx; a.vy -= fy;
            b.vx += fx; b.vy += fy;
        }
    }

    // Attraction le long des arêtes
    for (const e of graphEdges) {
        const s = graphNodes.find(n => n.id === e.source);
        const t = graphNodes.find(n => n.id === e.target);
        if (!s || !t) continue;
        const dx = t.x - s.x, dy = t.y - s.y;
        const dist = Math.max(Math.sqrt(dx * dx + dy * dy), 1);
        const ideal = 160;
        const force = (dist - ideal) * 0.012 * alpha;
        const fx = (dx / dist) * force, fy = (dy / dist) * force;
        s.vx += fx; s.vy += fy;
        t.vx -= fx; t.vy -= fy;
    }

    // Gravité vers le centre + amortissement (Moi ancré, ne bouge pas)
    graphNodes.forEach(n => {
        if (n.isMoi) { n.vx = 0; n.vy = 0; n.x = W / 2; n.y = H / 2; return; }
        n.vx += (cx - n.x) * 0.0015 * alpha;
        n.vy += (cy - n.y) * 0.0015 * alpha;
        n.vx *= 0.84; n.vy *= 0.84;
        n.x += n.vx; n.y += n.vy;
        n.x = Math.max(n.r + 8, Math.min(W - n.r - 8, n.x));
        n.y = Math.max(n.r + 8, Math.min(H - n.r - 8, n.y));
    });
}

function drawGraph() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    if (!graphNodes.length) {
        drawEmptyGraph();
        return;
    }

    ctx.save();
    ctx.translate(panX, panY);
    ctx.scale(zoom, zoom);

    // ── Arêtes ──────────────────────────────────────────────────
    for (const e of graphEdges) {
        const s = graphNodes.find(n => n.id === e.source);
        const t = graphNodes.find(n => n.id === e.target);
        if (!s || !t) continue;

        const dx = t.x - s.x, dy = t.y - s.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const ux = dx / dist, uy = dy / dist;
        const sx = s.x + ux * s.r, sy = s.y + uy * s.r;
        const tx = t.x - ux * t.r, ty = t.y - uy * t.r;

        if (e.isMoiEdge) {
            // Lien implicite Moi → contact : pointillé violet subtil, sans flèche
            ctx.beginPath();
            ctx.setLineDash([4, 7]);
            ctx.moveTo(sx, sy);
            ctx.lineTo(tx, ty);
            ctx.strokeStyle = 'rgba(123,94,255,0.22)';
            ctx.lineWidth = 1;
            ctx.stroke();
            ctx.setLineDash([]);
        } else {
            // Relation explicite entre contacts : trait plein + flèche + label
            ctx.beginPath();
            ctx.moveTo(sx, sy);
            ctx.lineTo(tx, ty);
            ctx.strokeStyle = 'rgba(148,163,184,0.35)';
            ctx.lineWidth = 1.5;
            ctx.stroke();

            const arrowLen = 8, arrowAngle = 0.4;
            ctx.beginPath();
            ctx.moveTo(tx, ty);
            ctx.lineTo(tx - arrowLen * Math.cos(Math.atan2(uy, ux) - arrowAngle),
                       ty - arrowLen * Math.sin(Math.atan2(uy, ux) - arrowAngle));
            ctx.moveTo(tx, ty);
            ctx.lineTo(tx - arrowLen * Math.cos(Math.atan2(uy, ux) + arrowAngle),
                       ty - arrowLen * Math.sin(Math.atan2(uy, ux) + arrowAngle));
            ctx.strokeStyle = 'rgba(148,163,184,0.55)';
            ctx.lineWidth = 1.2;
            ctx.stroke();

            if (e.type) {
                const mx = (sx + tx) / 2, my = (sy + ty) / 2;
                ctx.fillStyle = 'rgba(148,163,184,0.7)';
                ctx.font = '10px "Plus Jakarta Sans", sans-serif';
                ctx.textAlign = 'center';
                ctx.fillText(e.type, mx, my - 4);
            }
        }
    }

    // ── Nœuds ────────────────────────────────────────────────────
    for (const n of graphNodes) {
        const isHovered = hoveredNode && hoveredNode.id === n.id;
        const color = n.isMoi ? '#7b5eff' : getRoleColor(n.roles);
        const r = isHovered ? n.r + 3 : n.r;

        // Halo glow
        if (isHovered || n.isMoi) {
            const haloGrad = ctx.createRadialGradient(n.x, n.y, r * 0.5, n.x, n.y, r * 2.2);
            haloGrad.addColorStop(0, color + (n.isMoi ? '44' : '55'));
            haloGrad.addColorStop(1, 'transparent');
            ctx.beginPath();
            ctx.arc(n.x, n.y, r * 2.2, 0, Math.PI * 2);
            ctx.fillStyle = haloGrad;
            ctx.fill();
        }

        // Cercle principal
        ctx.beginPath();
        ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
        const grad = ctx.createRadialGradient(n.x - r * 0.3, n.y - r * 0.3, r * 0.1, n.x, n.y, r);
        if (n.isMoi) {
            grad.addColorStop(0, '#a78bfa');
            grad.addColorStop(1, '#6d28d9');
        } else {
            grad.addColorStop(0, color + 'CC');
            grad.addColorStop(1, color + '66');
        }
        ctx.fillStyle = grad;
        ctx.fill();

        // Bordure
        ctx.beginPath();
        ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
        ctx.strokeStyle = n.isMoi ? '#a78bfa' : (isHovered ? color : color + '88');
        ctx.lineWidth = n.isMoi ? 2.5 : (isHovered ? 2 : 1.5);
        ctx.stroke();

        // Initiales
        ctx.fillStyle = '#fff';
        ctx.font = `700 ${Math.round(r * (n.isMoi ? 0.4 : 0.45))}px "Plus Jakarta Sans", sans-serif`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(n.initials, n.x, n.y);

        // Nom sous le nœud
        ctx.fillStyle = n.isMoi ? '#c4b5fd' : (isHovered ? '#fff' : 'rgba(196,206,231,0.8)');
        ctx.font = `${(isHovered || n.isMoi) ? '600' : '500'} ${n.isMoi ? 12 : 11}px "Plus Jakarta Sans", sans-serif`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        const label = n.name.length > 16 ? n.name.slice(0, 14) + '…' : n.name;
        ctx.fillText(label, n.x, n.y + r + 5);
    }

    ctx.restore();
}

function drawEmptyGraph() {
    ctx.fillStyle = 'rgba(148,163,184,0.25)';
    ctx.font = '500 15px "Plus Jakarta Sans", sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('Aucun contact à afficher dans ce graphe.', canvas.width / 2, canvas.height / 2);
    ctx.fillStyle = 'rgba(123,94,255,0.3)';
    ctx.font = '500 13px "Plus Jakarta Sans", sans-serif';
    ctx.fillText('Créez des contacts pour voir le réseau.', canvas.width / 2, canvas.height / 2 + 28);
}

// ── Zoom & Pan ────────────────────────────────────────────────────
function resetZoom() {
    zoom = 1; panX = 0; panY = 0;
    drawGraph();
}

function getNodeAt(mx, my) {
    const wx = (mx - panX) / zoom, wy = (my - panY) / zoom;
    return graphNodes.find(n => Math.hypot(n.x - wx, n.y - wy) <= n.r + 4) || null;
}

function buildLegend() {
    const usedRoles = new Set();
    graphNodes.forEach(n => { for (const bit of [1,2,4,8,16]) if (n.roles & bit) usedRoles.add(bit); });
    const legend = document.getElementById('graphLegend');
    if (!legend) return;
    if (!usedRoles.size) { legend.innerHTML = ''; return; }
    legend.innerHTML = [...usedRoles].map(bit => {
        const m = ROLE_META[bit];
        return `<div class="graph-legend-item">
            <div class="graph-legend-dot" style="background:${m.color};"></div>
            <span>${m.label}</span>
        </div>`;
    }).join('');
}

// ── Événements souris sur le canvas ──────────────────────────────
function setupGraphEvents() {
    if (!canvas) return;

    canvas.addEventListener('wheel', e => {
        e.preventDefault();
        const factor = e.deltaY < 0 ? 1.1 : 0.9;
        zoom = Math.max(0.3, Math.min(3, zoom * factor));
        drawGraph();
    }, { passive: false });

    canvas.addEventListener('mousedown', e => {
        isDragging = true;
        dragStart = { x: e.offsetX, y: e.offsetY };
        panStart  = { x: panX, y: panY };
        canvas.style.cursor = 'grabbing';
    });

    canvas.addEventListener('mousemove', e => {
        if (isDragging) {
            panX = panStart.x + (e.offsetX - dragStart.x);
            panY = panStart.y + (e.offsetY - dragStart.y);
            drawGraph();
            return;
        }
        const node = getNodeAt(e.offsetX, e.offsetY);
        if (node !== hoveredNode) {
            hoveredNode = node;
            canvas.style.cursor = node ? 'pointer' : 'default';
            drawGraph();
        }
        updateTooltip(e, node);
    });

    canvas.addEventListener('mouseup', () => {
        isDragging = false;
        canvas.style.cursor = hoveredNode ? 'pointer' : 'default';
    });

    canvas.addEventListener('mouseleave', () => {
        isDragging = false;
        hoveredNode = null;
        hideTooltip();
        drawGraph();
    });

    canvas.addEventListener('click', e => {
        const node = getNodeAt(e.offsetX, e.offsetY);
        if (node && !node.isMoi) window.location.href = `/AnnuaireNew/${node.id}`;
    });
}

function updateTooltip(e, node) {
    const tt = document.getElementById('graphTooltip');
    if (!node) { hideTooltip(); return; }

    if (node.isMoi) {
        document.getElementById('ttName').textContent   = 'Mon Entreprise';
        document.getElementById('ttDomain').textContent = 'Centre de votre réseau';
        document.getElementById('ttEmail').textContent  = `${graphNodes.length - 1} contact(s) connecté(s)`;
        document.getElementById('ttRoles').innerHTML    = '';
    } else {
        document.getElementById('ttName').textContent   = node.name;
        document.getElementById('ttDomain').textContent = node.domain || '';
        document.getElementById('ttEmail').textContent  = node.email  || '';
        document.getElementById('ttRoles').innerHTML    = getRoleBadges(node.roles);
    }

    const wrap = canvas.parentElement.getBoundingClientRect();
    const canvasRect = canvas.getBoundingClientRect();
    let tx = e.offsetX + 16, ty = e.offsetY - 10;
    if (tx + 230 > canvas.width)  tx = e.offsetX - 230;
    if (ty + 100 > canvas.height) ty = e.offsetY - 110;

    tt.style.left = tx + 'px';
    tt.style.top  = ty + 'px';
    tt.classList.add('visible');
}

function hideTooltip() {
    document.getElementById('graphTooltip')?.classList.remove('visible');
}

// ═══════════════════════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
    renderGrid();

    // Fermer les dropdowns au clic extérieur
    document.addEventListener('click', () => {
        document.querySelectorAll('.contact-dd').forEach(d => d.style.display = 'none');
        closeFilterDropdown();
    });

    // Setup canvas events (disponibles même si graph pas encore ouvert)
    requestAnimationFrame(() => {
        if (document.getElementById('graphCanvas')) setupGraphEvents();
    });
});
</script>
