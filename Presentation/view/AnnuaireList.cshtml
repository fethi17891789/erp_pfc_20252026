                            <div class="product-card-subtitle">${c.domain || '—'}</div>
                            <div class="product-card-stock" style="font-size:0.75rem;">${c.email || 'Pas d\'email'}</div>
                            <div class="product-card-price" style="font-size:0.75rem;">${c.phone || 'Pas de téléphone'}</div>
