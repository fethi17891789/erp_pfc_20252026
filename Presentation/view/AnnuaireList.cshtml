@page
@model erp_pfc_20252026.Pages.AnnuaireListModel
@{
    ViewData["Title"] = "Annuaire Contacts";
}
@section Styles {
    <style>
        .role-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 2px 7px;
            border-radius: 999px;
            font-size: 0.6rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            margin-top: 2px;
            line-height: 1.4;
        }
        .badge-client { background: rgba(34, 197, 94, 0.15); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.3); }
        .badge-fournisseur { background: rgba(168, 85, 247, 0.15); color: #c084fc; border: 1px solid rgba(168, 85, 247, 0.3); }
        .badge-employe { background: rgba(56, 189, 248, 0.15); color: #7dd3fc; border: 1px solid rgba(56, 189, 248, 0.3); }
        .badge-investisseur { background: rgba(250, 204, 21, 0.15); color: #fde047; border: 1px solid rgba(250, 204, 21, 0.3); }

        /* Compacter les infos dans les cartes */
        .contact-card-info .product-card-stock,
        .contact-card-info .product-card-price {
            font-size: 0.75rem !important;
            margin-top: 0 !important;
            line-height: 1.3;
        }
        .contact-card-info .product-card-subtitle {
            margin-bottom: 2px !important;
        }
    </style>
}

@section HeaderLeft {
    <h1>Annuaire Contacts</h1>
    <p>Gérez vos clients, fournisseurs et employés.</p>
}

<section class="erp-content">

    <!-- Toolbar -->
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
        <div style="flex:1; display:flex; justify-content:center;">
            <div class="job-input-wrapper" style="max-width:420px; width:100%;">
                <input type="text" class="job-input" placeholder="Rechercher par nom, email...">
                <span class="job-input-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px;">
                        <circle cx="11" cy="11" r="6"></circle>
                        <line x1="16" y1="16" x2="20" y2="20"></line>
                    </svg>
                </span>
            </div>
        </div>
        <div style="margin-left:16px;">
            <a asp-page="/AnnuaireNew"
               class="sidebar-quick"
               style="display:inline-flex; align-items:center; gap:6px; padding-inline:16px; text-decoration:none;">
                <span>Créer Contact</span>
                <span style="font-size:16px; line-height:1">+</span>
            </a>
        </div>
    </div>

    <!-- GRILLE CONTACTS -->
    <div id="contactsContainer"
         style="display:grid; grid-template-columns:repeat(4, minmax(0, 1fr)); gap:16px; max-height:70vh; overflow-y:auto; padding-right:8px;">

        @{
            var contacts = new[] {
                new { Name = "Tesla, Inc.", Domain = "tesla.com", Email = "contact@@tesla.com", Phone = "+1 800 555 1234", Role = "Client", RoleClass = "badge-client", Initials = "TE", HasLogo = true, Id = 1 },
                new { Name = "John Doe", Domain = "(Particulier)", Email = "jdoe@@example.com", Phone = "+33 6 12 34 56 78", Role = "Employé", RoleClass = "badge-employe", Initials = "JD", HasLogo = false, Id = 2 },
                new { Name = "Sony Group", Domain = "sony.com", Email = "supply@@sony.co.jp", Phone = "+81 3 1234 5678", Role = "Fournisseur", RoleClass = "badge-fournisseur", Initials = "SO", HasLogo = true, Id = 3 }
            };
        }

        @foreach (var c in contacts)
        {
            <div class="form-group product-item" style="margin:0; position:relative;">
                <div class="product-card"
                     style="
                         padding:12px 12px;
                         background:linear-gradient(135deg, rgba(8,11,32,0.96), rgba(18,22,54,0.96));
                         border:1px solid var(--border-soft);
                         border-radius:var(--radius-sm);
                         display:flex;
                         flex-direction:column;
                         gap:8px;
                         transition:border-color 140ms cubic-bezier(0.2,0.8,0.2,1),
                                    box-shadow 140ms cubic-bezier(0.2,0.8,0.2,1),
                                    transform 80ms ease-out,
                                    background 140ms cubic-bezier(0.2,0.8,0.2,1);
                     "
                     onmouseover="this.style.borderColor='var(--accent-glow)'; this.style.boxShadow='0 14px 40px rgba(123,94,255,0.35)'; this.style.transform='translateY(-2px)'; this.style.background='linear-gradient(135deg, rgba(15,18,48,1), rgba(25,30,70,1))';"
                     onmouseout="this.style.borderColor='var(--border-soft)'; this.style.boxShadow='none'; this.style.transform='translateY(0)'; this.style.background='linear-gradient(135deg, rgba(8,11,32,0.96), rgba(18,22,54,0.96))';">
                    <div class="product-card-header">

                        <!-- IMAGE / LOGO -->
                        @if (c.HasLogo)
                        {
                            <div style="width:80px; height:100px; border-radius:14px; overflow:hidden; border:1px solid rgba(148,163,184,0.5); background:white; flex-shrink:0; display:flex; align-items:center; justify-content:center; cursor:pointer;"
                                 onclick="openContactImageModal('https://logo.clearbit.com/@(c.Domain)'); event.stopPropagation();">
                                <img src="https://logo.clearbit.com/@(c.Domain)"
                                     onerror="this.parentElement.innerHTML='<span style=\'font-size:1.5rem;font-weight:bold;color:#94a3b8;\'>@c.Initials</span>';"
                                     alt="Logo @c.Name"
                                     style="max-width:100%; max-height:100%; object-fit:contain; padding:6px;" />
                            </div>
                        }
                        else
                        {
                            <div style="width:80px; height:100px; border-radius:14px; overflow:hidden; border:1px solid rgba(148,163,184,0.5); background:#020617; flex-shrink:0; display:flex; align-items:center; justify-content:center; color:white; font-size:1.5rem; font-weight:bold;">
                                @c.Initials
                            </div>
                        }

                        <!-- TEXTE -->
                        <a asp-page="/AnnuaireNew" asp-route-id="@c.Id" style="text-decoration:none; color:inherit; flex:1; min-width:0;">
                            <div class="product-card-text contact-card-info">
                                <div class="product-card-title">@c.Name</div>
                                <div class="product-card-subtitle">@c.Domain</div>
                                <div class="product-card-stock">
                                    @c.Email
                                </div>
                                <div class="product-card-price">
                                    <span>@c.Phone</span>
                                </div>
                                <div>
                                    <span class="role-badge @c.RoleClass">@c.Role</span>
                                </div>
                            </div>
                        </a>

                    </div>
                </div>
            </div>
        }

    </div>
</section>

<!-- MODAL APERÇU GRANDE IMAGE -->
<div id="contact-image-overlay" class="logout-overlay" style="display:none; background:rgba(3,6,23,0.8);" onclick="this.style.display='none'">
    <div class="logout-modal" style="max-width:520px; width:90%; padding:12px 12px 16px 12px;" onclick="event.stopPropagation();">
        <h3 style="margin-bottom:10px;">Aperçu du Logo</h3>
        <div style="border-radius:16px; overflow:hidden; border:1px solid var(--border-soft); background:#fff; max-height:70vh; display:flex; align-items:center; justify-content:center;">
            <img id="contact-image-modal-img" src="" alt="Logo" style="max-width:100%; max-height:70vh; object-fit:contain; padding:20px;" />
        </div>
        <div class="logout-modal-actions" style="margin-top:12px;">
            <button type="button" class="btn-primary" onclick="document.getElementById('contact-image-overlay').style.display='none'">Fermer</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openContactImageModal(url) {
        if (!url) return;
        var overlay = document.getElementById('contact-image-overlay');
        var img = document.getElementById('contact-image-modal-img');
        if (overlay && img) {
            img.src = url;
            overlay.style.display = 'flex';
        }
    }
</script>
}
